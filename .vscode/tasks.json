{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build solution",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Mercadito.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "run frontend",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/Mercadito.Frontend/Mercadito.Frontend.csproj",
                "--urls",
                "http://localhost:5038"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run sales api",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/Mercadito.Sales.Api/Mercadito.Sales.Api.csproj",
                "--urls",
                "http://localhost:5101"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run users api",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/Mercadito.Users.Api/Mercadito.Users.Api.csproj",
                "--urls",
                "http://localhost:5102"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
