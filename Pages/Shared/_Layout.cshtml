@inject Mercadito.Pages.Shared.Navigation.INavigationMenuService NavigationMenuService
@{
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var navigationMenu = NavigationMenuService.Build(User, currentUrl);
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mercadito</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/fonts-local.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Mercadito.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light mb-4 py-2">
            <section class="container d-flex align-items-center">
                <a class="navbar-brand d-inline-flex align-items-center gap-2 m-0 p-0" asp-area="" asp-page="/Index">
                    <img src="~/favicon.svg" alt="" class="app-brand-logo" />
                    Mercadito
                </a>
                <button class="navbar-toggler btn-menu-only ms-auto" style="padding: 0; border: none;" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list" style="font-size: 2rem; line-height: 1; color: var(--mrc-ink);"></i>
                </button>
                <section class="navbar-collapse collapse d-sm-inline-flex justify-content-start align-items-center flex-grow-1">
                    <menu class="navbar-nav m-0 ps-4 gap-2 align-items-center w-100 p-0">
                        @foreach (var item in navigationMenu.Items)
                        {
                            if (item.Dropdown == null)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-page="@item.PagePath">@item.Label</a>
                                </li>
                            }
                            else
                            {
                                <partial name="_NavigationDropdown" model="item" />
                            }
                        }
                        <li class="nav-item nav-auth-item ms-sm-auto mt-2 mt-sm-0">
                            <section class="nav-auth-actions">
                                @if (navigationMenu.Auth.IsAuthenticated)
                                {
                                    <span class="b-btn b-btn-secondary nav-auth-chip">
                                        <i class="bi bi-person-circle"></i>
                                        <span style="font-family: var(--font-mono);">@navigationMenu.Auth.Username</span>
                                    </span>

                                    <form method="post" asp-page="@navigationMenu.Auth.LogoutPagePath" asp-page-handler="SignOut" class="d-inline-flex">
                                        <input type="hidden" name="returnUrl" value="@navigationMenu.Auth.ReturnUrl" />
                                        <button type="submit" class="b-btn b-btn-secondary nav-auth-icon-btn" title="Cerrar sesión" aria-label="Cerrar sesión">
                                            <i class="bi bi-box-arrow-right"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <a class="b-btn b-btn-secondary nav-auth-icon-btn" href="@navigationMenu.Auth.LoginPath" title="Iniciar sesión" aria-label="Iniciar sesión">
                                        <i class="bi bi-box-arrow-in-right"></i>
                                    </a>
                                }
                            </section>
                        </li>
                    </menu>
                </section>
            </section>
        </nav>
    </header>

    <main role="main" class="container pb-4 flex-grow-1 d-flex flex-column">
        @if (ViewData["UseToasts"] as bool? != true)
        {
            <section class="toast-container position-fixed bottom-0 end-0 p-3 app-toast-container" aria-live="polite" aria-atomic="true">
                @if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
                {
                    <section class="toast align-items-center border-0 app-toast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4000">
                        <section class="d-flex position-relative">
                            <section class="toast-icon d-flex align-items-center justify-content-center app-toast-icon app-toast-icon-success">
                                <i class="bi bi-check-lg"></i>
                            </section>
                            <section class="toast-body d-flex align-items-center app-toast-body">
                                <strong class="me-2">Éxito:</strong> @successMessage
                            </section>
                            <button type="button" class="btn-close me-2 m-auto position-absolute top-0 end-0 mt-2 app-toast-close" data-bs-dismiss="toast" aria-label="Cerrar"></button>
                        </section>
                    </section>
                }

                @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
                {
                    <section class="toast align-items-center border-0 app-toast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="6000">
                        <section class="d-flex position-relative">
                            <section class="toast-icon d-flex align-items-center justify-content-center app-toast-icon app-toast-icon-error">
                                <i class="bi bi-exclamation-lg"></i>
                            </section>
                            <section class="toast-body d-flex align-items-center app-toast-body">
                                <strong class="me-2">Error:</strong> @errorMessage
                            </section>
                            <button type="button" class="btn-close me-2 m-auto position-absolute top-0 end-0 mt-2 app-toast-close" data-bs-dismiss="toast" aria-label="Cerrar"></button>
                        </section>
                    </section>
                }
            </section>
        }

        @RenderBody()
    </main>

    <footer class="footer py-3 mt-auto" style="border-top: 2px solid var(--mrc-ink); background-color: var(--mrc-surface); position: relative; z-index: 10; margin-top: auto;">
        <section class="container text-center">
            <p style="font-family: var(--font-mono); font-size: 0.9rem; margin: 0;">&copy; @DateTime.Now.Year - <strong>Mercadito</strong> <a asp-area="" asp-page="/Privacy" style="color: var(--mrc-ink); font-weight: bold;">Privacidad</a></p>
        </section>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/shared/toasts.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script src="~/js/shared/input-normalization.js" asp-append-version="true"></script>
    <script src="~/js/shared/validation-native-attributes.js" asp-append-version="true"></script>
    <script src="~/js/shared/validation-tooltips.js" asp-append-version="true"></script>
</body>
</html>
