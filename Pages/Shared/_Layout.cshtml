<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mercadito</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/air-datepicker/air-datepicker.css" />
    <link rel="stylesheet" href="~/css/fonts-local.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Mercadito.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light mb-4 py-2">
            <section class="container d-flex align-items-center">
                <a class="navbar-brand d-inline-flex align-items-center gap-2 m-0 p-0" asp-area="" asp-page="/Index">
                    <img src="~/favicon.svg" alt="" class="app-brand-logo" />
                    Mercadito
                </a>
                <button class="navbar-toggler btn-menu-only ms-auto" style="padding: 0; border: none;" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list" style="font-size: 2rem; line-height: 1; color: var(--mrc-ink);"></i>
                </button>
                <section class="navbar-collapse collapse d-sm-inline-flex justify-content-start align-items-center flex-grow-1">
                    <menu class="navbar-nav m-0 ps-4 gap-2 align-items-center w-100 p-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Inicio</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" id="productosDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Productos
                            </a>
                            <ul class="dropdown-menu shadow-sm" aria-labelledby="productosDropdown" style="background-color: var(--mrc-surface); border: 2px solid var(--mrc-ink); border-radius: 0; box-shadow: var(--shadow-brutal); margin-top: 0; min-width: 280px; padding: 0;">
                                <li>
                                    <a class="dropdown-item fw-bold d-flex align-items-center" style="font-family: var(--font-mono); border-bottom: 2px solid var(--mrc-ink); padding: 1rem;" asp-area="" asp-page="/Products/Products">
                                        <i class="bi bi-box-seam me-3" style="font-size: 1.5rem;"></i>
                                        <section>
                                            <span class="d-block text-uppercase" style="font-family: var(--font-display); letter-spacing: -0.02em;">Gestión de Inventario</span>
                                            <small class="d-block text-muted" style="font-size: 0.75rem;">Ver, crear y editar productos</small>
                                        </section>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item fw-bold d-flex align-items-center" style="font-family: var(--font-mono); border-bottom: 2px solid var(--mrc-ink); padding: 1rem;" href="#">
                                        <i class="bi bi-tags me-3" style="font-size: 1.5rem;"></i>
                                        <section>
                                            <span class="d-block text-uppercase" style="font-family: var(--font-display); letter-spacing: -0.02em;">Ofertas Especiales</span>
                                            <small class="d-block text-muted" style="font-size: 0.75rem;">Administrar descuentos (Próximamente)</small>
                                        </section>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item fw-bold d-flex align-items-center" style="font-family: var(--font-mono); padding: 1rem;" href="#">
                                        <i class="bi bi-file-earmark-arrow-down me-3" style="font-size: 1.5rem;"></i>
                                        <section>
                                            <span class="d-block text-uppercase" style="font-family: var(--font-display); letter-spacing: -0.02em;">Exportar Catálogo</span>
                                            <small class="d-block text-muted" style="font-size: 0.75rem;">Descargar en PDF / Excel</small>
                                        </section>
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" id="categoriasDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Categorías
                            </a>
                            <ul class="dropdown-menu shadow-sm" aria-labelledby="categoriasDropdown" style="background-color: var(--mrc-surface); border: 2px solid var(--mrc-ink); border-radius: 0; box-shadow: var(--shadow-brutal); margin-top: 0; min-width: 280px; padding: 0;">
                                <li>
                                    <a class="dropdown-item fw-bold d-flex align-items-center" style="font-family: var(--font-mono); border-bottom: 2px solid var(--mrc-ink); padding: 1rem;" asp-area="" asp-page="/Categories/Categories">
                                        <i class="bi bi-folder me-3" style="font-size: 1.5rem;"></i>
                                        <section>
                                            <span class="d-block text-uppercase" style="font-family: var(--font-display); letter-spacing: -0.02em;">Organización</span>
                                            <small class="d-block text-muted" style="font-size: 0.75rem;">Ver, crear y editar categorías</small>
                                        </section>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item fw-bold d-flex align-items-center" style="font-family: var(--font-mono); padding: 1rem;" href="#">
                                        <i class="bi bi-diagram-3 me-3" style="font-size: 1.5rem;"></i>
                                        <section>
                                            <span class="d-block text-uppercase" style="font-family: var(--font-display); letter-spacing: -0.02em;">Árbol de Categorías</span>
                                            <small class="d-block text-muted" style="font-size: 0.75rem;">Ver dependencias (Próximamente)</small>
                                        </section>
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" id="empleadosDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Empleados
                            </a>
                            <ul class="dropdown-menu shadow-sm dropdown-menu-end" aria-labelledby="empleadosDropdown" style="background-color: var(--mrc-surface); border: 2px solid var(--mrc-ink); border-radius: 0; box-shadow: var(--shadow-brutal); margin-top: 0; min-width: 280px; padding: 0;">
                                <li>
                                    <a class="dropdown-item fw-bold d-flex align-items-center" style="font-family: var(--font-mono); border-bottom: 2px solid var(--mrc-ink); padding: 1rem;" asp-area="" asp-page="/Employees/Employees">
                                        <i class="bi bi-people me-3" style="font-size: 1.5rem;"></i>
                                        <section>
                                            <span class="d-block text-uppercase" style="font-family: var(--font-display); letter-spacing: -0.02em;">Personal</span>
                                            <small class="d-block text-muted" style="font-size: 0.75rem;">Administración de empleados</small>
                                        </section>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item fw-bold d-flex align-items-center" style="font-family: var(--font-mono); border-bottom: 2px solid var(--mrc-ink); padding: 1rem;" href="#">
                                        <i class="bi bi-clock-history me-3" style="font-size: 1.5rem;"></i>
                                        <section>
                                            <span class="d-block text-uppercase" style="font-family: var(--font-display); letter-spacing: -0.02em;">Control de Horarios</span>
                                            <small class="d-block text-muted" style="font-size: 0.75rem;">Turnos y asistencias (Próximamente)</small>
                                        </section>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item fw-bold d-flex align-items-center" style="font-family: var(--font-mono); padding: 1rem;" href="#">
                                        <i class="bi bi-shield-lock me-3" style="font-size: 1.5rem;"></i>
                                        <section>
                                            <span class="d-block text-uppercase" style="font-family: var(--font-display); letter-spacing: -0.02em;">Permisos de Acceso</span>
                                            <small class="d-block text-muted" style="font-size: 0.75rem;">Roles de seguridad (Próximamente)</small>
                                        </section>
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown ms-auto">
                            <a class="nav-link d-flex align-items-center gap-2" href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle" style="font-size:1.4rem;"></i>
                                <span class="small">Iniciar sesión</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="userMenu" style="min-width: 220px; border:2px solid var(--mrc-ink);">
                                <li class="px-3 py-2">
                                    <!-- no funcional: solo UI para apariencia -->
                                    <form class="d-flex flex-column" onsubmit="event.preventDefault(); alert('Inicio de sesión no funcional (UI)');">
                                        <input type="text" class="form-control mb-2" placeholder="Usuario" />
                                        <input type="password" class="form-control mb-2" placeholder="Contraseña" />
                                        <button type="submit" class="b-btn">Entrar</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                        
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Providers/Providers">Proveedores</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Sales/Sales">Ventas</a>
                        </li>
  
                    </menu>
                </section>
            </section>
        </nav>
    </header>

    <main role="main" class="container pb-4 flex-grow-1 d-flex flex-column">
        @if (ViewData["UseToasts"] as bool? != true)
        {
            <aside id="alert-container">
                @if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
                {
                    <aside class="alert alert-success alert-dismissible fade show b-card auto-close-alert" style="background-color: var(--mrc-success); color: var(--mrc-ink); border-color: var(--mrc-ink);" role="alert">
                        <strong>¡Éxito!</strong> @successMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                    </aside>
                }

                @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
                {
                    <aside class="alert alert-danger alert-dismissible fade show b-card mb-4" style="background-color: var(--mrc-danger); color: white; border-color: var(--mrc-ink);" role="alert">
                        <strong>Error:</strong> @errorMessage
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                    </aside>
                }
            </aside>
        }

        @RenderBody()
    </main>

    <footer class="footer py-3 mt-auto" style="border-top: 2px solid var(--mrc-ink); background-color: var(--mrc-surface); position: relative; z-index: 10; margin-top: auto;">
        <section class="container text-center">
            <p style="font-family: var(--font-mono); font-size: 0.9rem; margin: 0;">&copy; @DateTime.Now.Year - <strong>Mercadito</strong> <a asp-area="" asp-page="/Privacy" style="color: var(--mrc-ink); font-weight: bold;">Privacidad</a></p>
        </section>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/air-datepicker/air-datepicker.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof bootstrap === 'undefined') {
                return;
            }

            var toastElements = document.querySelectorAll('.toast');
            for (var index = 0; index < toastElements.length; index++) {
                var toast = new bootstrap.Toast(toastElements[index]);
                toast.show();
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
