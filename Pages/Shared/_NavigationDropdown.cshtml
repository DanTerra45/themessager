@model Mercadito.Pages.Shared.Navigation.NavigationTopLevelItem
@{
    var dropdown = Model.Dropdown!;
    var dropdownAlignmentClass = string.Empty;
    var fallbackHref = "#";
    if (dropdown.AlignEnd)
    {
        dropdownAlignmentClass = "dropdown-menu-end";
    }
}

<li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" id="@dropdown.Id" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        @Model.Label
    </a>
    <ul class="dropdown-menu shadow-sm @dropdownAlignmentClass" aria-labelledby="@dropdown.Id" style="background-color: var(--mrc-surface); border: 2px solid var(--mrc-ink); border-radius: 0; box-shadow: var(--shadow-brutal); margin-top: 0; min-width: 280px; padding: 0;">
        @for (var index = 0; index < dropdown.Items.Count; index++)
        {
            var item = dropdown.Items[index];
            var itemStyle = "font-family: var(--font-mono); padding: 1rem;";
            if (index < dropdown.Items.Count - 1)
            {
                itemStyle = "font-family: var(--font-mono); border-bottom: 2px solid var(--mrc-ink); padding: 1rem;";
            }
            <li>
                @if (!string.IsNullOrWhiteSpace(item.PagePath))
                {
                    <a class="dropdown-item fw-bold d-flex align-items-center" style="@itemStyle" asp-area="" asp-page="@item.PagePath">
                        <i class="@item.IconCss me-3" style="font-size: 1.5rem;"></i>
                        <section>
                            <span class="d-block text-uppercase" style="font-family: var(--font-display); letter-spacing: -0.02em;">@item.Title</span>
                            <small class="d-block text-muted" style="font-size: 0.75rem;">@item.Description</small>
                        </section>
                    </a>
                }
                else
                {
                    var itemHref = item.Href;
                    if (string.IsNullOrWhiteSpace(itemHref))
                    {
                        itemHref = fallbackHref;
                    }
                    <a class="dropdown-item fw-bold d-flex align-items-center" style="@itemStyle" href="@itemHref">
                        <i class="@item.IconCss me-3" style="font-size: 1.5rem;"></i>
                        <section>
                            <span class="d-block text-uppercase" style="font-family: var(--font-display); letter-spacing: -0.02em;">@item.Title</span>
                            <small class="d-block text-muted" style="font-size: 0.75rem;">@item.Description</small>
                        </section>
                    </a>
                }
            </li>
        }
    </ul>
</li>
