@page "/Users"
@model Mercadito.Pages.Users.UsersModel
@{
    ViewData["Title"] = "Usuarios";
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>USUARIOS</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Accesos al sistema y roles de seguridad</p>
    </section>
    <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#nuevoUsuarioModal">
        <i class="bi bi-person-plus"></i> Nuevo Usuario
    </button>
</header>

<section class="b-card p-0 overflow-hidden">
    <header class="d-flex justify-content-between align-items-center p-3" style="border-bottom: 2px solid var(--mrc-ink); background-color: var(--mrc-surface-alt);">
        <strong style="font-family: var(--font-display); text-transform: uppercase;">Usuarios activos</strong>
        <mark class="status-badge" data-status="success">@Model.ActiveUsers.Count</mark>
    </header>
    <section class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="text-center">
                <tr>
                    <th>Usuario</th>
                    <th>Empleado asociado</th>
                    <th>Rol</th>
                    <th>Correo</th>
                    <th>Último login</th>
                    <th>Registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ActiveUsers.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted" style="font-family: var(--font-mono);">
                            No hay usuarios activos registrados.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var user in Model.ActiveUsers)
                    {
                        <tr>
                            <td class="fw-bold" style="font-family: var(--font-mono);">@user.Username</td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(user.EmployeeFullName))
                                {
                                    <span class="text-muted">Sin empleado asociado</span>
                                }
                                else
                                {
                                    <section>
                                        <strong>@user.EmployeeFullName</strong>
                                        <small class="d-block text-muted">@user.EmployeeCargo</small>
                                    </section>
                                }
                            </td>
                            <td>@user.Role</td>
                            <td>@(string.IsNullOrWhiteSpace(user.Email) ? "Sin correo" : user.Email)</td>
                            <td style="font-family: var(--font-mono);">
                                @(user.LastLogin.HasValue ? user.LastLogin.Value.ToString("dd/MM/yyyy HH:mm") : "Sin ingreso")
                            </td>
                            <td style="font-family: var(--font-mono);">@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                <button type="button"
                                        class="b-btn b-btn-secondary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#resetPasswordModal"
                                        data-user-id="@user.Id"
                                        data-username="@user.Username">
                                    <i class="bi bi-key"></i> Resetear
                                </button>
                                <form method="post" asp-page-handler="Deactivate" class="d-inline-block ms-1">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="b-btn b-btn-danger">
                                        <i class="bi bi-person-dash"></i> Baja
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </section>
</section>

<form method="post" asp-page-handler="Create">
    <section class="modal fade" id="nuevoUsuarioModal" tabindex="-1" aria-labelledby="nuevoUsuarioModalLabel" aria-hidden="true">
        <section class="modal-dialog modal-dialog-centered">
            <article class="modal-content">
                <header class="modal-header">
                    <h5 class="modal-title" id="nuevoUsuarioModalLabel" style="font-family: var(--font-display); font-weight: 800;">
                        <i class="bi bi-shield-lock me-2"></i> Registrar Usuario
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>
                <section class="modal-body p-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <section class="mb-3">
                        <label asp-for="NewUser.Username" class="form-label fw-bold">Usuario generado</label>
                        <input asp-for="NewUser.Username" class="form-control" autocomplete="off" readonly />
                        <small class="text-muted d-block mt-1">Se genera desde el correo. Si ya existe, el sistema agrega un sufijo numérico.</small>
                        <span asp-validation-for="NewUser.Username" class="text-danger small"></span>
                    </section>

                    <section class="mb-3">
                        <label asp-for="NewUser.Email" class="form-label fw-bold">Correo</label>
                        <input asp-for="NewUser.Email" class="form-control" autocomplete="off" placeholder="usuario@mercadito.local" />
                        <small class="text-muted d-block mt-1">Obligatorio. Se enviará un enlace para definir la contraseña.</small>
                        <span asp-validation-for="NewUser.Email" class="text-danger small"></span>
                    </section>

                    <section class="mb-3">
                        <label asp-for="NewUser.EmployeeId" class="form-label fw-bold">Empleado asociado</label>
                        <select asp-for="NewUser.EmployeeId" class="form-select">
                            <option value="">Sin empleado asociado</option>
                            @foreach (var employee in Model.AvailableEmployees)
                            {
                                <option value="@employee.Id">@employee.FullName - @employee.Cargo - @employee.CiDisplay</option>
                            }
                        </select>
                        <span asp-validation-for="NewUser.EmployeeId" class="text-danger small"></span>
                    </section>

                    <section class="mb-3">
                        <label asp-for="NewUser.Role" class="form-label fw-bold">Rol del sistema</label>
                        <select asp-for="NewUser.Role" class="form-select">
                            <option value="">Seleccione un rol</option>
                            <option value="Admin">Admin</option>
                            <option value="Operador">Operador</option>
                            <option value="Auditor">Auditor</option>
                        </select>
                        <span asp-validation-for="NewUser.Role" class="text-danger small"></span>
                    </section>

                </section>
                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">Guardar</button>
                </footer>
            </article>
        </section>
    </section>
</form>

<form method="post" asp-page-handler="ResetPassword">
    <section class="modal fade" id="resetPasswordModal" tabindex="-1" aria-labelledby="resetPasswordModalLabel" aria-hidden="true">
        <section class="modal-dialog modal-dialog-centered">
            <article class="modal-content">
                <header class="modal-header">
                    <h5 class="modal-title" id="resetPasswordModalLabel" style="font-family: var(--font-display); font-weight: 800;">
                        <i class="bi bi-key me-2"></i> Resetear Contraseña
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>
                <section class="modal-body p-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <input asp-for="ResetPassword.UserId" type="hidden" />

                    <section class="mb-3">
                        <label asp-for="ResetPassword.Username" class="form-label fw-bold">Usuario</label>
                        <input asp-for="ResetPassword.Username" class="form-control" readonly />
                        <small class="text-muted d-block mt-1">Solo el administrador puede restablecer la contraseña.</small>
                        <span asp-validation-for="ResetPassword.Username" class="text-danger small"></span>
                    </section>

                    <section class="mb-3">
                        <label asp-for="ResetPassword.Password" class="form-label fw-bold">Nueva contraseña</label>
                        <input asp-for="ResetPassword.Password" type="password" class="form-control" autocomplete="new-password" />
                        <small class="text-muted d-block mt-1">Debe tener entre 8 y 128 caracteres, con mayúscula, minúscula y número.</small>
                        <span asp-validation-for="ResetPassword.Password" class="text-danger small"></span>
                    </section>

                    <section class="mb-0">
                        <label asp-for="ResetPassword.ConfirmPassword" class="form-label fw-bold">Confirmar contraseña</label>
                        <input asp-for="ResetPassword.ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ResetPassword.ConfirmPassword" class="text-danger small"></span>
                    </section>
                </section>
                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">Guardar</button>
                </footer>
            </article>
        </section>
    </section>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var emailInput = document.getElementById('NewUser_Email');
            var usernamePreviewInput = document.getElementById('NewUser_Username');
            var resetModal = document.getElementById('resetPasswordModal');

            function buildUsernamePreview(email) {
                if (!email) {
                    return '';
                }

                var localPart = email.split('@@')[0] || '';
                var normalized = localPart
                    .toLowerCase()
                    .replace(/[^a-z0-9._-]+/g, '.')
                    .replace(/[._-]{2,}/g, '.')
                    .replace(/^[._-]+|[._-]+$/g, '');

                if (!normalized) {
                    return 'usuario';
                }

                if (normalized.length < 4) {
                    normalized = 'usuario';
                }

                if (normalized.length > 40) {
                    normalized = normalized.substring(0, 40);
                }

                return normalized;
            }

            if (emailInput && usernamePreviewInput) {
                var updateUsernamePreview = function () {
                    usernamePreviewInput.value = buildUsernamePreview(emailInput.value);
                };

                emailInput.addEventListener('input', updateUsernamePreview);
                updateUsernamePreview();
            }

            if (resetModal) {
                resetModal.addEventListener('show.bs.modal', function (event) {
                    var trigger = event.relatedTarget;
                    if (!trigger) {
                        return;
                    }

                    var userId = trigger.getAttribute('data-user-id');
                    var username = trigger.getAttribute('data-username');
                    var userIdInput = document.getElementById('ResetPassword_UserId');
                    var usernameInput = document.getElementById('ResetPassword_Username');
                    var passwordInput = document.getElementById('ResetPassword_Password');
                    var confirmInput = document.getElementById('ResetPassword_ConfirmPassword');

                    if (userIdInput) {
                        userIdInput.value = userId;
                    }

                    if (usernameInput) {
                        usernameInput.value = username;
                    }

                    if (passwordInput) {
                        passwordInput.value = '';
                    }

                    if (confirmInput) {
                        confirmInput.value = '';
                    }
                });
            }
        });
    </script>

    @if (Model.ShowCreateModal)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var modalElement = document.getElementById('nuevoUsuarioModal');
                if (!modalElement) {
                    return;
                }

                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            });
        </script>
    }

    @if (Model.ShowResetPasswordModal)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var modalElement = document.getElementById('resetPasswordModal');
                if (!modalElement) {
                    return;
                }

                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            });
        </script>
    }
}
