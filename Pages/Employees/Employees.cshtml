@page "/Employees"
@model Mercadito.Pages.Employees.EmployeesModel
@{
    ViewData["Title"] = "Empleados";
}

<h1>@ViewData["Title"]</h1>

<div class="mb-3">
    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addEmployeeModal">
        <i class="bi bi-plus-circle"></i> Agregar Nuevo Empleado
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>CI</th>
                        <th>Nombres</th>
                        <th>Apellidos</th>
                        <th>Rol</th>
                        <th>Contacto</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Employees != null && Model.Employees.Any())
                {
                    @foreach (var emp in Model.Employees)
                    {
                        <tr>
                            <td class="small text-muted">@emp.Id</td>
                            <td>@emp.Ci @if (!string.IsNullOrWhiteSpace(emp.Complemento)) { <span>- @emp.Complemento</span> }</td>
                            <td>@emp.Nombres</td>
                            <td>@emp.PrimerApellido @emp.SegundoApellido</td>
                            <td>@emp.Rol</td>
                            <td>@emp.NumeroContacto</td>
                            <td>
                                @if (emp.IsActive)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary edit-employee-btn"
                                            data-id="@emp.Id"
                                            data-ci="@emp.Ci"
                                            data-complemento="@emp.Complemento"
                                            data-nombres="@emp.Nombres"
                                            data-primerapellido="@emp.PrimerApellido"
                                            data-segundoapellido="@emp.SegundoApellido"
                                            data-rol="@emp.Rol"
                                            data-numerocontacto="@emp.NumeroContacto"
                                            data-isactive="@emp.IsActive"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editEmployeeModal">
                                        <i class="bi bi-pencil"></i> Editar
                                    </button>
                                    <form method="post" asp-page-handler="Delete" class="d-inline">
                                        <input type="hidden" name="id" value="@emp.Id" />
                                        <button type="submit" class="btn btn-outline-danger" onclick="return confirm('¿Eliminar empleado?')">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            No se encontraron empleados.
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <!-- Paginación -->
        <div class="d-flex justify-content-center mt-3">
            <nav>
                <ul class="pagination pagination-sm">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="./Employees" asp-route-pageNumber="@(Model.CurrentPage - 1)"><i class="bi bi-chevron-left"></i></a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <a class="page-link" asp-page="./Employees" asp-route-pageNumber="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-page="./Employees" asp-route-pageNumber="@(Model.CurrentPage + 1)"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Modal Agregar Empleado -->
<div class="modal fade" id="addEmployeeModal" tabindex="-1" aria-labelledby="addEmployeeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow">
            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate>
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-semibold" id="addEmployeeModalLabel">
                        <i class="bi bi-person-plus me-2"></i> Nuevo Empleado
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div asp-validation-summary="All" class="text-danger small mb-2"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.Ci)" class="form-label">CI</label>
                            <input asp-for="NewEmployee.Ci" type="number" class="form-control" required />
                            <span asp-validation-for="NewEmployee.Ci" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.Complemento)" class="form-label">Complemento</label>
                            <input asp-for="NewEmployee.Complemento" class="form-control" />
                            <span asp-validation-for="NewEmployee.Complemento" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.Nombres)" class="form-label">Nombres</label>
                            <input asp-for="NewEmployee.Nombres" class="form-control" required />
                            <span asp-validation-for="NewEmployee.Nombres" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.PrimerApellido)" class="form-label">Primer Apellido</label>
                            <input asp-for="NewEmployee.PrimerApellido" class="form-control" required />
                            <span asp-validation-for="NewEmployee.PrimerApellido" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.SegundoApellido)" class="form-label">Segundo Apellido</label>
                            <input asp-for="NewEmployee.SegundoApellido" class="form-control" />
                            <span asp-validation-for="NewEmployee.SegundoApellido" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.Rol)" class="form-label">Rol</label>
                            <select asp-for="NewEmployee.Rol" class="form-select" required>
                                <option value="Cajero">Cajero</option>
                                <option value="Inventario">Inventario</option>
                            </select>
                            <span asp-validation-for="NewEmployee.Rol" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="@Html.IdFor(m => m.NewEmployee.NumeroContacto)" class="form-label">Número de Contacto</label>
                        <input asp-for="NewEmployee.NumeroContacto" class="form-control" required />
                        <span asp-validation-for="NewEmployee.NumeroContacto" class="text-danger small"></span>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i> Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Editar Empleado -->
<div class="modal fade" id="editEmployeeModal" tabindex="-1" aria-labelledby="editEmployeeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow">
            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate>
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-semibold" id="editEmployeeModalLabel">
                        <i class="bi bi-pencil me-2"></i> Editar Empleado
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input asp-for="EditEmployee.Id" type="hidden" />
                    <div asp-validation-summary="All" class="text-danger small mb-2"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.Ci)" class="form-label">CI</label>
                            <input asp-for="EditEmployee.Ci" type="number" class="form-control" required />
                            <span asp-validation-for="EditEmployee.Ci" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.Complemento)" class="form-label">Complemento</label>
                            <input asp-for="EditEmployee.Complemento" class="form-control" />
                            <span asp-validation-for="EditEmployee.Complemento" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.Nombres)" class="form-label">Nombres</label>
                            <input asp-for="EditEmployee.Nombres" class="form-control" required />
                            <span asp-validation-for="EditEmployee.Nombres" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.PrimerApellido)" class="form-label">Primer Apellido</label>
                            <input asp-for="EditEmployee.PrimerApellido" class="form-control" required />
                            <span asp-validation-for="EditEmployee.PrimerApellido" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.SegundoApellido)" class="form-label">Segundo Apellido</label>
                            <input asp-for="EditEmployee.SegundoApellido" class="form-control" />
                            <span asp-validation-for="EditEmployee.SegundoApellido" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.Rol)" class="form-label">Rol</label>
                            <select asp-for="EditEmployee.Rol" class="form-select" required>
                                <option value="Cajero">Cajero</option>
                                <option value="Inventario">Inventario</option>
                            </select>
                            <span asp-validation-for="EditEmployee.Rol" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="@Html.IdFor(m => m.EditEmployee.NumeroContacto)" class="form-label">Número de Contacto</label>
                        <input asp-for="EditEmployee.NumeroContacto" class="form-control" required />
                        <span asp-validation-for="EditEmployee.NumeroContacto" class="text-danger small"></span>
                    </div>
                    <div class="form-check mt-1">
                        <input asp-for="EditEmployee.IsActive" class="form-check-input" type="checkbox" />
                        <label for="@Html.IdFor(m => m.EditEmployee.IsActive)" class="form-check-label">Activo</label>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    @if (Model.ShowCreateEmployeeModal)
    {
        <script>
            var addEmployeeModalElement = document.getElementById('addEmployeeModal');
            if (addEmployeeModalElement && typeof bootstrap !== 'undefined') {
                var addEmployeeModal = new bootstrap.Modal(addEmployeeModalElement);
                addEmployeeModal.show();
            }
        </script>
    }

    @if (Model.ShowEditEmployeeModal)
    {
        <script>
            var editEmployeeModalElement = document.getElementById('editEmployeeModal');
            if (editEmployeeModalElement && typeof bootstrap !== 'undefined') {
                var editEmployeeModal = new bootstrap.Modal(editEmployeeModalElement);
                editEmployeeModal.show();
            }
        </script>
    }

    <script>
        // Poblar el modal de edición con los datos del botón
        document.addEventListener('DOMContentLoaded', function () {
            var editBtns = document.querySelectorAll('.edit-employee-btn');
            editBtns.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id = btn.getAttribute('data-id');
                    var ci = btn.getAttribute('data-ci') || '';
                    var complemento = btn.getAttribute('data-complemento') || '';
                    var nombres = btn.getAttribute('data-nombres') || '';
                    var primerApellido = btn.getAttribute('data-primerapellido') || '';
                    var segundoApellido = btn.getAttribute('data-segundoapellido') || '';
                    var rol = btn.getAttribute('data-rol') || 'Cajero';
                    var numeroContacto = btn.getAttribute('data-numerocontacto') || '';
                    var isActive = btn.getAttribute('data-isactive') === 'True';

                    var modal = document.getElementById('editEmployeeModal');
                    modal.querySelector('[name="EditEmployee.Id"]').value = id;
                    modal.querySelector('[name="EditEmployee.Ci"]').value = ci;
                    modal.querySelector('[name="EditEmployee.Complemento"]').value = complemento;
                    modal.querySelector('[name="EditEmployee.Nombres"]').value = nombres;
                    modal.querySelector('[name="EditEmployee.PrimerApellido"]').value = primerApellido;
                    modal.querySelector('[name="EditEmployee.SegundoApellido"]').value = segundoApellido;
                    modal.querySelector('[name="EditEmployee.Rol"]').value = rol;
                    modal.querySelector('[name="EditEmployee.NumeroContacto"]').value = numeroContacto;
                    modal.querySelector('[name="EditEmployee.IsActive"]').checked = isActive;
                });
            });
        });
    </script>
}