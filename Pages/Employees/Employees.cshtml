@page "/Employees"
@model Mercadito.Pages.Employees.EmployeesModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Empleados";
    ViewData["UseToasts"] = true;
    var showIdColumn = bool.TryParse(Configuration["Ui:ShowIDs"], out var showIDs) && showIDs;
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Administración de personal</p>
    </section>
    <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#addEmployeeModal">
        <i class="bi bi-person-plus-fill"></i> Registrar Empleado
    </button>
</header>

<section>
    @if (Model.Employees.Count > 0)
    {
        <section class="table-responsive">
            <table class="table table-striped table-bordered text-center">
                <thead>
                    <tr>
                        @if (showIdColumn)
                        {
                            <th class="sortable-header" title="Ordenar por ID">
                                <form method="post" asp-page-handler="Sort" class="d-inline">
                                    <input type="hidden" name="sortBy" value="id" />
                                    <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                    <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                    <button type="submit" class="sort-button">
                                        ID <i class="bi @Model.GetSortIcon("id")" style="font-size: 0.8em;"></i>
                                    </button>
                                </form>
                            </th>
                        }
                        <th class="sortable-header" title="Ordenar por CI">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="ci" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    CI <i class="bi @Model.GetSortIcon("ci")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="sortable-header" title="Ordenar por Nombre">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="nombres" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Nombre <i class="bi @Model.GetSortIcon("nombres")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="sortable-header" title="Ordenar por Apellidos">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="apellidos" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Apellidos <i class="bi @Model.GetSortIcon("apellidos")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th>Contacto</th>
                        <th class="sortable-header" title="Ordenar por Rol">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="rol" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Rol <i class="bi @Model.GetSortIcon("rol")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="text-center" style="width: 170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model.Employees)
                    {
                        <tr>
                            @if (showIdColumn)
                            {
                                <td class="small text-muted" style="font-family: var(--font-mono);">@emp.Id</td>
                            }
                            <td class="fw-bold" style="font-family: var(--font-mono); text-align: center;">
                                @emp.Ci @if (!string.IsNullOrWhiteSpace(emp.Complemento)) { <strong>- @emp.Complemento</strong> }
                            </td>
                            <td class="text-center" style="font-family: var(--font-display); font-size: 1.1rem;">@emp.Nombres</td>
                            <td>@emp.PrimerApellido @emp.SegundoApellido</td>
                            <td style="font-family: var(--font-mono); text-align: center;">@emp.NumeroContacto</td>
                            <td class="text-center">
                                <mark class="status-badge" data-status="good">@emp.Rol</mark>
                            </td>
                            <td class="text-center">
                                <menu class="d-flex justify-content-center gap-2 m-0 p-0" style="list-style: none;">
                                    <form method="post" asp-page-handler="StartEdit" class="d-inline">
                                        <input type="hidden" name="id" value="@emp.Id" />
                                        <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                                        <input type="hidden" name="sortBy" value="@Model.SortBy" />
                                        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                                        <button type="submit" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;"
                                                title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </form>
                                    <button class="b-btn b-btn-danger" style="padding: 0.25rem 0.5rem;"
                                            title="Eliminar"
                                            aria-label="Eliminar"
                                            type="button"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteEmployeeModal"
                                            data-id="@emp.Id"
                                            data-name="@($"{emp.Nombres} {emp.PrimerApellido} {emp.SegundoApellido}".Trim())">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </menu>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>

        <!-- Paginación -->
        <section class="d-flex justify-content-center mt-4">
            <nav aria-label="Paginación de empleados">
                <ul class="pagination">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <form method="post" asp-page-handler="Navigate" class="d-inline">
                            <input type="hidden" name="pageNumber" value="@(Model.CurrentPage - 1)" />
                            <input type="hidden" name="sortBy" value="@Model.SortBy" />
                            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                            <button type="submit" class="page-link" disabled="@(Model.CurrentPage == 1)">
                                <i class="bi bi-chevron-left me-1"></i>Anterior
                            </button>
                        </form>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <form method="post" asp-page-handler="Navigate" class="d-inline">
                                <input type="hidden" name="pageNumber" value="@i" />
                                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="page-link">@i</button>
                            </form>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <form method="post" asp-page-handler="Navigate" class="d-inline">
                            <input type="hidden" name="pageNumber" value="@(Model.CurrentPage + 1)" />
                            <input type="hidden" name="sortBy" value="@Model.SortBy" />
                            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                            <button type="submit" class="page-link" disabled="@(Model.CurrentPage == Model.TotalPages)">
                                Siguiente<i class="bi bi-chevron-right ms-1"></i>
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>
        </section>
    }
    else
    {
        <aside class="text-center text-muted py-5" style="font-family: var(--font-mono); border: 2px dashed var(--mrc-ink); border-radius: var(--radius-md);">
            No hay empleados registrados en el sistema.
        </aside>
    }
</section>

<!-- Modals -->
<section class="modal fade" id="deleteEmployeeModal" tabindex="-1" aria-labelledby="deleteEmployeeModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Delete" id="deleteEmployeeForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <input type="hidden" name="id" id="DeleteEmployeeId" />

                <header class="modal-header" style="background-color: var(--mrc-danger); color: white;">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; color: white;" id="deleteEmployeeModalLabel">
                        <i class="bi bi-exclamation-triangle me-2"></i> Confirmar eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">
                    <p class="mb-3" style="font-size: 1.1rem;">¿Está seguro de eliminar al empleado seleccionado?</p>
                    <p class="mb-0" style="font-family: var(--font-mono); padding: 1rem; background-color: var(--mrc-surface-alt); border: 2px solid var(--mrc-ink); border-radius: var(--radius-sm);">
                        Empleado: <strong id="deleteEmployeeName" style="font-size: 1.2rem;">-</strong>
                    </p>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn b-btn-danger">
                        <i class="bi bi-trash me-1"></i> Eliminar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="addEmployeeModal" tabindex="-1" aria-labelledby="addEmployeeModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-lg modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate id="createEmployeeForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="addEmployeeModalLabel">
                        <i class="bi bi-person-badge me-2"></i> Registrar Empleado
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>
                <section class="modal-body p-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Identificación & Rol</h6>
                    <section class="row g-3 mb-4">
                        <section class="col-md-5">
                            <label asp-for="NewEmployee.Ci" class="form-label fw-bold">CI</label>
                            <input asp-for="NewEmployee.Ci" type="number" class="form-control" required />
                            <span asp-validation-for="NewEmployee.Ci" class="text-danger small d-block mt-1" style="font-size:0.85em; font-family:var(--font-mono); font-weight:bold; max-height:3.6rem; overflow:auto;"></span>
                        </section>
                        <section class="col-md-2">
                            <label asp-for="NewEmployee.Complemento" class="form-label fw-bold">Complemento</label>
                            <input asp-for="NewEmployee.Complemento" class="form-control text-uppercase js-uppercase" minlength="2" maxlength="2" pattern="[0-9][A-Za-z]" title="Debe tener 2 caracteres: número y letra (ej. 1A)" />
                            <span asp-validation-for="NewEmployee.Complemento" class="text-danger small d-block mt-1" style="font-size:0.85em; font-family:var(--font-mono); font-weight:bold; max-height:3.6rem; overflow:auto;"></span>
                        </section>
                        <section class="col-md-5">
                            <label asp-for="NewEmployee.Rol" class="form-label fw-bold">Rol</label>
                            <select asp-for="NewEmployee.Rol" class="form-select" required>
                                <option value="Cajero">Cajero</option>
                                <option value="Inventario">Inventario</option>
                            </select>
                            <span asp-validation-for="NewEmployee.Rol" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Datos Personales</h6>
                    <section class="row g-3">
                        <section class="col-md-4">
                            <label asp-for="NewEmployee.PrimerApellido" class="form-label fw-bold">Primer Apellido</label>
                            <input asp-for="NewEmployee.PrimerApellido" class="form-control" required />
                            <span asp-validation-for="NewEmployee.PrimerApellido" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                        <section class="col-md-4">
                            <label asp-for="NewEmployee.SegundoApellido" class="form-label fw-bold">Segundo Apellido</label>
                            <input asp-for="NewEmployee.SegundoApellido" class="form-control" />
                            <span asp-validation-for="NewEmployee.SegundoApellido" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                        <section class="col-md-4">
                            <label asp-for="NewEmployee.Nombres" class="form-label fw-bold">Nombres</label>
                            <input asp-for="NewEmployee.Nombres" class="form-control" required />
                            <span asp-validation-for="NewEmployee.Nombres" class="text-danger small d-block mt-1" style="font-size:0.85em; font-family:var(--font-mono); font-weight:bold; max-height:3.6rem; overflow:auto;"></span>
                        </section>
                        
                        <section class="col-md-6 mt-4">
                            <label asp-for="NewEmployee.NumeroContacto" class="form-label fw-bold">Teléfono</label>
                            <input asp-for="NewEmployee.NumeroContacto" class="form-control" required />
                            <span asp-validation-for="NewEmployee.NumeroContacto" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                    </section>
                </section>
                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">
                        <i class="bi bi-check-lg me-1"></i> Guardar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="editEmployeeModal" tabindex="-1" aria-labelledby="editEmployeeModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-lg modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate id="editEmployeeForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <input asp-for="EditEmployee.Id" type="hidden" />
                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="editEmployeeModalLabel">
                        <i class="bi bi-pencil-square me-2"></i> Actualizar Empleado
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>
                <section class="modal-body p-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Identificación & Rol</h6>
                    <section class="row g-3 mb-4">
                        <section class="col-md-5">
                            <label asp-for="EditEmployee.Ci" class="form-label fw-bold">CI</label>
                            <input asp-for="EditEmployee.Ci" type="number" class="form-control" required />
                            <span asp-validation-for="EditEmployee.Ci" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                        <section class="col-md-2">
                            <label asp-for="EditEmployee.Complemento" class="form-label fw-bold">Complemento</label>
                            <input asp-for="EditEmployee.Complemento" class="form-control text-uppercase js-uppercase" minlength="2" maxlength="2" pattern="[0-9][A-Za-z]" title="Debe tener 2 caracteres: número y letra (ej. 1A)" />
                            <span asp-validation-for="EditEmployee.Complemento" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                        <section class="col-md-5">
                            <label asp-for="EditEmployee.Rol" class="form-label fw-bold">Rol</label>
                            <select asp-for="EditEmployee.Rol" class="form-select" required>
                                <option value="Cajero">Cajero</option>
                                <option value="Inventario">Inventario</option>
                            </select>
                            <span asp-validation-for="EditEmployee.Rol" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Datos Personales</h6>
                    <section class="row g-3">
                        <section class="col-md-4">
                            <label asp-for="EditEmployee.PrimerApellido" class="form-label fw-bold">Primer Apellido</label>
                            <input asp-for="EditEmployee.PrimerApellido" class="form-control" required />
                            <span asp-validation-for="EditEmployee.PrimerApellido" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                        <section class="col-md-4">
                            <label asp-for="EditEmployee.SegundoApellido" class="form-label fw-bold">Segundo Apellido</label>
                            <input asp-for="EditEmployee.SegundoApellido" class="form-control" />
                            <span asp-validation-for="EditEmployee.SegundoApellido" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                        <section class="col-md-4">
                            <label asp-for="EditEmployee.Nombres" class="form-label fw-bold">Nombres</label>
                            <input asp-for="EditEmployee.Nombres" class="form-control" required />
                            <span asp-validation-for="EditEmployee.Nombres" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
           
                        <section class="col-md-6 mt-4">
                            <label asp-for="EditEmployee.NumeroContacto" class="form-label fw-bold">Teléfono</label>
                            <input asp-for="EditEmployee.NumeroContacto" class="form-control" required />
                            <span asp-validation-for="EditEmployee.NumeroContacto" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                    </section>
                </section>
                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">
                        <i class="bi bi-check-lg me-1"></i> Actualizar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<!-- Brutalist Toasts -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1060;">
    @if (TempData["SuccessMessage"] is string successMsg && !string.IsNullOrWhiteSpace(successMsg))
    {
        <div class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4000" style="background-color: white; border: 4px solid var(--mrc-ink) !important; border-radius: 0; box-shadow: 4px 4px 0 var(--mrc-ink); opacity: 1;">
            <div class="d-flex position-relative">
                <div class="toast-icon d-flex align-items-center justify-content-center" style="background-color: var(--mrc-success); width: 60px; border-right: 4px solid var(--mrc-ink);">
                    <i class="bi bi-check-circle" style="font-size: 1.5rem; color: var(--mrc-ink);"></i>
                </div>
                <div class="toast-body d-flex align-items-center" style="font-family: var(--font-mono); font-weight: bold; flex-grow: 1; min-height: 60px;">
                    @successMsg
                </div>
                <button type="button" class="btn-close me-2 m-auto position-absolute top-0 end-0 mt-2" data-bs-dismiss="toast" aria-label="Cerrar" style="background-size: 0.8em;"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMsg && !string.IsNullOrWhiteSpace(errorMsg))
    {
        <div class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="6000" style="background-color: white; border: 4px solid var(--mrc-ink) !important; border-radius: 0; box-shadow: 4px 4px 0 var(--mrc-ink); opacity: 1;">
            <div class="d-flex position-relative">
                <div class="toast-icon d-flex align-items-center justify-content-center" style="background-color: var(--mrc-danger); width: 60px; border-right: 4px solid var(--mrc-ink);">
                    <i class="bi bi-x-circle" style="font-size: 1.5rem; color: white;"></i>
                </div>
                <div class="toast-body d-flex align-items-center" style="font-family: var(--font-mono); font-weight: bold; flex-grow: 1; min-height: 60px;">
                    @errorMsg
                </div>
                <button type="button" class="btn-close me-2 m-auto position-absolute top-0 end-0 mt-2" data-bs-dismiss="toast" aria-label="Cerrar" style="background-size: 0.8em;"></button>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.js-uppercase').forEach(function (input) {
                input.addEventListener('input', function () {
                    input.value = input.value.toUpperCase();
                });
            });

            if (typeof bootstrap === 'undefined') {
                return;
            }

            var deleteEmployeeModal = document.getElementById('deleteEmployeeModal');
            if (deleteEmployeeModal) {
                deleteEmployeeModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    if (!button) {
                        return;
                    }

                    var employeeId = button.getAttribute('data-id') || '';
                    var employeeName = button.getAttribute('data-name') || '-';

                    var deleteIdInput = document.getElementById('DeleteEmployeeId');
                    var deleteNameLabel = document.getElementById('deleteEmployeeName');

                    if (deleteIdInput) {
                        deleteIdInput.value = employeeId;
                    }
                    if (deleteNameLabel) {
                        deleteNameLabel.textContent = employeeName;
                    }
                });
            }

            @if (Model.ShowCreateEmployeeModal)
            {
                <text>
                var addModal = new bootstrap.Modal(document.getElementById('addEmployeeModal'));
                addModal.show();
                </text>
            }

            @if (Model.ShowEditEmployeeModal)
            {
                <text>
                var editModal = new bootstrap.Modal(document.getElementById('editEmployeeModal'));
                editModal.show();
                </text>
            }

        });
    </script>
}
