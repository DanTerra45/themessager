@page
@model Mercadito.Pages.Employees.EmployeesModel
@{
    ViewData["Title"] = "Empleados";
}

<h1>@ViewData["Title"]</h1>

<div class="mb-3">
    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addEmployeeModal">
        <i class="bi bi-plus-circle"></i> Agregar Nuevo Empleado
    </button>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Nombre Completo</th>
                        <th>Cargo</th>
                        <th>Email</th>
                        <th>Teléfono</th>
                        <th>Fecha Ingreso</th>
                        <th>Salario</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Employees != null && Model.Employees.Any())
                {
                    @foreach (var emp in Model.Employees)
                    {
                        <tr>
                            <td class="small text-muted">@emp.Id.ToString().Substring(0,8)</td>
                            <td>@emp.FirstName @emp.LastName</td>
                            <td>@emp.Position</td>
                            <td>@emp.Email</td>
                            <td>@emp.Phone</td>
                            <td>@emp.HireDate.ToShortDateString()</td>
                            <td class="text-end">@($"{emp.Salary:N2} Bs.")</td>
                            <td>
                                @if (emp.IsActive)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary edit-employee-btn"
                                            data-id="@emp.Id"
                                            data-firstname="@emp.FirstName"
                                            data-lastname="@emp.LastName"
                                            data-position="@emp.Position"
                                            data-hiredate="@emp.HireDate.ToString("yyyy-MM-dd")"
                                            data-salary="@emp.Salary"
                                            data-email="@emp.Email"
                                            data-phone="@emp.Phone"
                                            data-address="@emp.Address"
                                            data-isactive="@emp.IsActive"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editEmployeeModal">
                                        <i class="bi bi-pencil"></i> Editar
                                    </button>
                                    <form method="post" asp-page-handler="Delete" class="d-inline">
                                        <input type="hidden" name="id" value="@emp.Id" />
                                        <button type="submit" class="btn btn-outline-danger" onclick="return confirm('¿Eliminar empleado?')">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            No se encontraron empleados.
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <!-- Paginación -->
        <div class="d-flex justify-content-center mt-3">
            <nav>
                <ul class="pagination pagination-sm">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="./Employees" asp-route-page="@(Model.CurrentPage - 1)"><i class="bi bi-chevron-left"></i></a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <a class="page-link" asp-page="./Employees" asp-route-page="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-page="./Employees" asp-route-page="@(Model.CurrentPage + 1)"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Modal Agregar Empleado -->
<div class="modal fade" id="addEmployeeModal" tabindex="-1" aria-labelledby="addEmployeeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow">
            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate>
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-semibold" id="addEmployeeModalLabel">
                        <i class="bi bi-person-plus me-2"></i> Nuevo Empleado
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.FirstName)" class="form-label">Nombre</label>
                            <input asp-for="NewEmployee.FirstName" class="form-control" required />
                            <span asp-validation-for="NewEmployee.FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.LastName)" class="form-label">Apellido</label>
                            <input asp-for="NewEmployee.LastName" class="form-control" required />
                            <span asp-validation-for="NewEmployee.LastName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.Position)" class="form-label">Cargo</label>
                            <input asp-for="NewEmployee.Position" class="form-control" required />
                            <span asp-validation-for="NewEmployee.Position" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.HireDate)" class="form-label">Fecha Ingreso</label>
                            <input asp-for="NewEmployee.HireDate" type="date" class="form-control" required />
                            <span asp-validation-for="NewEmployee.HireDate" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.Email)" class="form-label">Email</label>
                            <input asp-for="NewEmployee.Email" type="email" class="form-control" required />
                            <span asp-validation-for="NewEmployee.Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.Phone)" class="form-label">Teléfono</label>
                            <input asp-for="NewEmployee.Phone" class="form-control" required />
                            <span asp-validation-for="NewEmployee.Phone" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="@Html.IdFor(m => m.NewEmployee.Address)" class="form-label">Dirección</label>
                        <input asp-for="NewEmployee.Address" class="form-control" />
                        <span asp-validation-for="NewEmployee.Address" class="text-danger small"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.NewEmployee.Salary)" class="form-label">Salario (Bs.)</label>
                            <input asp-for="NewEmployee.Salary" type="number" step="0.01" class="form-control" required />
                            <span asp-validation-for="NewEmployee.Salary" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i> Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Editar Empleado -->
<div class="modal fade" id="editEmployeeModal" tabindex="-1" aria-labelledby="editEmployeeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow">
            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate>
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-semibold" id="editEmployeeModalLabel">
                        <i class="bi bi-pencil me-2"></i> Editar Empleado
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input asp-for="EditEmployee.Id" type="hidden" />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.FirstName)" class="form-label">Nombre</label>
                            <input asp-for="EditEmployee.FirstName" class="form-control" required />
                            <span asp-validation-for="EditEmployee.FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.LastName)" class="form-label">Apellido</label>
                            <input asp-for="EditEmployee.LastName" class="form-control" required />
                            <span asp-validation-for="EditEmployee.LastName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.Position)" class="form-label">Cargo</label>
                            <input asp-for="EditEmployee.Position" class="form-control" required />
                            <span asp-validation-for="EditEmployee.Position" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.HireDate)" class="form-label">Fecha Ingreso</label>
                            <input asp-for="EditEmployee.HireDate" type="date" class="form-control" required />
                            <span asp-validation-for="EditEmployee.HireDate" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.Email)" class="form-label">Email</label>
                            <input asp-for="EditEmployee.Email" type="email" class="form-control" required />
                            <span asp-validation-for="EditEmployee.Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.Phone)" class="form-label">Teléfono</label>
                            <input asp-for="EditEmployee.Phone" class="form-control" required />
                            <span asp-validation-for="EditEmployee.Phone" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="@Html.IdFor(m => m.EditEmployee.Address)" class="form-label">Dirección</label>
                        <input asp-for="EditEmployee.Address" class="form-control" />
                        <span asp-validation-for="EditEmployee.Address" class="text-danger small"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="@Html.IdFor(m => m.EditEmployee.Salary)" class="form-label">Salario (Bs.)</label>
                            <input asp-for="EditEmployee.Salary" type="number" step="0.01" class="form-control" required />
                            <span asp-validation-for="EditEmployee.Salary" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check mt-4">
                                <input asp-for="EditEmployee.IsActive" class="form-check-input" type="checkbox" />
                                <label for="@Html.IdFor(m => m.EditEmployee.IsActive)" class="form-check-label">Activo</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Poblar el modal de edición con los datos del botón
        document.addEventListener('DOMContentLoaded', function () {
            var editBtns = document.querySelectorAll('.edit-employee-btn');
            editBtns.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id = btn.getAttribute('data-id');
                    var firstName = btn.getAttribute('data-firstname') || '';
                    var lastName = btn.getAttribute('data-lastname') || '';
                    var position = btn.getAttribute('data-position') || '';
                    var hireDate = btn.getAttribute('data-hiredate') || '';
                    var salary = btn.getAttribute('data-salary') || '';
                    var email = btn.getAttribute('data-email') || '';
                    var phone = btn.getAttribute('data-phone') || '';
                    var address = btn.getAttribute('data-address') || '';
                    var isActive = btn.getAttribute('data-isactive') === 'True';

                    var modal = document.getElementById('editEmployeeModal');
                    modal.querySelector('[name="EditEmployee.Id"]').value = id;
                    modal.querySelector('[name="EditEmployee.FirstName"]').value = firstName;
                    modal.querySelector('[name="EditEmployee.LastName"]').value = lastName;
                    modal.querySelector('[name="EditEmployee.Position"]').value = position;
                    modal.querySelector('[name="EditEmployee.HireDate"]').value = hireDate;
                    modal.querySelector('[name="EditEmployee.Salary"]').value = salary;
                    modal.querySelector('[name="EditEmployee.Email"]').value = email;
                    modal.querySelector('[name="EditEmployee.Phone"]').value = phone;
                    modal.querySelector('[name="EditEmployee.Address"]').value = address;
                    modal.querySelector('[name="EditEmployee.IsActive"]').checked = isActive;
                });
            });
        });
    </script>
}