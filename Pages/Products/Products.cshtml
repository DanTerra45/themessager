@page "/Products"
@model Mercadito.Pages.Products.ProductsModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment
@{
    ViewData["Title"] = "Productos";
    var showIdColumn = HostEnvironment.IsDevelopment();
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Gestión del inventario de productos</p>
    </section>
    <button type="button" class="b-btn" style="background-color: #198754; color: white; border-color: var(--mrc-ink); box-shadow: 2px 2px 0 var(--mrc-ink);" data-bs-toggle="modal" data-bs-target="#addProductModal">
        <i class="bi bi-plus-circle"></i> Agregar Nuevo Producto
    </button>
</header>

@if (Model.Products.Any() || Model.CategoryFilter != 0)
{
    <section class="mb-4">
        <form method="post" asp-page-handler="Filter" class="d-flex align-items-center gap-2">
            <select name="categoryFilter" class="form-select fw-bold" style="max-width: 300px; border-width: 2px; border-color: var(--mrc-ink);">
                <option value="0" selected="@(Model.CategoryFilter == 0)">Todas las categorías</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id" selected="@(Model.CategoryFilter == category.Id)">@category.Name</option>
                }
            </select>
            <button type="submit" class="b-btn" style="background-color: #0d6efd; color: white; border-color: #0d6efd; box-shadow: 2px 2px 0 #0a58ca;">Filtrar</button>
        </form>
    </section>
}

<section>
    @if (Model.Products != null && Model.Products.Count > 0)
    {
        <section class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="text-center">
                    <tr>
                        @if (showIdColumn)
                        {
                            <th>ID</th>
                        }
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Categorías</th>
                        <th>Stock</th>
                        <th>Lote</th>
                        <th>Vencimiento</th>
                        <th class="text-end">Precio</th>
                        <th class="text-center" style="width: 200px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            @if (showIdColumn)
                            {
                                <td class="small text-muted" style="font-family: var(--font-mono);">
                                    @product.Id
                                </td>
                            }

                            <td class="fw-bold" style="font-family: var(--font-display); font-size: 1.1rem;">@product.Name</td>

                            <td class="text-truncate truncate-description-product">
                                @product.Description
                            </td>

                            <td class="text-center">
                                @if (product.Categories != null && product.Categories.Count > 0)
                                {
                                    @foreach (var category in product.Categories)
                                    {
                                        <mark class="badge bg-secondary me-1 mb-1" style="font-family: var(--font-mono); font-size: 0.85rem; border: 1px solid var(--mrc-ink); display: inline-block;">@category</mark>
                                    }
                                }
                                else
                                {
                                    <small class="text-muted" style="font-family: var(--font-mono);">Sin categoría</small>
                                }
                            </td>

                            <td class="text-center">
                                @if(product.Stock <= 5)
                                {
                                    <mark class="status-badge" data-status="danger">@product.Stock</mark>
                                }
                                else if(product.Stock <= 20)
                                {
                                    <mark class="status-badge" data-status="warning">@product.Stock</mark>
                                }
                                else
                                {
                                    <mark class="status-badge" data-status="good">@product.Stock</mark>
                                }
                            </td>

                            <td class="text-center" style="font-family: var(--font-mono);">
                                @product.Batch.ToShortDateString()
                            </td>

                            <td class="text-center" style="font-family: var(--font-mono);">
                                @product.ExpirationDate.ToShortDateString()
                            </td>

                            <td class="text-end fw-bold" style="font-family: var(--font-mono); font-size: 1.1rem;">
                                @($"{product.Price:N2} Bs.")
                            </td>

                            <td class="text-center">
                                <menu class="d-flex justify-content-center gap-2 m-0 p-0" style="list-style: none;">
                                    <a asp-page="./Products"
                                       asp-route-pageNumber="@Model.CurrentPage"
                                       asp-route-categoryFilter="@Model.CategoryFilter"
                                       asp-route-editId="@product.Id"
                                       class="b-btn" style="background-color: white; color: #0d6efd; border-color: #0d6efd; box-shadow: 2px 2px 0 #0d6efd; padding: 0.25rem 0.6rem; font-size: 0.85rem;">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>

                                    <form method="post" asp-page-handler="Delete" class="d-inline">
                                        <input type="hidden" name="id" value="@product.Id" />
                                        <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                                        <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                        <button type="submit" class="b-btn" style="background-color: white; color: var(--mrc-danger); border-color: var(--mrc-danger); box-shadow: 2px 2px 0 var(--mrc-danger); padding: 0.25rem 0.6rem; font-size: 0.85rem;" 
                                                onclick="return confirm('¿Eliminar producto?')">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </button>
                                    </form>
                                </menu>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
    else
    {
        <aside class="text-center text-muted py-5" style="font-family: var(--font-mono); border: 2px dashed var(--mrc-ink); border-radius: var(--radius-md);">
            No hay productos registrados que coincidan con la búsqueda.
        </aside>
    }
    
    <section class="d-flex justify-content-center mt-4">
        <nav aria-label="Paginación de productos">
            <ul class="pagination">
                @if (Model.CategoryFilter != 0)
                {
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="./Products" asp-route-pageNumber="@(Model.CurrentPage - 1)" asp-route-categoryFilter="@Model.CategoryFilter">
                            <i class="bi bi-chevron-left me-1"></i>Anterior
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <a class="page-link" asp-page="./Products" asp-route-pageNumber="@i" asp-route-categoryFilter="@Model.CategoryFilter">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-page="./Products" asp-route-pageNumber="@(Model.CurrentPage + 1)" asp-route-categoryFilter="@Model.CategoryFilter">
                            Siguiente<i class="bi bi-chevron-right ms-1"></i>
                        </a>
                    </li>
                }
                else
                {
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="./Products" asp-route-pageNumber="@(Model.CurrentPage - 1)">
                            <i class="bi bi-chevron-left me-1"></i>Anterior
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <a class="page-link" asp-page="./Products" asp-route-pageNumber="@i">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-page="./Products" asp-route-pageNumber="@(Model.CurrentPage + 1)">
                            Siguiente<i class="bi bi-chevron-right ms-1"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </section>
</section>

<!-- Modals -->
<section class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-lg modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate id="createProductForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />

                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="addProductModalLabel">
                        <i class="bi bi-box-seam me-2"></i> Nuevo Producto
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">
                    <aside asp-validation-summary="ModelOnly" class="text-danger small mb-3"></aside>

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Información General</h6>
                    <section class="row">
                        <section class="col-md-6 mb-3">
                            <label asp-for="NewProduct.Name" class="form-label fw-bold">Nombre</label>
                            <input asp-for="NewProduct.Name" class="form-control" required />
                            <small asp-validation-for="NewProduct.Name" class="text-danger"></small>
                        </section>

                        <section class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Categorías</label>
                            <section class="border form-control" style="max-height: 120px; overflow-y: auto; background-color: var(--mrc-surface); border-width: 2px !important; border-color: var(--mrc-ink) !important;">
                                @foreach (var category in Model.Categories)
                                {
                                    <section class="form-check">
                                        <input class="form-check-input" type="checkbox" name="NewProduct.CategoryIds" value="@category.Id" id="newCat_@category.Id">
                                        <label class="form-check-label" for="newCat_@category.Id" style="font-family: var(--font-mono); font-size: 0.9rem; cursor: pointer;">
                                            @category.Name
                                        </label>
                                    </section>
                                }
                            </section>
                            <p class="form-text mt-1" style="font-family: var(--font-mono); font-size: 0.8rem; margin-bottom: 0;">Puede seleccionar múltiples categorías.</p>
                            <small asp-validation-for="NewProduct.CategoryIds" class="text-danger"></small>
                        </section>
                    </section>

                    <section class="mb-4">
                        <label asp-for="NewProduct.Description" class="form-label fw-bold">Descripción</label>
                        <textarea asp-for="NewProduct.Description" class="form-control product-description-textarea"></textarea>
                        <small asp-validation-for="NewProduct.Description" class="text-danger"></small>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Inventario y Fechas</h6>
                    <section class="row">
                        <section class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Stock" class="form-label fw-bold">Stock</label>
                            <input asp-for="NewProduct.Stock" type="number" class="form-control" min="0" required />
                            <small asp-validation-for="NewProduct.Stock" class="text-danger"></small>
                        </section>

                        <section class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Batch" class="form-label fw-bold">Lote</label>
                            <input asp-for="NewProduct.Batch" type="date" class="form-control" max="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            <small asp-validation-for="NewProduct.Batch" class="text-danger"></small>
                        </section>

                        <section class="col-md-4 mb-3">
                            <label asp-for="NewProduct.ExpirationDate" class="form-label fw-bold">Vencimiento</label>
                            <input asp-for="NewProduct.ExpirationDate" type="date" class="form-control" min="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            <small asp-validation-for="NewProduct.ExpirationDate" class="text-danger"></small>
                        </section>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Precio</h6>
                    <section class="row">
                        <section class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Price" class="form-label fw-bold">Precio</label>
                            <section class="input-group">
                                <strong class="input-group-text">Bs.</strong>
                                <input asp-for="NewProduct.Price" type="number" step="0.01" class="form-control" min="0" required />
                            </section>
                            <small asp-validation-for="NewProduct.Price" class="text-danger"></small>
                        </section>
                    </section>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn js-submit-lock" data-busy-text="<i class='bi bi-hourglass-split me-1'></i> Guardando...">
                        <i class="bi bi-check-lg me-1"></i> Guardar Producto
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="editProductModal" tabindex="-1" aria-labelledby="editProductModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-lg modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate id="updateProductForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                <input type="hidden" asp-for="EditProduct.Id" />

                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="editProductModalLabel">
                        <i class="bi bi-pencil-square me-2"></i> Editar Producto
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">
                    <aside asp-validation-summary="ModelOnly" class="text-danger small mb-3"></aside>

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Información General</h6>
                    <section class="row">
                        <section class="col-md-6 mb-3">
                            <label asp-for="EditProduct.Name" class="form-label fw-bold">Nombre</label>
                            <input asp-for="EditProduct.Name" class="form-control" required />
                            <small asp-validation-for="EditProduct.Name" class="text-danger"></small>
                        </section>

                        <section class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Categorías</label>
                            <section class="border form-control" style="max-height: 120px; overflow-y: auto; background-color: var(--mrc-surface); border-width: 2px !important; border-color: var(--mrc-ink) !important;">
                                @foreach (var category in Model.Categories)
                                {
                                    bool isChecked = Model.EditProduct?.CategoryIds?.Contains(category.Id) == true;
                                    <section class="form-check">
                                        <input class="form-check-input" type="checkbox" name="EditProduct.CategoryIds" value="@category.Id" id="editCat_@category.Id" checked="@isChecked">
                                        <label class="form-check-label" for="editCat_@category.Id" style="font-family: var(--font-mono); font-size: 0.9rem; cursor: pointer;">
                                            @category.Name
                                        </label>
                                    </section>
                                }
                            </section>
                            <p class="form-text mt-1" style="font-family: var(--font-mono); font-size: 0.8rem; margin-bottom: 0;">Puede seleccionar múltiples categorías.</p>
                            <small asp-validation-for="EditProduct.CategoryIds" class="text-danger"></small>
                        </section>
                    </section>

                    <section class="mb-4">
                        <label asp-for="EditProduct.Description" class="form-label fw-bold">Descripción</label>
                        <textarea asp-for="EditProduct.Description" class="form-control product-description-textarea"></textarea>
                        <small asp-validation-for="EditProduct.Description" class="text-danger"></small>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Inventario y Fechas</h6>
                    <section class="row">
                        <section class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Stock" class="form-label fw-bold">Stock</label>
                            <input asp-for="EditProduct.Stock" type="number" class="form-control" min="0" required />
                            <small asp-validation-for="EditProduct.Stock" class="text-danger"></small>
                        </section>

                        <section class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Batch" class="form-label fw-bold">Lote</label>
                            <input asp-for="EditProduct.Batch" type="date" class="form-control" max="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            <small asp-validation-for="EditProduct.Batch" class="text-danger"></small>
                        </section>

                        <section class="col-md-4 mb-3">
                            <label asp-for="EditProduct.ExpirationDate" class="form-label fw-bold">Vencimiento</label>
                            <input asp-for="EditProduct.ExpirationDate" type="date" class="form-control" required />
                            <small asp-validation-for="EditProduct.ExpirationDate" class="text-danger"></small>
                        </section>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Precio</h6>
                    <section class="row">
                        <section class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Price" class="form-label fw-bold">Precio</label>
                            <section class="input-group">
                                <strong class="input-group-text">Bs.</strong>
                                <input asp-for="EditProduct.Price" type="number" step="0.01" class="form-control" min="0" required />
                            </section>
                            <small asp-validation-for="EditProduct.Price" class="text-danger"></small>
                        </section>
                    </section>
                </section>

                <footer class="modal-footer">
                    <a asp-page="./Products" asp-route-pageNumber="@Model.CurrentPage" asp-route-categoryFilter="@Model.CategoryFilter" class="b-btn b-btn-secondary text-decoration-none">
                        Cancelar
                    </a>
                    <button type="submit" class="b-btn js-submit-lock" data-busy-text="<i class='bi bi-hourglass-split me-1'></i> Actualizando...">
                        <i class="bi bi-check-lg me-1"></i> Actualizar Producto
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    @if (Model.ShowModal)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var createModalElement = document.getElementById('addProductModal');
                if (createModalElement && typeof bootstrap !== 'undefined') {
                    var createModal = new bootstrap.Modal(createModalElement);
                    createModal.show();
                }
            });
        </script>
    }

    @if (Model.EditProduct != null && Model.EditProduct.Id != 0)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var editModalElement = document.getElementById('editProductModal');
                if (editModalElement && typeof bootstrap !== 'undefined') {
                    var editModal = new bootstrap.Modal(editModalElement);
                    editModalElement.addEventListener('hidden.bs.modal', function () {
                        var url = new URL(window.location.href);
                        if (url.searchParams.has('editId')) {
                            url.searchParams.delete('editId');
                            window.history.replaceState({}, document.title, url.toString());
                        }
                    }, { once: true });
                    editModal.show();
                }
            });
        </script>
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.js-submit-lock').forEach(function (button) {
                button.addEventListener('click', function (e) {
                    const form = button.closest('form');
                    if (form && form.checkValidity()) {
                        setTimeout(() => {
                            button.disabled = true;
                            const busyText = button.getAttribute('data-busy-text');
                            if (busyText) {
                                button.innerHTML = busyText;
                            }
                        }, 10);
                    }
                });
            });
        });
    </script>
}