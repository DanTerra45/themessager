@page "/Products"
@using System.Data
@model Mercadito.Pages.Products.ProductsModel
@{
    ViewData["Title"] = "Productos";
}

<h1>@ViewData["Title"]</h1>

<div class="mb-3">
    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addProductModal">
        <i class="bi bi-plus-circle" aria-hidden="true"></i> Agregar Nuevo Producto
    </button>
</div>
<div class="filter mb-3">
    <form method="post" class="row g-2" asp-page-handler="Filter">
        <div class="col-md-3">
            <select name="categoryFilter" class="form-select">
                <option value="0" selected="@(Model.CategoryFilter == 0)">Todas las categorías</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id" selected="@(Model.CategoryFilter == category.Id)">@category.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filtrar</button>
        </div>
    </form>
</div>

<div>
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light text-center">
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Categorías</th>
                            <th>Stock</th>
                            <th>Lote</th>
                            <th>Vencimiento</th>
                            <th class="text-end">Precio</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Products != null && Model.Products.Count > 0)
                    {
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td class="small text-muted">
                                    @product.Id
                                </td>

                                <td class="fw-semibold">@product.Name</td>

                                <td class="text-truncate" style="max-width: 200px;">
                                    @product.Description
                                </td>

                                <td>
                                    @if (product.Categories != null && product.Categories.Count > 0)
                                    {
                                        @foreach (var category in product.Categories)
                                        {
                                            <span class="badge bg-secondary me-1">@category</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Sin categoría</span>
                                    }
                                </td>

                                <td class="text-center">
                                    @if(product.Stock <= 5)
                                    {
                                        <span class="badge bg-danger">@product.Stock</span>
                                    }
                                    else if(product.Stock <= 20)
                                    {
                                        <span class="badge bg-warning text-dark">@product.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@product.Stock</span>
                                    }
                                </td>

                                <td class="text-center">
                                    @product.Batch.ToShortDateString()
                                </td>

                                <td class="text-center">
                                    @product.ExpirationDate.ToShortDateString()
                                </td>

                                <td class="text-end fw-bold">
                                    @($"{product.Price:N2} Bs.")
                                </td>

                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                                     <a href="/Products?editId=@product.Id"
                                                         class="btn btn-outline-primary">
                                            <i class="bi bi-pencil" aria-hidden="true"></i> Editar
                                        </a>

                                        <form method="post" asp-page-handler="Delete" class="d-inline">
                                            <input type="hidden" name="id" value="@product.Id" />
                                            <button type="submit" class="btn btn-outline-danger" 
                                                    onclick="return confirm('¿Eliminar producto?')">
                                                <i class="bi bi-trash" aria-hidden="true"></i> Eliminar
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                No se encontraron productos.
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <div class="d-flex justify-content-center mt-3">
        <nav>
            <ul class="pagination">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    @{
                        var prevPage = Model.CurrentPage - 1;
                        var prevUrl = Model.CategoryFilter != 0 
                            ? $"/Products?page={prevPage}&categoryFilter={Model.CategoryFilter}&t={DateTime.Now.Ticks}"
                            : $"/Products?page={prevPage}&t={DateTime.Now.Ticks}";
                    }
                    <a class="page-link" href="@prevUrl">
                        Anterior
                    </a>
                </li>
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    var pageUrl = Model.CategoryFilter != 0 
                        ? $"/Products?page={i}&categoryFilter={Model.CategoryFilter}&t={DateTime.Now.Ticks}"
                        : $"/Products?page={i}&t={DateTime.Now.Ticks}";
                    
                    <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                        <a class="page-link" href="@pageUrl">
                            @i
                        </a>
                    </li>
                }
                
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    @{
                        var nextPage = Model.CurrentPage + 1;
                        var nextUrl = Model.CategoryFilter != 0 
                            ? $"/Products?page={nextPage}&categoryFilter={Model.CategoryFilter}&t={DateTime.Now.Ticks}"
                            : $"/Products?page={nextPage}&t={DateTime.Now.Ticks}";
                    }
                    <a class="page-link" href="@nextUrl">
                        Siguiente
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>
<div class="modal fade" id="addProductModal" tabindex="-1"
     aria-labelledby="addProductModalLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow">

            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate>

                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-semibold" id="addProductModalLabel">
                        <i class="bi bi-box-seam me-2" aria-hidden="true"></i>
                        Nuevo Producto
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Cerrar">
                    </button>
                </div>

                <div class="modal-body">
                    <h6 class="text-muted mb-3">Información General</h6>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="NewProduct.Name" class="form-label">Nombre</label>
                            <input asp-for="NewProduct.Name" class="form-control" required />
                            <span asp-validation-for="NewProduct.Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="NewProduct.CategoryId" class="form-label">Categoría</label>
                            <select asp-for="NewProduct.CategoryId" class="form-select">
                                <option value="0">Sin categoría</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                            <span asp-validation-for="NewProduct.CategoryId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="NewProduct.Description" class="form-label">Descripción</label>
                        <textarea asp-for="NewProduct.Description"
                                  class="form-control"
                                  style="min-height:120px; resize: none;"></textarea>
                        <span asp-validation-for="NewProduct.Description" class="text-danger small"></span>
                    </div>

                    <hr>

                    <h6 class="text-muted mb-3">Inventario y Fechas</h6>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Stock" class="form-label">Stock</label>
                            <input asp-for="NewProduct.Stock"
                                   type="number"
                                   class="form-control"
                                   required />
                            <span asp-validation-for="NewProduct.Stock" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Batch" class="form-label">Lote</label>
                            <input asp-for="NewProduct.Batch"
                                    type="date"
                                    max="@DateTime.Now.ToString("yyyy-MM-dd")"
                                    value="@DateTime.Now.ToString("yyyy-MM-dd")"
                                   class="form-control"
                                   required />
                            <span asp-validation-for="NewProduct.Batch" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="NewProduct.ExpirationDate" class="form-label">
                                Fecha de Vencimiento
                            </label>
                            <input asp-for="NewProduct.ExpirationDate"
                                   type="date"
                                      value="@DateTime.Now.AddMonths(3).ToString("yyyy-MM-dd")"
                                      min="@DateTime.Now.ToString("yyyy-MM-dd")"
                                   class="form-control"
                                   required />
                            <span asp-validation-for="NewProduct.ExpirationDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr>

                    <h6 class="text-muted mb-3">Precio</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Price" class="form-label">Precio</label>
                            <div class="input-group">
                                <span class="input-group-text">Bs.</span>
                                <input asp-for="NewProduct.Price"
                                       type="number"
                                       step="0.01"
                                       class="form-control"
                                       required />
                            </div>
                            <span asp-validation-for="NewProduct.Price" class="text-danger small"></span>
                        </div>
                    </div>

                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="btn btn-success ">
                        <i class="bi bi-check-lg me-1" aria-hidden="true"></i>
                        Guardar Producto
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>


<div class="modal fade"
    id="editProductModal"
    tabindex="-1"
    aria-labelledby="editProductModalLabel"
    aria-hidden="true">

    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow">

            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate>

                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-semibold" id="editProductModalLabel">
                        <i class="bi bi-pencil-square me-2" aria-hidden="true"></i>
                        Editar Producto
                    </h5>
                        <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Cerrar">
                    </button>
                </div>

                <div class="modal-body">
                    <input type="hidden" asp-for="EditProduct.Id" />

                    <h6 class="text-muted mb-3">Información General</h6>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="EditProduct.Name" class="form-label">Nombre</label>
                            <input asp-for="EditProduct.Name" class="form-control" required />
                            <span asp-validation-for="EditProduct.Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="EditProduct.CategoryId" class="form-label">Categoría</label>
                            <select asp-for="EditProduct.CategoryId" class="form-select">
                                <option value="0">Sin categoría</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                            <span asp-validation-for="EditProduct.CategoryId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="EditProduct.Description" class="form-label">Descripción</label>
                        <textarea asp-for="EditProduct.Description"
                                  class="form-control"
                                  style="min-height:120px; resize: none;"></textarea>
                        <span asp-validation-for="EditProduct.Description" class="text-danger small"></span>
                    </div>

                    <hr>

                    <h6 class="text-muted mb-3">Inventario y Fechas</h6>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Stock" class="form-label">Stock</label>
                            <input asp-for="EditProduct.Stock"
                                   type="number"
                                   class="form-control"
                                   required />
                            <span asp-validation-for="EditProduct.Stock" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Batch" class="form-label">Lote</label>
                            <input asp-for="EditProduct.Batch"
                                   type="date"
                                   class="form-control"
                                   max="@DateTime.Now.ToString("yyyy-MM-dd")"
                                value="@(Model.EditProduct != null ? Model.EditProduct.Batch.ToString("yyyy-MM-dd") : string.Empty)"
                                   required />
                            <span asp-validation-for="EditProduct.Batch" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="EditProduct.ExpirationDate" class="form-label">
                                Fecha de Vencimiento
                            </label>
                            <input asp-for="EditProduct.ExpirationDate"
                                   type="date"
                                          value="@(Model.EditProduct != null ? Model.EditProduct.ExpirationDate.ToString("yyyy-MM-dd") : string.Empty)"
                                   class="form-control"
                                   required />
                            <span asp-validation-for="EditProduct.ExpirationDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr>

                    <h6 class="text-muted mb-3">Precio</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Price" class="form-label">Precio</label>
                            <div class="input-group">
                                <span class="input-group-text">Bs.</span>
                                <input asp-for="EditProduct.Price"
                                       type="number"
                                       step="0.01"
                                       class="form-control"
                                       required />
                            </div>
                            <span asp-validation-for="EditProduct.Price" class="text-danger small"></span>
                        </div>
                    </div>

                </div>

                <div class="modal-footer border-0 pt-0">
                          <a href="/Products"
                              class="btn btn-outline-secondary">
                        Cancelar
                    </a>
                    <button type="submit"
                            class="btn btn-primary">
                        <i class="bi bi-check-lg me-1" aria-hidden="true"></i>
                        Actualizar Producto
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    @if (Model.ShowModal)
    {
        <script>
            var myModal = new bootstrap.Modal(document.getElementById('addProductModal'));
            myModal.show();
        </script>
    }

    @if (Model.EditProduct != null && Model.EditProduct.Id != 0)
    {
        <script>
            var editModalElement = document.getElementById('editProductModal');
            if (editModalElement && typeof bootstrap !== 'undefined') {
                var editModal = new bootstrap.Modal(editModalElement);
                editModalElement.addEventListener('hidden.bs.modal', function () {
                    var url = new URL(window.location.href);
                    if (url.searchParams.has('editId')) {
                        window.location.href = '/Products';
                    }
                }, { once: true });
                editModal.show();
            }
        </script>
    }
    
    
}