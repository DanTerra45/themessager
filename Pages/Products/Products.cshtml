@page "/Products"
@model Mercadito.Pages.Products.ProductsModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Productos";
    ViewData["UseToasts"] = true;
    var showIdColumn = bool.TryParse(Configuration["Ui:ShowIDs"], out var showIDs) && showIDs;
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Gestión del inventario de productos</p>
    </section>
    <button type="button" class="b-btn" style="background-color: #198754; color: white; border-color: var(--mrc-ink); box-shadow: 2px 2px 0 var(--mrc-ink);" data-bs-toggle="modal" data-bs-target="#addProductModal">
        <i class="bi bi-plus-circle"></i> Agregar Nuevo Producto
    </button>
</header>

@if (Model.Products.Count > 0 || Model.CategoryFilter != 0)
{
    <section class="mb-4">
        <form method="post" asp-page-handler="Filter" class="d-flex align-items-center gap-2">
            <input type="hidden" name="sortBy" value="@Model.SortBy" />
            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
            <select name="categoryFilter" class="form-select fw-bold" style="max-width: 300px; border-width: 2px; border-color: var(--mrc-ink);">
                <option value="0" selected="@(Model.CategoryFilter == 0)">Todas las categorías</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id" selected="@(Model.CategoryFilter == category.Id)">@category.Name</option>
                }
            </select>
            <button type="submit" class="b-btn" style="background-color: #0d6efd; color: white; border-color: #0d6efd; box-shadow: 2px 2px 0 #0a58ca;">Filtrar</button>
        </form>
    </section>
}

<section>
    @if (Model.Products.Count > 0)
    {
        <section class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="text-center">
                    <tr>
                        @if (showIdColumn)
                        {
                            <th class="sortable-header" title="Ordenar por ID">
                                <form method="post" asp-page-handler="Sort" class="d-inline">
                                    <input type="hidden" name="sortBy" value="id" />
                                    <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                    <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                    <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                    <button type="submit" class="sort-button">
                                        ID <i class="bi @Model.GetSortIcon("id")" style="font-size: 0.8em;"></i>
                                    </button>
                                </form>
                            </th>
                        }
                        <th class="sortable-header" title="Ordenar por Nombre">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="name" />
                                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Nombre <i class="bi @Model.GetSortIcon("name")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th>Descripción</th>
                        <th>Categorías</th>
                        <th class="sortable-header" title="Ordenar por Stock">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="stock" />
                                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Stock <i class="bi @Model.GetSortIcon("stock")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="sortable-header" title="Ordenar por Lote">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="batch" />
                                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Lote <i class="bi @Model.GetSortIcon("batch")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="sortable-header" title="Ordenar por Vencimiento">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="expirationDate" />
                                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Vencimiento <i class="bi @Model.GetSortIcon("expirationDate")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="text-end sortable-header" title="Ordenar por Precio">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="price" />
                                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Precio <i class="bi @Model.GetSortIcon("price")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="text-center" style="width: 200px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            @if (showIdColumn)
                            {
                                <td class="small text-muted" style="font-family: var(--font-mono);">
                                    @product.Id
                                </td>
                            }

                            <td class="fw-bold" style="font-family: var(--font-display); font-size: 1.1rem;">@product.Name</td>

                            <td class="text-truncate truncate-description-product">
                                @product.Description
                            </td>

                            <td class="text-center">
                                @if (product.Categories.Count > 0)
                                {
                                    @foreach (var category in product.Categories)
                                    {
                                        <mark class="badge bg-secondary me-1 mb-1" style="font-family: var(--font-mono); font-size: 0.85rem; border: 1px solid var(--mrc-ink); display: inline-block;">@category</mark>
                                    }
                                }
                                else
                                {
                                    <small class="text-muted" style="font-family: var(--font-mono);">Sin categorías</small>
                                }
                            </td>

                            <td class="text-center">
                                @if(product.Stock <= 5)
                                {
                                    <mark class="status-badge" data-status="danger">@product.Stock</mark>
                                }
                                else if(product.Stock <= 20)
                                {
                                    <mark class="status-badge" data-status="warning">@product.Stock</mark>
                                }
                                else
                                {
                                    <mark class="status-badge" data-status="good">@product.Stock</mark>
                                }
                            </td>

                            <td class="text-center" style="font-family: var(--font-mono);">
                                @product.Batch
                            </td>

                            <td class="text-center" style="font-family: var(--font-mono);">
                                @product.ExpirationDate.ToShortDateString()
                            </td>

                            <td class="text-end fw-bold" style="font-family: var(--font-mono); font-size: 1.1rem;">
                                @($"{product.Price:N2} Bs.")
                            </td>

                            <td class="text-center">
                                <menu class="d-flex justify-content-center gap-2 m-0 p-0" style="list-style: none;">
                                    <form method="post" asp-page-handler="StartEdit" class="d-inline">
                                        <input type="hidden" name="id" value="@product.Id" />
                                        <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                                        <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                        <input type="hidden" name="sortBy" value="@Model.SortBy" />
                                        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                                        <button type="submit" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </form>

                                    <button class="b-btn b-btn-danger" style="padding: 0.25rem 0.5rem;" title="Eliminar"
                                            aria-label="Eliminar"
                                            type="button"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteProductModal"
                                            data-id="@product.Id"
                                            data-name="@product.Name"
                                            data-has-categories="@(product.Categories.Count > 0 ? "true" : "false")">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </menu>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
    else
    {
        <aside class="text-center text-muted py-5" style="font-family: var(--font-mono); border: 2px dashed var(--mrc-ink); border-radius: var(--radius-md);">
            No hay productos registrados que coincidan con la búsqueda.
        </aside>
    }

    <section class="d-flex justify-content-center mt-4">
        <nav aria-label="Paginación de productos">
            <ul class="pagination">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <form method="post" asp-page-handler="Navigate" class="d-inline">
                        <input type="hidden" name="pageNumber" value="@(Model.CurrentPage - 1)" />
                        <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                        <input type="hidden" name="sortBy" value="@Model.SortBy" />
                        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                        <button type="submit" class="page-link" disabled="@(Model.CurrentPage == 1)">
                            <i class="bi bi-chevron-left me-1"></i>Anterior
                        </button>
                    </form>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                        <form method="post" asp-page-handler="Navigate" class="d-inline">
                            <input type="hidden" name="pageNumber" value="@i" />
                            <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                            <input type="hidden" name="sortBy" value="@Model.SortBy" />
                            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                            <button type="submit" class="page-link">@i</button>
                        </form>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <form method="post" asp-page-handler="Navigate" class="d-inline">
                        <input type="hidden" name="pageNumber" value="@(Model.CurrentPage + 1)" />
                        <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                        <input type="hidden" name="sortBy" value="@Model.SortBy" />
                        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                        <button type="submit" class="page-link" disabled="@(Model.CurrentPage == Model.TotalPages)">
                            Siguiente<i class="bi bi-chevron-right ms-1"></i>
                        </button>
                    </form>
                </li>
            </ul>
        </nav>
    </section>
</section>

<!-- Modals -->
<section class="modal fade" id="deleteProductModal" tabindex="-1" aria-labelledby="deleteProductModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Delete" id="deleteProductForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <input type="hidden" name="id" id="DeleteProductId" />

                <header class="modal-header" style="background-color: var(--mrc-danger); color: white;">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; color: white;" id="deleteProductModalLabel">
                        <i class="bi bi-exclamation-triangle me-2"></i> Confirmar eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">
                    <p class="mb-3" style="font-size: 1.1rem;">¿Está seguro de eliminar el producto seleccionado?</p>
                    <p class="mb-4" style="font-family: var(--font-mono); padding: 1rem; background-color: var(--mrc-surface-alt); border: 2px solid var(--mrc-ink); border-radius: var(--radius-sm);">
                        Producto: <strong id="deleteProductName" style="font-size: 1.2rem;">-</strong>
                    </p>
                    <aside id="deleteProductCategoryWarning" class="alert app-status-alert d-none mb-0" role="alert">
                        Este producto tiene relación con una o más categorías. Primero se eliminará la relación con categorías y luego el producto.
                    </aside>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn b-btn-danger">
                        <i class="bi bi-trash me-1"></i> Eliminar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-lg modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate id="createProductForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />

                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="addProductModalLabel">
                        <i class="bi bi-box-seam me-2"></i> Nuevo Producto
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Información General</h6>
                    <section class="row">
                        <section class="col-md-6 mb-3">
                            <label asp-for="NewProduct.Name" class="form-label fw-bold">Nombre</label>
                            <input asp-for="NewProduct.Name" class="form-control" required />
                            <span asp-validation-for="NewProduct.Name" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>

                        <section class="col-md-6 mb-3">
                            <label asp-for="NewProduct.CategoryIds" class="form-label fw-bold">Categorías</label>
                            <section class="dropdown">
                                <button class="form-select text-start" type="button" id="newCategoryDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" style="background-color: var(--mrc-surface); border-width: 2px !important; border-color: var(--mrc-ink) !important; font-family: var(--font-mono); font-size: 1rem; min-height: 38px; display: flex; align-items: center; justify-content: space-between;">
                                    <span id="newCategoryDropdownText" class="dropdown-fade-container">Sin categorías seleccionadas</span>
                                </button>
                                <ul class="dropdown-menu w-100 p-0 shadow-sm" aria-labelledby="newCategoryDropdown" style="max-height: 200px; overflow-y: auto; background-color: var(--mrc-surface); border: 2px solid var(--mrc-ink); border-radius: 0; box-shadow: var(--shadow-brutal);">
                                    @foreach (var category in Model.Categories)
                                    {
                                        <li>
                                            <label class="dropdown-item category-select-item m-0 d-flex align-items-center justify-content-between" for="newCat_@category.Id" style="cursor: pointer; border-radius: 0; font-family: var(--font-mono); font-size: 0.9rem; padding: 0.5rem 1rem; border-bottom: 1px solid var(--mrc-ink);">
                                                <input class="d-none new-category-checkbox" type="checkbox" name="NewProduct.CategoryIds" value="@category.Id" id="newCat_@category.Id" data-name="@category.Name">
                                                <span class="text-truncate">@category.Name</span>
                                                <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                                            </label>
                                        </li>
                                    }
                                </ul>
                            </section>
                            <span asp-validation-for="NewProduct.CategoryIds" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                    </section>

                    <section class="mb-4">
                        <label asp-for="NewProduct.Description" class="form-label fw-bold">Descripción</label>
                        <textarea asp-for="NewProduct.Description" class="form-control product-description-textarea"></textarea>
                        <span asp-validation-for="NewProduct.Description" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Inventario y Fechas</h6>
                    <section class="row">
                        <section class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Stock" class="form-label fw-bold">Stock</label>
                            <section class="input-group brutal-number-group">
                                <button class="btn b-btn-number border-end-0" type="button" tabindex="-1" data-step="-1">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <input asp-for="NewProduct.Stock" value=0 type="number" class="form-control text-center px-0" min="0" required />
                                <button class="btn b-btn-number border-start-0" type="button" tabindex="-1" data-step="1">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </section>
                            <span asp-validation-for="NewProduct.Stock" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                        <section class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Batch" class="form-label fw-bold">Lote</label>
                            <input asp-for="NewProduct.Batch" type="text" class="form-control" maxlength="40" required />
                            <span asp-validation-for="NewProduct.Batch" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>

                        <section class="col-md-4 mb-3">
                            <label asp-for="NewProduct.ExpirationDate" class="form-label fw-bold">Vencimiento</label>
                            <input asp-for="NewProduct.ExpirationDate" type="text" class="form-control date-picker-input" asp-format="{0:yyyy-MM-dd}" required />
                            <span asp-validation-for="NewProduct.ExpirationDate" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Precio</h6>
                    <section class="row">
                        <section class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Price" class="form-label fw-bold">Precio</label>
                            <section class="input-group brutal-number-group">
                                <strong class="input-group-text border-end-0">Bs.</strong>
                                <button class="btn b-btn-number border-end-0" type="button" tabindex="-1" data-step="-1">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <input asp-for="NewProduct.Price"  type="number" step="0.01" class="form-control text-center px-0" min="0.01" required />
                                <button class="btn b-btn-number border-start-0" type="button" tabindex="-1" data-step="1">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </section>
                            <span asp-validation-for="NewProduct.Price" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                    </section>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">
                        <i class="bi bi-check-lg me-1"></i> Guardar Producto
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="editProductModal" tabindex="-1" aria-labelledby="editProductModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-lg modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate id="updateProductForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <input type="hidden" asp-for="EditProduct.Id" />

                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="editProductModalLabel">
                        <i class="bi bi-pencil-square me-2"></i> Editar Producto
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Información General</h6>
                    <section class="row">
                        <section class="col-md-6 mb-3">
                            <label asp-for="EditProduct.Name" class="form-label fw-bold">Nombre</label>
                            <input asp-for="EditProduct.Name" class="form-control" required />
                            <span asp-validation-for="EditProduct.Name" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>

                        <section class="col-md-6 mb-3">
                            <label asp-for="EditProduct.CategoryIds" class="form-label fw-bold">Categorías</label>
                            <section class="dropdown">
                                <button class="form-select text-start" type="button" id="editCategoryDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" style="background-color: var(--mrc-surface); border-width: 2px !important; border-color: var(--mrc-ink) !important; font-family: var(--font-mono); font-size: 1rem; min-height: 38px; display: flex; align-items: center; justify-content: space-between;">
                                    <span id="editCategoryDropdownText" class="text-truncate">Sin categorías seleccionadas</span>
                                </button>
                                <ul class="dropdown-menu w-100 p-1 shadow-sm" aria-labelledby="editCategoryDropdown" style="max-height: 200px; overflow-y: auto; background-color: var(--mrc-surface); border: 2px solid var(--mrc-ink); border-radius: var(--radius-sm); box-shadow: var(--shadow-brutal);">
                                    @foreach (var category in Model.Categories)
                                    {
                                        bool isChecked = Model.EditProduct.CategoryIds.Contains(category.Id);
                                        <li>
                                            <label class="dropdown-item category-select-item m-0 d-flex align-items-center justify-content-between" for="editCat_@category.Id" style="cursor: pointer; border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 0.9rem; padding: 0.5rem 1rem;">
                                                <input class="d-none edit-category-checkbox" type="checkbox" name="EditProduct.CategoryIds" value="@category.Id" id="editCat_@category.Id" checked="@isChecked" data-name="@category.Name">
                                                <span class="text-truncate">@category.Name</span>
                                                <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                                            </label>
                                        </li>
                                    }
                                </ul>
                            </section>
                            <span asp-validation-for="EditProduct.CategoryIds" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                    </section>

                    <section class="mb-4">
                        <label asp-for="EditProduct.Description" class="form-label fw-bold">Descripción</label>
                        <textarea asp-for="EditProduct.Description" class="form-control product-description-textarea"></textarea>
                        <span asp-validation-for="EditProduct.Description" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Inventario y Fechas</h6>
                    <section class="row">
                        <section class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Stock" class="form-label fw-bold">Stock</label>
                            <section class="input-group brutal-number-group">
                                <button class="btn b-btn-number border-end-0" type="button" tabindex="-1" data-step="-1">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <input asp-for="EditProduct.Stock" type="number"  class="form-control text-center px-0" min="0" required />
                                <button class="btn b-btn-number border-start-0" type="button" tabindex="-1" data-step="1">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </section>
                            <span asp-validation-for="EditProduct.Stock" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>

                        <section class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Batch" class="form-label fw-bold">Lote</label>
                            <input asp-for="EditProduct.Batch" type="text" class="form-control" maxlength="40" required />
                            <span asp-validation-for="EditProduct.Batch" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>

                        <section class="col-md-4 mb-3">
                            <label asp-for="EditProduct.ExpirationDate" class="form-label fw-bold">Vencimiento</label>
                            <input asp-for="EditProduct.ExpirationDate" type="text" class="form-control date-picker-input" asp-format="{0:yyyy-MM-dd}" required />
                            <span asp-validation-for="EditProduct.ExpirationDate" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Precio</h6>
                    <section class="row">
                        <section class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Price" class="form-label fw-bold">Precio</label>
                            <section class="input-group brutal-number-group">
                                <strong class="input-group-text border-end-0">Bs.</strong>
                                <button class="btn b-btn-number border-end-0" type="button" tabindex="-1" data-step="-1">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <input asp-for="EditProduct.Price" type="number" step="0.01" class="form-control text-center px-0" min="0.01" required />
                                <button class="btn b-btn-number border-start-0" type="button" tabindex="-1" data-step="1">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </section>
                            <span asp-validation-for="EditProduct.Price" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                        </section>
                    </section>
                </section>

                <footer class="modal-footer">
                    <a asp-page="./Products" class="b-btn b-btn-secondary text-decoration-none">
                        Cancelar
                    </a>
                    <button type="submit" class="b-btn">
                        <i class="bi bi-check-lg me-1"></i> Actualizar Producto
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<!-- Brutalist Toasts -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1060;">
    @if (TempData["SuccessMessage"] is string successMsg && !string.IsNullOrWhiteSpace(successMsg))
    {
        <div class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4000" style="background-color: white; border: 4px solid var(--mrc-ink) !important; border-radius: 0; box-shadow: 4px 4px 0 var(--mrc-ink); opacity: 1;">
            <div class="d-flex position-relative">
                <div class="toast-icon d-flex align-items-center justify-content-center" style="background-color: var(--mrc-success); width: 60px; border-right: 4px solid var(--mrc-ink);">
                    <i class="bi bi-check-circle" style="font-size: 1.5rem; color: var(--mrc-ink);"></i>
                </div>
                <div class="toast-body d-flex align-items-center" style="font-family: var(--font-mono); font-weight: bold; flex-grow: 1; min-height: 60px;">
                    @successMsg
                </div>
                <button type="button" class="btn-close me-2 m-auto position-absolute top-0 end-0 mt-2" data-bs-dismiss="toast" aria-label="Cerrar" style="background-size: 0.8em;"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMsg && !string.IsNullOrWhiteSpace(errorMsg))
    {
        <div class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="6000" style="background-color: white; border: 4px solid var(--mrc-ink) !important; border-radius: 0; box-shadow: 4px 4px 0 var(--mrc-ink); opacity: 1;">
            <div class="d-flex position-relative">
                <div class="toast-icon d-flex align-items-center justify-content-center" style="background-color: var(--mrc-danger); width: 60px; border-right: 4px solid var(--mrc-ink);">
                    <i class="bi bi-x-circle" style="font-size: 1.5rem; color: white;"></i>
                </div>
                <div class="toast-body d-flex align-items-center" style="font-family: var(--font-mono); font-weight: bold; flex-grow: 1; min-height: 60px;">
                    @errorMsg
                </div>
                <button type="button" class="btn-close me-2 m-auto position-absolute top-0 end-0 mt-2" data-bs-dismiss="toast" aria-label="Cerrar" style="background-size: 0.8em;"></button>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.b-btn-number[data-step]').forEach(function (button) {
                button.addEventListener('click', function () {
                    var inputGroup = button.closest('.input-group');
                    if (!inputGroup) {
                        return;
                    }

                    var numericInput = inputGroup.querySelector('input[type=number]');
                    if (!numericInput) {
                        return;
                    }

                    if (button.getAttribute('data-step') == '-1') {
                        numericInput.stepDown();
                    } else {
                        numericInput.stepUp();
                    }
                });
            });
        });
    </script>

    @if (Model.ShowModal)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var createModalElement = document.getElementById('addProductModal');
                if (createModalElement && typeof bootstrap !== 'undefined') {
                    var createModal = new bootstrap.Modal(createModalElement);
                    createModal.show();
                }
            });
        </script>
    }

    @if (Model.ShowEditModal)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var editModalElement = document.getElementById('editProductModal');
                if (editModalElement && typeof bootstrap !== 'undefined') {
                    var editModal = new bootstrap.Modal(editModalElement);
                    editModal.show();
                }
            });
        </script>
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Spanish locale definition for AirDatepicker
            const localeEs = {
                days: ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'],
                daysShort: ['Dom', 'Lun', 'Mar', 'Mie', 'Jue', 'Vie', 'Sab'],
                daysMin: ['Do', 'Lu', 'Ma', 'Mi', 'Ju', 'Vi', 'Sa'],
                months: ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'],
                monthsShort: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'],
                today: 'Hoy',
                clear: 'Limpiar',
                dateFormat: 'dd/MM/yyyy',
                timeFormat: 'hh:mm aa',
                firstDay: 1
            };

            // Initialize Air Datepicker for dates
            const dateInputs = document.querySelectorAll('.date-picker-input');
            dateInputs.forEach(input => {
                const minDate = input.getAttribute('data-min-date');
                new AirDatepicker(input, {
                    locale: localeEs,
                    dateFormat: 'yyyy-MM-dd',
                    minDate: minDate || undefined,
                    autoClose: true,
                    isMobile: false
                });
            });

            var deleteProductModal = document.getElementById('deleteProductModal');
            if (deleteProductModal) {
                deleteProductModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    if (!button) {
                        return;
                    }

                    var productId = button.getAttribute('data-id') || '';
                    var productName = button.getAttribute('data-name') || '-';
                    var hasCategories = (button.getAttribute('data-has-categories') || '').toLowerCase() === 'true';

                    var deleteIdInput = document.getElementById('DeleteProductId');
                    var deleteNameLabel = document.getElementById('deleteProductName');
                    var deleteCategoryWarning = document.getElementById('deleteProductCategoryWarning');

                    if (deleteIdInput) {
                        deleteIdInput.value = productId;
                    }
                    if (deleteNameLabel) {
                        deleteNameLabel.textContent = productName;
                    }
                    if (deleteCategoryWarning) {
                        deleteCategoryWarning.classList.toggle('d-none', !hasCategories);
                    }
                });
            }

            // Actualizar texto del dropdown de categorías en modal de crear
            function updateNewCategoryText() {
                const checkedBoxes = document.querySelectorAll('.new-category-checkbox:checked');
                const textSpan = document.getElementById('newCategoryDropdownText');
                if (checkedBoxes.length === 0) {
                    textSpan.textContent = 'Sin categorías seleccionadas';
                } else if (checkedBoxes.length === 1) {
                    textSpan.textContent = checkedBoxes[0].getAttribute('data-name');
                } else {
                    textSpan.textContent = checkedBoxes.length + ' categorías seleccionadas';
                }
            }

            document.querySelectorAll('.new-category-checkbox').forEach(box => {
                box.addEventListener('change', function() {
                    updateNewCategoryText();
                    const label = this.closest('.category-select-item');
                    const icon = label.querySelector('.check-icon');
                    if (this.checked) {
                        label.style.backgroundColor = 'rgba(0, 230, 118, 0.15)'; // Soft brutalist green
                        label.style.fontWeight = 'bold';
                        icon.classList.remove('d-none');
                    } else {
                        label.style.backgroundColor = '';
                        label.style.fontWeight = 'normal';
                        icon.classList.add('d-none');
                    }
                });
                // Initialize styles
                box.dispatchEvent(new Event('change'));
            });

            // Actualizar texto del dropdown de categorías en modal de editar
            function updateEditCategoryText() {
                const checkedBoxes = document.querySelectorAll('.edit-category-checkbox:checked');
                const textSpan = document.getElementById('editCategoryDropdownText');
                if (checkedBoxes.length === 0) {
                    textSpan.textContent = 'Sin categorías seleccionadas';
                } else if (checkedBoxes.length === 1) {
                    textSpan.textContent = checkedBoxes[0].getAttribute('data-name');
                } else {
                    textSpan.textContent = checkedBoxes.length + ' categorías seleccionadas';
                }
            }

            document.querySelectorAll('.edit-category-checkbox').forEach(box => {
                box.addEventListener('change', function() {
                    updateEditCategoryText();
                    const label = this.closest('.category-select-item');
                    const icon = label.querySelector('.check-icon');
                    if (this.checked) {
                        label.style.backgroundColor = 'rgba(0, 230, 118, 0.15)'; // Soft brutalist green
                        label.style.fontWeight = 'bold';
                        icon.classList.remove('d-none');
                    } else {
                        label.style.backgroundColor = '';
                        label.style.fontWeight = 'normal';
                        icon.classList.add('d-none');
                    }
                });
                // Initialize styles
                box.dispatchEvent(new Event('change'));
            });

        });
    </script>
}
