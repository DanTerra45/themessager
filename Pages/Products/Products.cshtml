@page
@model Mercadito.Pages.Products.ProductsModel
@{
    ViewData["Title"] = "Productos";
}

<h1>@ViewData["Title"]</h1>

<div class="mb-3">
    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addProductModal">
        <i class="bi bi-plus-circle"></i> Agregar Nuevo Producto
    </button>
</div>

<div>
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light text-center">
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Categorías</th>
                            <th>Stock</th>
                            <th>Lote</th>
                            <th>Vencimiento</th>
                            <th class="text-end">Precio</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Products != null && Model.Products.Count > 0)
                    {
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td class="small text-muted">
                                    @product.Id.ToString().Substring(0,8)
                                </td>

                                <td class="fw-semibold">@product.Name</td>

                                <td class="text-truncate" style="max-width: 200px;">
                                    @product.Description
                                </td>

                                <td>
                                    @if (product.Categories != null && product.Categories.Count > 0)
                                    {
                                        @foreach (var category in product.Categories)
                                        {
                                            <span class="badge bg-secondary me-1">@category</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Sin categoría</span>
                                    }
                                </td>

                                <td class="text-center">
                                    @if(product.Stock <= 5)
                                    {
                                        <span class="badge bg-danger">@product.Stock</span>
                                    }
                                    else if(product.Stock <= 20)
                                    {
                                        <span class="badge bg-warning text-dark">@product.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@product.Stock</span>
                                    }
                                </td>

                                <td class="text-center">
                                    @product.Lote.ToShortDateString()
                                </td>

                                <td class="text-center">
                                    @product.FechaDeCaducidad.ToShortDateString()
                                </td>

                                <td class="text-end fw-bold">
                                    @($"{product.Price:N2} Bs.")
                                </td>

                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <!-- Keep product id and open an edit modal that will be populated by fetching product details -->
                                        <button class="btn btn-outline-primary edit-product-btn"
                                                data-product-id="@product.Id"
                                                type="button">
                                            <i class="bi bi-pencil"></i> Editar
                                        </button>

                                        <form method="post" asp-page-handler="Delete" class="d-inline">
                                            <input type="hidden" name="id" value="@product.Id" />
                                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Eliminar producto?')">
                                                <i class="bi bi-trash"></i> Eliminar
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                No se encontraron productos.
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex justify-content-center">
        <nav>
            <ul class="pagination">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-page-handler="Index" asp-route-page="@(Model.CurrentPage - 1)">Anterior</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                        <a class="page-link" asp-page-handler="Index" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page-handler="Index" asp-route-page="@(Model.CurrentPage + 1)">Siguiente</a>
                </li>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<!-- Add Product Modal (unchanged) -->
<div class="modal fade" id="addProductModal" tabindex="-1"
     aria-labelledby="addProductModalLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow">

            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate>

                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-semibold" id="addProductModalLabel">
                        <i class="bi bi-box-seam me-2"></i>
                        Nuevo Producto
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body">
                    <h6 class="text-muted mb-3">Información General</h6>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="NewProduct.Name" class="form-label">Nombre</label>
                            <input asp-for="NewProduct.Name" class="form-control" required />
                            <span asp-validation-for="NewProduct.Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="NewProduct.CategoryId" class="form-label">Categoría</label>
                            <select asp-for="NewProduct.CategoryId" class="form-select" required>
                                <option value="@Guid.Empty">Seleccionar categoría</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                            <span asp-validation-for="NewProduct.CategoryId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="NewProduct.Description" class="form-label">Descripción</label>
                        <textarea asp-for="NewProduct.Description"
                                  class="form-control"
                                  style="min-height:120px;
                                  resize: none;"
                                  ></textarea>
                        <span asp-validation-for="NewProduct.Description" class="text-danger small"></span>
                    </div>

                    <hr>

                    <h6 class="text-muted mb-3">Inventario y Fechas</h6>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Stock" class="form-label">Stock</label>
                            <input asp-for="NewProduct.Stock"
                                   type="number"
                                   class="form-control"
                                   min="0"
                                   required />
                            <span asp-validation-for="NewProduct.Stock" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Lote" class="form-label">Lote</label>
                            <input asp-for="NewProduct.Lote"
                                   type="date"
                                   class="form-control"
                                   required />
                            <span asp-validation-for="NewProduct.Lote" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="NewProduct.FechaDeCaducidad" class="form-label">
                                Fecha de Vencimiento
                            </label>
                            <input asp-for="NewProduct.FechaDeCaducidad"
                                   type="date"
                                   class="form-control"
                                   required />
                            <span asp-validation-for="NewProduct.FechaDeCaducidad" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr>

                    <h6 class="text-muted mb-3">Precio</h6>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="NewProduct.Price" class="form-label">Precio</label>
                            <div class="input-group">
                                <span class="input-group-text">Bs.</span>
                                <input asp-for="NewProduct.Price"
                                       type="number"
                                       step="0.01"
                                       class="form-control"
                                       min="0"
                                       required />
                            </div>
                            <span asp-validation-for="NewProduct.Price" class="text-danger small"></span>
                        </div>
                    </div>

                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="btn btn-success ">
                        <i class="bi bi-check-lg me-1"></i>
                        Guardar Producto
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- Edit Product Modal -->
<div class="modal fade" id="editProductModal" tabindex="-1" aria-labelledby="editProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow">
            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate>
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-semibold" id="editProductModalLabel">
                        <i class="bi bi-pencil me-2"></i> Editar Producto
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input asp-for="EditProduct.Id" type="hidden" />

                    <h6 class="text-muted mb-3">Información General</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="EditProduct.Name" class="form-label">Nombre</label>
                            <input asp-for="EditProduct.Name" class="form-control" required />
                            <span asp-validation-for="EditProduct.Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="EditProduct.CategoryId" class="form-label">Categoría</label>
                            <select asp-for="EditProduct.CategoryId" class="form-select" id="editProductCategorySelect">
                                <option value="@Guid.Empty">No asignada</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                            <span asp-validation-for="EditProduct.CategoryId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="EditProduct.Description" class="form-label">Descripción</label>
                        <textarea asp-for="EditProduct.Description" class="form-control" style="min-height:120px; resize: none;"></textarea>
                        <span asp-validation-for="EditProduct.Description" class="text-danger small"></span>
                    </div>

                    <hr>

                    <h6 class="text-muted mb-3">Inventario y Fechas</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Stock" class="form-label">Stock</label>
                            <input asp-for="EditProduct.Stock" type="number" class="form-control" min="0" required />
                            <span asp-validation-for="EditProduct.Stock" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Lote" class="form-label">Lote</label>
                            <input asp-for="EditProduct.Lote" type="date" class="form-control" required />
                            <span asp-validation-for="EditProduct.Lote" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="EditProduct.FechaDeCaducidad" class="form-label">Fecha de Vencimiento</label>
                            <input asp-for="EditProduct.FechaDeCaducidad" type="date" class="form-control" required />
                            <span asp-validation-for="EditProduct.FechaDeCaducidad" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr>

                    <h6 class="text-muted mb-3">Precio</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="EditProduct.Price" class="form-label">Precio</label>
                            <div class="input-group">
                                <span class="input-group-text">Bs.</span>
                                <input asp-for="EditProduct.Price" type="number" step="0.01" class="form-control" min="0" required />
                            </div>
                            <span asp-validation-for="EditProduct.Price" class="text-danger small"></span>
                        </div>
                    </div>

                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // use fetch to get full product details (including current category id)
            var editBtns = document.querySelectorAll('.edit-product-btn');
            editBtns.forEach(function (btn) {
                btn.addEventListener('click', async function () {
                    var productId = btn.getAttribute('data-product-id');
                    if (!productId) return;

                    try {
                        var resp = await fetch(`/Products?handler=Details&id=${productId}`);
                        if (!resp.ok) throw new Error('Error fetching product details');
                        var data = await resp.json();

                        var modal = document.getElementById('editProductModal');
                        if (!modal) return;

                        modal.querySelector('[name="EditProduct.Id"]').value = data.id ?? '';
                        modal.querySelector('[name="EditProduct.Name"]').value = data.name ?? '';
                        modal.querySelector('[name="EditProduct.Description"]').value = data.description ?? '';
                        modal.querySelector('[name="EditProduct.Stock"]').value = data.stock ?? '';
                        modal.querySelector('[name="EditProduct.Lote"]').value = data.lote ?? '';
                        modal.querySelector('[name="EditProduct.FechaDeCaducidad"]').value = data.fechaDeCaducidad ?? '';
                        modal.querySelector('[name="EditProduct.Price"]').value = data.price ?? '';

                        // preselect category
                        var select = document.getElementById('editProductCategorySelect');
                        if (select) {
                            var catId = data.categoryId ?? '';
                            select.value = catId || "@Guid.Empty";
                        }

                        // show modal (in case it didn't open automatically)
                        var bsModal = new bootstrap.Modal(modal);
                        bsModal.show();
                    } catch (err) {
                        console.error(err);
                        alert('No se pudo cargar la información del producto.');
                    }
                });
            });

            // If server requested modal reopen due to validation errors:
            @if (TempData["ShowEditProductModal"] != null && TempData["ShowEditProductModal"].ToString() == "true")
            {
                <text>
                var m = new bootstrap.Modal(document.getElementById('editProductModal'));
                m.show();
                </text>
            }
        });
    </script>
}