@page "/Products"
@model Mercadito.Pages.Products.ProductsModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Productos";
    ViewData["UseToasts"] = true;
    var showIdColumn = bool.TryParse(Configuration["Ui:ShowIDs"], out var showIDs) && showIDs;
    var hasCategories = Model.Categories.Count > 0;
    var selectedFilterCategoryName = "Todas las categorías";
    foreach (var category in Model.Categories)
    {
        if (category.Id == Model.CategoryFilter)
        {
            selectedFilterCategoryName = category.Name;
            break;
        }
    }
    var isRecentOrderPreset = string.Equals(Model.OrderPreset, "recent");
    var isAlphabeticalAscOrderPreset = string.Equals(Model.OrderPreset, "az");
    var isAlphabeticalDescOrderPreset = string.Equals(Model.OrderPreset, "za");
    var selectedOrderPresetValue = "custom";
    var selectedOrderPresetName = "Personalizado";
    var minAllowedExpirationDate = DateTime.Today.ToString("yyyy-MM-dd");
    if (isRecentOrderPreset)
    {
        selectedOrderPresetValue = "recent";
        selectedOrderPresetName = "Recientes";
    }
    else if (isAlphabeticalAscOrderPreset)
    {
        selectedOrderPresetValue = "az";
        selectedOrderPresetName = "A-Z";
    }
    else if (isAlphabeticalDescOrderPreset)
    {
        selectedOrderPresetValue = "za";
        selectedOrderPresetName = "Z-A";
    }
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Gestión del inventario de productos</p>
    </section>
    <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#addProductModal">
        <i class="bi bi-plus-circle"></i> Nuevo Producto
    </button>
</header>

@if (Model.Products.Count > 0 || Model.CategoryFilter != 0 || !string.IsNullOrWhiteSpace(Model.SearchTerm))
{
    <section class="mb-4 products-filter-wrap">
        <form method="post" asp-page-handler="Filter" class="products-filter-form">
            <input type="hidden" name="sortBy" value="@Model.SortBy" />
            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
            <input type="hidden" id="categoryFilterInput" name="categoryFilter" value="@Model.CategoryFilter" />
            <section class="products-search-field">
                <label for="productsSearchTerm" class="visually-hidden">Buscar producto</label>
                <input type="search"
                       id="productsSearchTerm"
                       name="searchTerm"
                       class="form-control products-search-input"
                       value="@Model.SearchTerm"
                       placeholder="Buscar producto..."
                       autocomplete="off" />
            </section>

            <section class="dropdown products-filter-dropdown">
                <button class="form-select text-start category-select-trigger products-filter-trigger"
                        type="button"
                        id="productsFilterDropdown"
                        data-bs-toggle="dropdown"
                        data-bs-auto-close="outside"
                        aria-expanded="false">
                    <span id="productsFilterDropdownText" class="dropdown-fade-container">@selectedFilterCategoryName</span>
                </button>

                <ul class="dropdown-menu w-100 p-0 shadow-sm category-dropdown-menu products-filter-dropdown-menu"
                    aria-labelledby="productsFilterDropdown">
                    <li class="products-filter-search-wrap">
                        <input type="text"
                               id="productsFilterSearch"
                               class="form-control products-filter-search"
                               placeholder="Buscar categoría..."
                               autocomplete="off"
                               aria-label="Buscar categoría" />
                    </li>
                    <li>
                        <button type="button"
                                class="dropdown-item category-select-item products-filter-item m-0 d-flex align-items-center justify-content-between"
                                data-filter-value="0"
                                data-filter-name="Todas las categorías">
                            <span class="text-truncate">Todas las categorías</span>
                            <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                        </button>
                    </li>
                    @foreach (var category in Model.Categories)
                    {
                        <li>
                            <button type="button"
                                    class="dropdown-item category-select-item products-filter-item m-0 d-flex align-items-center justify-content-between"
                                    data-filter-value="@category.Id"
                                    data-filter-name="@category.Name">
                                <span class="text-truncate">@category.Name</span>
                                <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                            </button>
                        </li>
                    }
                </ul>
            </section>

            <section class="dropdown products-order-field">
                <label for="productsOrderDropdown" class="visually-hidden">Orden</label>
                <input type="hidden" id="productsOrderPresetInput" name="orderPreset" value="@selectedOrderPresetValue" />
                <button class="form-select text-start category-select-trigger products-order-trigger"
                        type="button"
                        id="productsOrderDropdown"
                        data-bs-toggle="dropdown"
                        aria-expanded="false">
                    <span id="productsOrderDropdownText" class="dropdown-fade-container">@selectedOrderPresetName</span>
                </button>

                <ul class="dropdown-menu w-100 p-0 shadow-sm category-dropdown-menu products-order-dropdown-menu"
                    aria-labelledby="productsOrderDropdown">
                    <li>
                        <button type="button"
                                class="dropdown-item products-order-item m-0 d-flex align-items-center justify-content-between"
                                data-order-value="recent"
                                data-order-name="Recientes">
                            <span class="text-truncate">Recientes</span>
                            <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                        </button>
                    </li>
                    <li>
                        <button type="button"
                                class="dropdown-item products-order-item m-0 d-flex align-items-center justify-content-between"
                                data-order-value="az"
                                data-order-name="A-Z">
                            <span class="text-truncate">A-Z</span>
                            <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                        </button>
                    </li>
                    <li>
                        <button type="button"
                                class="dropdown-item products-order-item m-0 d-flex align-items-center justify-content-between"
                                data-order-value="za"
                                data-order-name="Z-A">
                            <span class="text-truncate">Z-A</span>
                            <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                        </button>
                    </li>
                    <li class="d-none" aria-hidden="true">
                        <button type="button"
                                class="dropdown-item products-order-item m-0 d-flex align-items-center justify-content-between"
                                data-order-value="custom"
                                data-order-name="Personalizado"
                                disabled
                                tabindex="-1"
                                aria-hidden="true">
                            <span class="text-truncate">Personalizado</span>
                            <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                        </button>
                    </li>
                </ul>
            </section>

            <section class="products-filter-actions">
                <button type="submit" class="b-btn b-btn-secondary products-icon-btn" title="Buscar productos" aria-label="Buscar productos">
                    <i class="bi bi-search"></i>
                </button>
                <button type="submit" class="b-btn b-btn-secondary products-icon-btn" title="Filtrar por categoría" aria-label="Filtrar por categoría">
                    <i class="bi bi-funnel"></i>
                </button>
            </section>

            @if (Model.CategoryFilter != 0 || !string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <button type="submit" name="clear" value="true" class="b-btn b-btn-secondary products-icon-btn" title="Limpiar" aria-label="Limpiar">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </button>
            }
        </form>
    </section>
}

<section>
    @if (Model.Products.Count > 0)
    {
        <section class="table-responsive table-shadow-safe-wrap products-table-wrap">
            <table class="table table-hover align-middle products-table">
                <thead class="text-center">
                    <tr>
                        @if (showIdColumn)
                        {
                            <th class="sortable-header" title="Ordenar por ID">
                                <form method="post" asp-page-handler="Sort" class="d-inline">
                                    <input type="hidden" name="sortBy" value="id" />
                                    <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                    <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                    <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                    <button type="submit" class="sort-button">
                                        ID <i class="bi @Model.GetSortIcon("id")" style="font-size: 0.8em;"></i>
                                    </button>
                                </form>
                            </th>
                        }
                        <th class="sortable-header" title="Ordenar por Nombre">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="name" />
                                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Nombre <i class="bi @Model.GetSortIcon("name")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th>Descripción</th>
                        <th>Categorías</th>
                        <th class="sortable-header" title="Ordenar por Stock">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="stock" />
                                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Stock <i class="bi @Model.GetSortIcon("stock")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="sortable-header" title="Ordenar por Lote">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="batch" />
                                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Lote <i class="bi @Model.GetSortIcon("batch")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="sortable-header" title="Ordenar por Vencimiento">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="expirationDate" />
                                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Vencimiento <i class="bi @Model.GetSortIcon("expirationDate")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="sortable-header" title="Ordenar por Precio">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="price" />
                                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Precio <i class="bi @Model.GetSortIcon("price")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="text-center products-actions-col" style="width: 170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            @if (showIdColumn)
                            {
                                <td class="small text-muted" style="font-family: var(--font-mono);">
                                    @product.Id
                                </td>
                            }

                            <td class="fw-bold product-name-cell" style="font-family: var(--font-display); font-size: 1.1rem;">
                                <span class="table-ellipsis table-ellipsis-name" title="@product.Name">@product.Name</span>
                            </td>

                            <td class="product-description-cell">
                                <span class="table-ellipsis table-ellipsis-description" title="@product.Description">@product.Description</span>
                            </td>

                            <td class="text-center">
                                @if (product.Categories.Count > 0)
                                {
                                    var maxVisibleCategories = 3;
                                    var visibleCategoriesCount = product.Categories.Count < maxVisibleCategories
                                        ? product.Categories.Count
                                        : maxVisibleCategories;
                                    var hiddenCategoriesCount = product.Categories.Count - visibleCategoriesCount;

                                    for (var categoryIndex = 0; categoryIndex < visibleCategoriesCount; categoryIndex++)
                                    {
                                        var category = product.Categories[categoryIndex];
                                        <mark class="badge bg-secondary me-1 mb-1 product-category-badge" style="font-family: var(--font-mono); font-size: 0.85rem; border: 1px solid var(--mrc-ink); display: inline-block;" title="@category">@category</mark>
                                    }

                                    if (hiddenCategoriesCount > 0)
                                    {
                                        var hiddenCategoriesTitle = string.Empty;
                                        for (var hiddenCategoryIndex = maxVisibleCategories; hiddenCategoryIndex < product.Categories.Count; hiddenCategoryIndex++)
                                        {
                                            if (hiddenCategoryIndex > maxVisibleCategories)
                                            {
                                                hiddenCategoriesTitle += ", ";
                                            }

                                            hiddenCategoriesTitle += product.Categories[hiddenCategoryIndex];
                                        }
                                        <mark class="badge bg-secondary me-1 mb-1 product-category-badge product-category-extra-badge"
                                              style="font-family: var(--font-mono); font-size: 0.85rem; border: 1px solid var(--mrc-ink); display: inline-block;"
                                              title="@hiddenCategoriesTitle">
                                            +@hiddenCategoriesCount
                                        </mark>
                                    }
                                }
                                else
                                {
                                    <small class="text-muted" style="font-family: var(--font-mono);">Sin categorías</small>
                                }
                            </td>

                            <td class="text-center">
                                @if(product.Stock <= 5)
                                {
                                    <mark class="status-badge" data-status="danger">@product.Stock</mark>
                                }
                                else if(product.Stock <= 20)
                                {
                                    <mark class="status-badge" data-status="warning">@product.Stock</mark>
                                }
                                else
                                {
                                    <mark class="status-badge" data-status="good">@product.Stock</mark>
                                }
                            </td>

                            <td class="text-center product-batch-cell" style="font-family: var(--font-mono);">
                                <span class="table-ellipsis table-ellipsis-batch" title="@product.Batch">@product.Batch</span>
                            </td>

                            <td class="text-center" style="font-family: var(--font-mono);">
                                @product.ExpirationDate.ToShortDateString()
                            </td>

                            <td class="text-end fw-bold" style="font-family: var(--font-mono); font-size: 1.1rem;">
                                @($"{product.Price:N2} Bs.")
                            </td>

                            <td class="text-center">
                                <menu class="d-flex justify-content-center gap-2 m-0 p-0" style="list-style: none;">
                                    <form method="post" asp-page-handler="StartEdit" class="d-inline">
                                        <input type="hidden" name="id" value="@product.Id" />
                                        <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                                        <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                                        <input type="hidden" name="sortBy" value="@Model.SortBy" />
                                        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                                        <button type="submit" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </form>

                                    <button class="b-btn b-btn-danger" style="padding: 0.25rem 0.5rem;" title="Eliminar"
                                            aria-label="Eliminar"
                                            type="button"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteProductModal"
                                            data-id="@product.Id"
                                            data-name="@product.Name"
                                            data-has-categories="@(product.Categories.Count > 0 ? "true" : "false")">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </menu>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
    else
    {
        <aside class="text-center text-muted py-5" style="font-family: var(--font-mono); border: 2px dashed var(--mrc-ink); border-radius: var(--radius-md);">
            No hay productos registrados que coincidan con la búsqueda.
        </aside>
    }

    <section class="d-flex justify-content-center mt-4">
        <nav aria-label="Paginación de productos">
            <ul class="pagination">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <form method="post" asp-page-handler="Navigate" class="d-inline">
                        <input type="hidden" name="pageNumber" value="@(Model.CurrentPage - 1)" />
                        <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                        <input type="hidden" name="sortBy" value="@Model.SortBy" />
                        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                        <button type="submit" class="page-link" disabled="@(Model.CurrentPage == 1)">
                            <i class="bi bi-chevron-left me-1"></i>Anterior
                        </button>
                    </form>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                        <form method="post" asp-page-handler="Navigate" class="d-inline">
                            <input type="hidden" name="pageNumber" value="@i" />
                            <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                            <input type="hidden" name="sortBy" value="@Model.SortBy" />
                            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                            <button type="submit" class="page-link">@i</button>
                        </form>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <form method="post" asp-page-handler="Navigate" class="d-inline">
                        <input type="hidden" name="pageNumber" value="@(Model.CurrentPage + 1)" />
                        <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                        <input type="hidden" name="sortBy" value="@Model.SortBy" />
                        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                        <button type="submit" class="page-link" disabled="@(Model.CurrentPage == Model.TotalPages)">
                            Siguiente<i class="bi bi-chevron-right ms-1"></i>
                        </button>
                    </form>
                </li>
            </ul>
        </nav>
    </section>
</section>

<!-- Modals -->
<section class="modal fade" id="deleteProductModal" tabindex="-1" aria-labelledby="deleteProductModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Delete" id="deleteProductForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <input type="hidden" name="id" id="DeleteProductId" />

                <header class="modal-header" style="background-color: var(--mrc-danger); color: white;">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; color: white;" id="deleteProductModalLabel">
                        <i class="bi bi-exclamation-triangle me-2"></i> Confirmar eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4 product-modal-body">
                    <p class="mb-3" style="font-size: 1.1rem;">¿Está seguro de eliminar el producto seleccionado?</p>
                    <p class="mb-4" style="font-family: var(--font-mono); padding: 1rem; background-color: var(--mrc-surface-alt); border: 2px solid var(--mrc-ink); border-radius: var(--radius-sm);">
                        Producto: <strong id="deleteProductName" style="font-size: 1.2rem;">-</strong>
                    </p>
                    <aside id="deleteProductCategoryWarning" class="alert app-status-alert d-none mb-0" role="alert">
                        Este producto tiene relación con una o más categorías. Primero se eliminará la relación con categorías y luego el producto.
                    </aside>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn b-btn-danger">
                        <i class="bi bi-trash me-1"></i> Eliminar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-lg modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate id="createProductForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" name="categoryFilter" value="@Model.CategoryFilter" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />

                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="addProductModalLabel">
                        <i class="bi bi-box-seam me-2"></i> Nuevo Producto
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4 product-modal-body">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Información General</h6>
                    <section class="row">
                        <section class="col-md-6 mb-3">
                            <label asp-for="NewProduct.Name" class="form-label fw-bold">
                                Nombre
                                <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Máximo 150 caracteres.">i</span>
                                <span asp-validation-for="NewProduct.Name" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="NewProduct.Name" class="form-control" required />
                        </section>

                        <section class="col-md-6 mb-3">
                            <label asp-for="NewProduct.CategoryIds" class="form-label fw-bold category-field-label">
                                Categorías
                                <span class="info-tooltip" tabindex="0" data-info-message="Opcional. Puede dejarlo vacío o elegir varias categorías sin repetir. Si no hay categorías creadas, no estará disponible.">i</span>
                                <span asp-validation-for="NewProduct.CategoryIds" class="validation-icon-inline"></span>
                            </label>
                            <section class="dropdown">
                                @if (hasCategories)
                                {
                                    <button class="form-select text-start category-select-trigger" type="button" id="newCategoryDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" style="border: 2px solid var(--mrc-ink); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 1rem;">
                                        <span id="newCategoryDropdownText" class="dropdown-fade-container">Sin categorías seleccionadas</span>
                                    </button>
                                }
                                else
                                {
                                    <button class="form-select text-start category-select-trigger" type="button" id="newCategoryDropdown" aria-expanded="false" disabled style="border: 2px solid var(--mrc-ink); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 1rem;">
                                        <span id="newCategoryDropdownText" class="dropdown-fade-container">No hay categorías creadas.</span>
                                    </button>
                                }
                                <ul class="dropdown-menu w-100 p-0 shadow-sm category-dropdown-menu" aria-labelledby="newCategoryDropdown" style="max-height: 200px; overflow-y: auto; background-color: var(--mrc-surface); border: 2px solid var(--mrc-ink); border-radius: 0; box-shadow: var(--shadow-brutal);">
                                    @foreach (var category in Model.Categories)
                                    {
                                        <li>
