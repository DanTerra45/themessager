@page "/Suppliers"
@model Mercadito.Pages.Suppliers.SuppliersModel
@{
    ViewData["Title"] = "Proveedores";
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Directorio para compras y abastecimiento</p>
    </section>
    <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#nuevoProveedorModal">
        <i class="bi bi-truck"></i> Nuevo Proveedor
    </button>
</header>

<section class="b-card p-0 overflow-hidden">
    <header class="d-flex justify-content-between align-items-center p-3" style="border-bottom: 2px solid var(--mrc-ink); background-color: var(--mrc-surface-alt);">
        <strong style="font-family: var(--font-display); text-transform: uppercase;">Listado de proveedores</strong>
        <mark class="status-badge" data-status="warning">Solo visual</mark>
    </header>
    <section class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="text-center">
                <tr>
                    <th>Código</th>
                    <th>Razón social</th>
                    <th>Contacto</th>
                    <th>Teléfono</th>
                    <th>Rubro</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var supplier in Model.ActiveSuppliers)
                {
                    <tr>
                        <td style="font-family: var(--font-mono);" class="fw-bold">@supplier.Codigo</td>
                        <td class="fw-bold">@supplier.RazonSocial</td>
                        <td>@supplier.Contacto</td>
                        <td style="font-family: var(--font-mono);">@supplier.Telefono</td>
                        <td>@supplier.Rubro</td>
                        <td class="text-center">
                            <button type="button" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;" disabled title="Ver detalle">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button type="button" class="b-btn b-btn-secondary ms-1" style="padding: 0.25rem 0.5rem;" disabled title="Editar registro">
                                <i class="bi bi-pencil"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</section>

<section class="modal fade" id="nuevoProveedorModal" tabindex="-1" aria-labelledby="nuevoProveedorModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <header class="modal-header">
                <h5 class="modal-title" id="nuevoProveedorModalLabel" style="font-family: var(--font-display); font-weight: 800;">
                    <i class="bi bi-building-add me-2"></i> Registrar Proveedor
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </header>
            <section class="modal-body p-4">
                <section class="mb-3">
                    <label class="form-label fw-bold">Razón social</label>
                    <input class="form-control" placeholder="Ejemplo: Distribuidora Centro" />
                </section>
                <section class="mb-3">
                    <label class="form-label fw-bold">NIT / Documento</label>
                    <input class="form-control" placeholder="Dato no persistente" />
                </section>
                <section class="mb-0">
                    <label class="form-label fw-bold">Rubro principal</label>
                    <input class="form-control" placeholder="Alimentos, limpieza, panadería..." />
                </section>
            </section>
            <footer class="modal-footer">
                <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="b-btn" disabled>Guardar</button>
            </footer>
        </article>
    </section>
</section>
