@page "/Suppliers"
@model Mercadito.Pages.Suppliers.SuppliersModel
@{
    ViewData["Title"] = "Proveedores";
    ViewData["UseToasts"] = true;

    string BuildTooltipMessage(IEnumerable<string> messages)
    {
        return string.Join(" ", messages.Where(message => !string.IsNullOrWhiteSpace(message)).Select(message => $"• {message.Trim()}"));
    }
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Directorio para compras y abastecimiento</p>
    </section>
    <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#nuevoProveedorModal">
        <i class="bi bi-truck"></i> Nuevo Proveedor
    </button>
</header>

<section class="mb-4 listing-filter-wrap">
    <form method="post" asp-page-handler="Filter" class="listing-filter-form">
        <section class="listing-search-field">
            <label for="suppliersSearchTerm" class="visually-hidden">Buscar proveedor</label>
            <input type="search"
                   id="suppliersSearchTerm"
                   name="searchTerm"
                   class="form-control listing-search-input"
                   value="@Model.SearchTerm"
                   placeholder="Buscar proveedor..."
                   autocomplete="off" />
        </section>
        <section class="listing-filter-actions">
            <button type="submit" class="b-btn b-btn-secondary listing-icon-btn" title="Buscar proveedores" aria-label="Buscar proveedores">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <button type="submit" name="clear" value="true" class="b-btn b-btn-secondary listing-icon-btn" title="Limpiar búsqueda" aria-label="Limpiar búsqueda">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </button>
            }
        </section>
    </form>
</section>

@if (Model.ActiveSuppliers.Count > 0)
{
    <section class="table-responsive table-shadow-safe-wrap">
        <table class="table table-hover align-middle">
                <thead class="text-center">
                    <tr>
                        <th>Código</th>
                        <th>Razón social</th>
                        <th>Contacto</th>
                        <th>Teléfono</th>
                        <th>Rubro</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var supplier in Model.ActiveSuppliers)
                    {
                        <tr>
                            <td style="font-family: var(--font-mono);" class="fw-bold">@supplier.Codigo</td>
                            <td class="fw-bold">@supplier.RazonSocial</td>
                            <td>@supplier.Contacto</td>
                            <td style="font-family: var(--font-mono);">@supplier.Telefono</td>
                            <td>@supplier.Rubro</td>
                            <td class="text-center">
                                <button type="button" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;" disabled title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button type="button" 
                                        class="b-btn b-btn-secondary ms-1" 
                                        style="padding: 0.25rem 0.5rem;" 
                                        title="Editar registro"
                                        data-bs-toggle="modal" 
                                        data-bs-target="#editarProveedorModal"
                                        data-id="@supplier.Id"
                                        data-details-url="@Url.Page("/Suppliers/Suppliers", "Details", new { id = supplier.Id })">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
    </section>
}
else
{
    <aside class="text-center text-muted py-5" style="font-family: var(--font-mono); border: 2px dashed var(--mrc-ink); border-radius: var(--radius-md);">
        @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
        {
            <span>No se encontraron proveedores para la búsqueda actual.</span>
        }
        else
        {
            <span>No hay proveedores registrados en el sistema.</span>
        }
    </aside>
}

<form method="post" asp-page-handler="Create" class="needs-validation" novalidate autocomplete="off" id="createSupplierForm">
    <input type="hidden" id="showModalOnError" value="@(Model.ShowModalOnError && Model.ActiveModal == "create" ? "true" : "false")" />
    <section class="modal fade" id="nuevoProveedorModal" tabindex="-1" aria-labelledby="nuevoProveedorModalLabel" aria-hidden="true">
        <section class="modal-dialog modal-dialog-centered">
            <article class="modal-content">
                <header class="modal-header">
                    <h5 class="modal-title" id="nuevoProveedorModalLabel" style="font-family: var(--font-display); font-weight: 800;">
                        <i class="bi bi-building-add me-2"></i> Registrar Proveedor
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>
                <section class="modal-body p-4">
                     
                    <!-- Código -->
                    <section class="mb-3">
                        <label class="form-label fw-bold">
                            Código
                            @if (Model.FieldHints.TryGetValue("Codigo", out var codigoHints) && codigoHints.Count > 0)
                            {
                                <span class="info-tooltip" tabindex="0" data-info-message="@BuildTooltipMessage(codigoHints)">i</span>
                            }
                            @if (Model.CodigoErrors?.Count > 0)
                            {
                                <span class="validation-icon-inline field-validation-error" data-valmsg-for="Codigo" data-error-message="@BuildTooltipMessage(Model.CodigoErrors)" aria-label="@BuildTooltipMessage(Model.CodigoErrors)"></span>
                            }
                        </label>
                        <input class="form-control supplier-code-readonly @(Model.CodigoErrors?.Count > 0 ? "is-invalid" : "")" 
                               asp-for="Codigo" 
                               value="@Model.NextSupplierCodePreview"
                               readonly
                               autocomplete="off" />
                    </section>

                    <!-- Razón Social -->
                    <section class="mb-3">
                        <label class="form-label fw-bold">
                            Razón social
                            @if (Model.FieldHints.TryGetValue("Nombre", out var nombreHints) && nombreHints.Count > 0)
                            {
                                <span class="info-tooltip" tabindex="0" data-info-message="@BuildTooltipMessage(nombreHints)">i</span>
                            }
                            @if (Model.RazonSocialErrors?.Count > 0)
                            {
                                <span class="validation-icon-inline field-validation-error" data-valmsg-for="RazonSocial" data-error-message="@BuildTooltipMessage(Model.RazonSocialErrors)" aria-label="@BuildTooltipMessage(Model.RazonSocialErrors)"></span>
                            }
                        </label>
                        <input class="form-control @(Model.RazonSocialErrors?.Count > 0 ? "is-invalid" : "")" 
                               asp-for="RazonSocial" 
                               placeholder="Ejemplo: Distribuidora Centro" />
                    </section>

                    <!-- Dirección -->
                    <section class="mb-3">
                        <label class="form-label fw-bold">
                            Dirección
                            @if (Model.FieldHints.TryGetValue("Direccion", out var direccionHints) && direccionHints.Count > 0)
                            {
                                <span class="info-tooltip" tabindex="0" data-info-message="@BuildTooltipMessage(direccionHints)">i</span>
                            }
                            @if (Model.DireccionErrors?.Count > 0)
                            {
                                <span class="validation-icon-inline field-validation-error" data-valmsg-for="Direccion" data-error-message="@BuildTooltipMessage(Model.DireccionErrors)" aria-label="@BuildTooltipMessage(Model.DireccionErrors)"></span>
                            }
                        </label>
                        <input class="form-control @(Model.DireccionErrors?.Count > 0 ? "is-invalid" : "")" 
                               asp-for="Direccion" 
                               placeholder="Calle, número, zona" />
                    </section>

                    <!-- Contacto -->
                    <section class="mb-3">
                        <label class="form-label fw-bold">
                            Contacto
                            @if (Model.FieldHints.TryGetValue("Contacto", out var contactoHints) && contactoHints.Count > 0)
                            {
                                <span class="info-tooltip" tabindex="0" data-info-message="@BuildTooltipMessage(contactoHints)">i</span>
                            }
                            @if (Model.ContactoErrors?.Count > 0)
                            {
                                <span class="validation-icon-inline field-validation-error" data-valmsg-for="Contacto" data-error-message="@BuildTooltipMessage(Model.ContactoErrors)" aria-label="@BuildTooltipMessage(Model.ContactoErrors)"></span>
                            }
                        </label>
                        <input class="form-control @(Model.ContactoErrors?.Count > 0 ? "is-invalid" : "")" 
                               asp-for="Contacto" 
                               placeholder="Nombre del contacto" />
                    </section>

                    <!-- Rubro -->
                    <section class="mb-0">
                        <label class="form-label fw-bold">
                            Rubro
                            @if (Model.FieldHints.TryGetValue("Rubro", out var rubroHints) && rubroHints.Count > 0)
                            {
                                <span class="info-tooltip" tabindex="0" data-info-message="@BuildTooltipMessage(rubroHints)">i</span>
                            }
                            @if (Model.RubroErrors?.Count > 0)
                            {
                                <span class="validation-icon-inline field-validation-error" data-valmsg-for="Rubro" data-error-message="@BuildTooltipMessage(Model.RubroErrors)" aria-label="@BuildTooltipMessage(Model.RubroErrors)"></span>
                            }
                        </label>
                        <input class="form-control @(Model.RubroErrors?.Count > 0 ? "is-invalid" : "")" 
                               asp-for="Rubro" 
                               placeholder="Ejemplo: Alimentos" />
                    </section>
                </section>
                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="b-btn">Guardar</button>
                </footer>
            </article>
        </section>
    </section>
</form>

