@page "/Suppliers"
@model Mercadito.Pages.Suppliers.SuppliersModel
@{
    ViewData["Title"] = "Proveedores";
    ViewData["UseToasts"] = true;
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Directorio para compras y abastecimiento</p>
    </section>
    <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#nuevoProveedorModal">
        <i class="bi bi-truck"></i> Nuevo Proveedor
    </button>
</header>

<section class="b-card p-0 overflow-hidden">
    <header class="d-flex justify-content-between align-items-center p-3" style="border-bottom: 2px solid var(--mrc-ink); background-color: var(--mrc-surface-alt);">
        <strong style="font-family: var(--font-display); text-transform: uppercase;">Listado de proveedores</strong>
        <mark class="status-badge" data-status="warning">Solo visual</mark>
    </header>
    <section class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="text-center">
                <tr>
                    <th>Código</th>
                    <th>Razón social</th>
                    <th>Contacto</th>
                    <th>Teléfono</th>
                    <th>Rubro</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var supplier in Model.ActiveSuppliers)
                {
                    <tr>
                        <td style="font-family: var(--font-mono);" class="fw-bold">@supplier.Codigo</td>
                        <td class="fw-bold">@supplier.RazonSocial</td>
                        <td>@supplier.Contacto</td>
                        <td style="font-family: var(--font-mono);">@supplier.Telefono</td>
                        <td>@supplier.Rubro</td>
                        <td class="text-center">
                            <button type="button" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;" disabled title="Ver detalle">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button type="button" 
                                    class="b-btn b-btn-secondary ms-1" 
                                    style="padding: 0.25rem 0.5rem;" 
                                    title="Editar registro"
                                    data-bs-toggle="modal" 
                                    data-bs-target="#editarProveedorModal"
                                    data-id="@supplier.Id"
                                    data-codigo="@supplier.Codigo"
                                    data-razonsocial="@supplier.RazonSocial"
                                    data-contacto="@supplier.Contacto"
                                    data-telefono="@supplier.Telefono"
                                    data-rubro="@supplier.Rubro">
                                <i class="bi bi-pencil"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</section>

<form method="post" asp-page-handler="Create">
    <input type="hidden" id="showModalOnError" value="@(Model.ShowModalOnError && Model.ActiveModal == "create" ? "true" : "false")" />
    <section class="modal fade" id="nuevoProveedorModal" tabindex="-1" aria-labelledby="nuevoProveedorModalLabel" aria-hidden="true">
        <section class="modal-dialog modal-dialog-centered">
            <article class="modal-content">
                <header class="modal-header">
                    <h5 class="modal-title" id="nuevoProveedorModalLabel" style="font-family: var(--font-display); font-weight: 800;">
                        <i class="bi bi-building-add me-2"></i> Registrar Proveedor
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>
                <section class="modal-body p-4">
                     
                    <!-- Código -->
                    <section class="mb-3">
                        <label class="form-label fw-bold">
                            Código
                            @if (Model.FieldHints.TryGetValue("Codigo", out var codigoHints) && codigoHints.Count > 0)
                            {
                                var codigoHintMsg = Html.Raw($"<ul class='mb-0 ps-3'>{string.Join("", codigoHints.Select(h => $"<li>{h}</li>"))}</ul>").ToString();
                                <span class="info-tooltip" tabindex="0" data-bs-toggle="tooltip" data-bs-html="true" title="@codigoHintMsg">i</span>
                            }
                            @if (Model.CodigoErrors?.Count > 0)
                            {
                                var codigoErrorMsg = Html.Raw($"<ul class='mb-0 ps-3'>{string.Join("", Model.CodigoErrors.Select(e => $"<li>{e}</li>"))}</ul>").ToString();
                                <span class="error-tooltip" data-bs-toggle="tooltip" data-bs-html="true" title="@codigoErrorMsg">
                                    <i class="bi bi-exclamation-triangle-fill text-danger ms-1"></i>
                                </span>
                            }
                        </label>
                        <input class="form-control @(Model.CodigoErrors?.Count > 0 ? "is-invalid" : "")" 
                               asp-for="Codigo" 
                               placeholder="ABC123" />
                    </section>

                    <!-- Razón Social -->
                    <section class="mb-3">
                        <label class="form-label fw-bold">
                            Razón social
                            @if (Model.FieldHints.TryGetValue("Nombre", out var nombreHints) && nombreHints.Count > 0)
                            {
                                var nombreHintMsg = Html.Raw($"<ul class='mb-0 ps-3'>{string.Join("", nombreHints.Select(h => $"<li>{h}</li>"))}</ul>").ToString();
                                <span class="info-tooltip" tabindex="0" data-bs-toggle="tooltip" data-bs-html="true" title="@nombreHintMsg">i</span>
                            }
                            @if (Model.RazonSocialErrors?.Count > 0)
                            {
                                var nombreErrorMsg = Html.Raw($"<ul class='mb-0 ps-3'>{string.Join("", Model.RazonSocialErrors.Select(e => $"<li>{e}</li>"))}</ul>").ToString();
                                <span class="error-tooltip" data-bs-toggle="tooltip" data-bs-html="true" title="@nombreErrorMsg">
                                    <i class="bi bi-exclamation-triangle-fill text-danger ms-1"></i>
                                </span>
                            }
                        </label>
                        <input class="form-control @(Model.RazonSocialErrors?.Count > 0 ? "is-invalid" : "")" 
                               asp-for="RazonSocial" 
                               placeholder="Ejemplo: Distribuidora Centro" />
                    </section>

                    <!-- Dirección -->
                    <section class="mb-3">
                        <label class="form-label fw-bold">
                            Dirección
                            @if (Model.FieldHints.TryGetValue("Direccion", out var direccionHints) && direccionHints.Count > 0)
                            {
                                var direccionHintMsg = Html.Raw($"<ul class='mb-0 ps-3'>{string.Join("", direccionHints.Select(h => $"<li>{h}</li>"))}</ul>").ToString();
                                <span class="info-tooltip" tabindex="0" data-bs-toggle="tooltip" data-bs-html="true" title="@direccionHintMsg">i</span>
                            }
                            @if (Model.DireccionErrors?.Count > 0)
                            {
                                var direccionErrorMsg = Html.Raw($"<ul class='mb-0 ps-3'>{string.Join("", Model.DireccionErrors.Select(e => $"<li>{e}</li>"))}</ul>").ToString();
                                <span class="error-tooltip" data-bs-toggle="tooltip" data-bs-html="true" title="@direccionErrorMsg">
                                    <i class="bi bi-exclamation-triangle-fill text-danger ms-1"></i>
                                </span>
                            }
                        </label>
                        <input class="form-control @(Model.DireccionErrors?.Count > 0 ? "is-invalid" : "")" 
                               asp-for="Direccion" 
                               placeholder="Calle, número, zona" />
                    </section>

                    <!-- Contacto -->
                    <section class="mb-3">
                        <label class="form-label fw-bold">
                            Contacto
                            @if (Model.FieldHints.TryGetValue("Contacto", out var contactoHints) && contactoHints.Count > 0)
                            {
                                var contactoHintMsg = Html.Raw($"<ul class='mb-0 ps-3'>{string.Join("", contactoHints.Select(h => $"<li>{h}</li>"))}</ul>").ToString();
                                <span class="info-tooltip" tabindex="0" data-bs-toggle="tooltip" data-bs-html="true" title="@contactoHintMsg">i</span>
                            }
                            @if (Model.ContactoErrors?.Count > 0)
                            {
                                var contactoErrorMsg = Html.Raw($"<ul class='mb-0 ps-3'>{string.Join("", Model.ContactoErrors.Select(e => $"<li>{e}</li>"))}</ul>").ToString();
                                <span class="error-tooltip" data-bs-toggle="tooltip" data-bs-html="true" title="@contactoErrorMsg">
                                    <i class="bi bi-exclamation-triangle-fill text-danger ms-1"></i>
                                </span>
                            }
                        </label>
                        <input class="form-control @(Model.ContactoErrors?.Count > 0 ? "is-invalid" : "")" 
                               asp-for="Contacto" 
                               placeholder="Nombre del contacto" />
                    </section>

                    <!-- Rubro -->
                    <section class="mb-0">
                        <label class="form-label fw-bold">
                            Rubro
                            @if (Model.FieldHints.TryGetValue("Rubro", out var rubroHints) && rubroHints.Count > 0)
                            {
                                var rubroHintMsg = Html.Raw($"<ul class='mb-0 ps-3'>{string.Join("", rubroHints.Select(h => $"<li>{h}</li>"))}</ul>").ToString();
                                <span class="info-tooltip" tabindex="0" data-bs-toggle="tooltip" data-bs-html="true" title="@rubroHintMsg">i</span>
                            }
                            @if (Model.RubroErrors?.Count > 0)
                            {
                                var rubroErrorMsg = Html.Raw($"<ul class='mb-0 ps-3'>{string.Join("", Model.RubroErrors.Select(e => $"<li>{e}</li>"))}</ul>").ToString();
                                <span class="error-tooltip" data-bs-toggle="tooltip" data-bs-html="true" title="@rubroErrorMsg">
                                    <i class="bi bi-exclamation-triangle-fill text-danger ms-1"></i>
                                </span>
                            }
                        </label>
                        <input class="form-control @(Model.RubroErrors?.Count > 0 ? "is-invalid" : "")" 
                               asp-for="Rubro" 
                               placeholder="Ejemplo: Alimentos" />
                    </section>
                </section>
                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="b-btn">Guardar</button>
                </footer>
            </article>
        </section>
    </section>
</form>

