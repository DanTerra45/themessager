@page "/Categories"
@model Mercadito.Pages.Categories.CategoriesModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment
@{
    ViewData["Title"] = "Categorías";
    var showIdColumn = HostEnvironment.IsDevelopment();
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Organización del catálogo</p>
    </section>
    <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
        <i class="bi bi-plus-circle"></i> Nueva Categoría
    </button>
</header>

<section>
    @if (Model.Categories != null && Model.Categories.Count > 0)
    {
        <section class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="text-center">
                    <tr>
                        @if (showIdColumn)
                        {
                            <th>ID</th>
                        }
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Productos Asociados</th>
                        <th class="text-center" style="width: 170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model.Categories)
                    {
                        <tr>
                            @if (showIdColumn)
                            {
                                <td class="small text-muted" style="font-family: var(--font-mono);">
                                    @category.Id
                                </td>
                            }
                            <td class="text-center">
                                <mark class="badge bg-secondary" style="font-family: var(--font-mono); font-size: 0.9rem;">@category.Code</mark>
                            </td>
                            <td class="fw-bold" style="font-family: var(--font-display); font-size: 1.1rem;">@category.Name</td>
                            <td class="text-truncate truncate-description-category" style="max-width: 250px;">@category.Description</td>
                            <td class="text-center">
                                @if (category.ProductCount == 0)
                                {
                                    <mark class="status-badge" data-status="danger">0</mark>
                                }
                                else if (category.ProductCount <= 5)
                                {
                                    <mark class="status-badge" data-status="warning">@category.ProductCount</mark>
                                    <a asp-page="/Products/Products"
                                       asp-route-categoryFilter="@category.Id"
                                       class="b-btn ms-2" style="background-color: white; color: #0d6efd; border-color: #0d6efd; box-shadow: 2px 2px 0 #0d6efd; padding: 0.1rem 0.4rem; font-size: 0.85rem; vertical-align: middle;"
                                       title="Ver productos de esta categoría">
                                        <i class="bi bi-eye-fill" aria-hidden="true"></i>
                                    </a>
                                }
                                else
                                {
                                    <mark class="status-badge" data-status="good">@category.ProductCount</mark>
                                    <a asp-page="/Products/Products"
                                       asp-route-categoryFilter="@category.Id"
                                       class="b-btn ms-2" style="background-color: white; color: #0d6efd; border-color: #0d6efd; box-shadow: 2px 2px 0 #0d6efd; padding: 0.1rem 0.4rem; font-size: 0.85rem; vertical-align: middle;"
                                       title="Ver productos de esta categoría">
                                        <i class="bi bi-eye-fill" aria-hidden="true"></i>
                                    </a>
                                }
                            </td>
                            <td class="text-center">
                                <menu class="d-flex justify-content-center gap-2 m-0 p-0" style="list-style: none;">
                                    <button class="b-btn b-btn-secondary edit-category-btn" style="padding: 0.25rem 0.5rem;"
                                            title="Editar"
                                            aria-label="Editar"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editCategoryModal"
                                            data-id="@category.Id"
                                            data-code="@category.Code"
                                            data-name="@category.Name"
                                            data-description="@category.Description">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    
                                    <form method="post" asp-page-handler="Delete" class="d-inline">
                                        <input type="hidden" name="id" value="@category.Id" />
                                        <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                                        <button type="submit" class="b-btn b-btn-danger" style="padding: 0.25rem 0.5rem;"
                                                title="Eliminar"
                                                onclick="return confirm('¿Eliminar categoría?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </menu>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>

        <!-- Paginación -->
        <section class="d-flex justify-content-center mt-4">
            <nav aria-label="Paginación de categorías">
                <ul class="pagination">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-page="./Categories"
                           asp-route-pageNumber="@(Model.CurrentPage - 1)">
                            <i class="bi bi-chevron-left me-1"></i>Anterior
                        </a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <a class="page-link"
                               asp-page="./Categories"
                               asp-route-pageNumber="@i">
                                @i
                            </a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-page="./Categories"
                           asp-route-pageNumber="@(Model.CurrentPage + 1)">
                            Siguiente<i class="bi bi-chevron-right ms-1"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </section>
    }
    else
    {
        <aside class="text-center text-muted py-5" style="font-family: var(--font-mono); border: 2px dashed var(--mrc-ink); border-radius: var(--radius-md);">
            No hay categorías registradas en el sistema.
        </aside>
    }
</section>

<!-- Modals -->
<section class="modal fade" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate id="createCategoryForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />

                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="addCategoryModalLabel">
                        <i class="bi bi-tags me-2"></i> Nueva Categoría
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">
                    <aside asp-validation-summary="ModelOnly" class="text-danger small mb-3"></aside>

                    <section class="form-floating mb-3">
                        <input asp-for="NewCategory.Code" class="form-control fw-bold" placeholder="Código" required />
                        <label asp-for="NewCategory.Code" class="fw-bold">Código</label>
                        <small asp-validation-for="NewCategory.Code" class="text-danger"></small>
                    </section>

                    <section class="form-floating mb-3">
                        <input asp-for="NewCategory.Name" class="form-control fw-bold" placeholder="Nombre" required />
                        <label asp-for="NewCategory.Name" class="fw-bold">Nombre</label>
                        <small asp-validation-for="NewCategory.Name" class="text-danger"></small>
                    </section>

                    <section class="form-floating">
                        <textarea asp-for="NewCategory.Description" class="form-control category-description-textarea" placeholder="Descripción" rows="5"></textarea>
                        <label asp-for="NewCategory.Description" class="fw-bold">Descripción</label>
                        <small asp-validation-for="NewCategory.Description" class="text-danger"></small>
                    </section>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn" id="confirmCreateCategoryButton">
                        <i class="bi bi-check-lg me-1"></i> Guardar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="editCategoryModal" tabindex="-1" aria-labelledby="editCategoryModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate id="updateCategoryForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" asp-for="EditCategory.Id" />

                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="editCategoryModalLabel">
                        <i class="bi bi-pencil-square me-2"></i> Editar Categoría
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">
                    <aside asp-validation-summary="ModelOnly" class="text-danger small mb-3"></aside>

                    <section class="form-floating mb-3">
                        <input asp-for="EditCategory.Code" class="form-control fw-bold" placeholder="Código" required />
                        <label asp-for="EditCategory.Code" class="fw-bold">Código</label>
                        <small asp-validation-for="EditCategory.Code" class="text-danger"></small>
                    </section>

                    <section class="form-floating mb-3">
                        <input asp-for="EditCategory.Name" class="form-control fw-bold" placeholder="Nombre" required />
                        <label asp-for="EditCategory.Name" class="fw-bold">Nombre</label>
                        <small asp-validation-for="EditCategory.Name" class="text-danger"></small>
                    </section>

                    <section class="form-floating">
                        <textarea asp-for="EditCategory.Description" class="form-control category-description-textarea" placeholder="Descripción" rows="5"></textarea>
                        <label asp-for="EditCategory.Description" class="fw-bold">Descripción</label>
                        <small asp-validation-for="EditCategory.Description" class="text-danger"></small>
                    </section>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn" id="confirmUpdateCategoryButton">
                        <i class="bi bi-check-lg me-1"></i> Actualizar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.edit-category-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    document.getElementById('EditCategory_Id').value = button.getAttribute('data-id') || '';
                    document.getElementById('EditCategory_Code').value = button.getAttribute('data-code') || '';
                    document.getElementById('EditCategory_Name').value = button.getAttribute('data-name') || '';
                    document.getElementById('EditCategory_Description').value = button.getAttribute('data-description') || '';
                });
            });

            @if (Model.ShowCreateCategoryModal)
            {
                <text>
                var createModal = new bootstrap.Modal(document.getElementById('addCategoryModal'));
                createModal.show();
                </text>
            }

            @if (Model.ShowEditCategoryModal)
            {
                <text>
                var editModalElement = document.getElementById('editCategoryModal');
                var editModal = new bootstrap.Modal(editModalElement);
                editModalElement.addEventListener('hidden.bs.modal', function () {
                    var url = new URL(window.location.href);
                    if (url.searchParams.has('editId')) {
                        url.searchParams.delete('editId');
                        window.history.replaceState({}, document.title, url.toString());
                    }
                }, { once: true });
                editModal.show();
                </text>
            }
        });
    </script>
}