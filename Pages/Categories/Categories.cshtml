@page "/Categories"
@model Mercadito.Pages.Categories.CategoriesModel
@{
    ViewData["Title"] = "Categorías";
}

<h1>@ViewData["Title"]</h1>

<div class="mb-3">
    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
        <i class="bi bi-plus-circle" aria-hidden="true"></i> Agregar Nueva Categoría
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light text-center">
                    <tr>
                        <th>ID</th>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Productos Asociados</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>

                @if (Model.Categories != null && Model.Categories.Count > 0)
                {
                    @foreach (var category in Model.Categories)
                    {
                        <tr>
                            <td class="small text-muted">
                                @category.Id
                            </td>

                            <td>
                                <span class="badge bg-secondary">
                                    @category.Code
                                </span>
                            </td>

                            <td class="fw-semibold">
                                @category.Name
                            </td>

                            <td class="text-truncate" style="max-width: 250px;">
                                @category.Description
                            </td>

                            <td class="text-center">
                                @if(category.ProductCount == 0)
                                {
                                    <span class="badge bg-danger">0</span>
                                }
                                else if(category.ProductCount <= 5)
                                {
                                    <span class="badge bg-warning text-dark">
                                        @category.ProductCount
                                    </span>
                                                <a href="/Products?categoryFilter=@category.Code"
                                       class="btn btn-sm btn-link p-0 ms-1" 
                                       title="Ver productos de esta categoría">
                                        <i class="bi bi-eye-fill" aria-hidden="true"></i>
                                        ver productos
                                    </a>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        @category.ProductCount
                                    </span>
                                                <a href="/Products?categoryFilter=@category.Id"
                                       class="btn btn-sm btn-link p-0 ms-1" 
                                       title="Ver productos de esta categoría">
                                        <i class="bi bi-eye-fill" aria-hidden="true"></i>
                                        ver productos
                                    </a>
                                }
                            </td>

                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                                <a href="/Categories?page=@Model.CurrentPage&editId=@category.Id"
                                       class="btn btn-outline-primary">
                                        <i class="bi bi-pencil" aria-hidden="true"></i> Editar
                                    </a>

                                    <form method="post" asp-page-handler="Delete" class="d-inline">
                                        <input type="hidden" name="id" value="@category.Id" />
                                        <button type="submit" class="btn btn-outline-danger" 
                                                    onclick="return confirm('Eliminar categoría?')">
                                            <i class="bi bi-trash" aria-hidden="true"></i> Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No se encontraron categorías.
                        </td>
                    </tr>
                }

                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-center mt-3">
            <nav>
                <ul class="pagination pagination-sm">

                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-route-page="@(Model.CurrentPage - 1)">
                            <i class="bi bi-chevron-left" aria-hidden="true"></i>
                            <span class="visually-hidden">Anterior</span>
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <a class="page-link"
                               asp-route-page="@i">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-route-page="@(Model.CurrentPage + 1)">
                            <i class="bi bi-chevron-right" aria-hidden="true"></i>
                            <span class="visually-hidden">Siguiente</span>
                        </a>
                    </li>

                </ul>
            </nav>
        </div>

    </div>
</div>

<div class="modal fade" id="addCategoryModal" tabindex="-1"
     aria-labelledby="addCategoryModalLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">

            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate>

                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-semibold" id="addCategoryModalLabel">
                        <i class="bi bi-tags me-2" aria-hidden="true"></i>
                        Nueva Categoría
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Cerrar">
                    </button>
                </div>

                <div class="modal-body">

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="NewCategory.Code"
                               class="form-control"
                               placeholder="Código"
                               required />
                        <label asp-for="NewCategory.Code">Código</label>
                        <span asp-validation-for="NewCategory.Code"
                              class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="NewCategory.Name"
                               class="form-control"
                               placeholder="Nombre"
                               required />
                        <label asp-for="NewCategory.Name">Nombre</label>
                        <span asp-validation-for="NewCategory.Name"
                              class="text-danger small"></span>
                    </div>

                    <div class="form-floating">
                        <textarea asp-for="NewCategory.Description"
                                  class="form-control"
                                  placeholder="Descripción"
                                  rows="5"
                                  style="height: 100px;
                                    resize: none;"></textarea>
                        <label asp-for="NewCategory.Description">Descripción</label>
                        <span asp-validation-for="NewCategory.Description"
                              class="text-danger small"></span>
                    </div>

                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit"
                            class="btn btn-success">
                        <i class="bi bi-check-lg me-1" aria-hidden="true"></i>
                        Guardar
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<div class="modal fade"
    id="editCategoryModal"
    tabindex="-1"
    aria-labelledby="editCategoryModalLabel"
    aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">

            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate>

                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-semibold" id="editCategoryModalLabel">
                        <i class="bi bi-pencil-square me-2" aria-hidden="true"></i>
                        Editar Categoría
                    </h5>
                        <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Cerrar">
                        </button>
                </div>

                <div class="modal-body">
                    <input type="hidden" asp-for="EditCategory.Id" />

                    <div class="form-floating mb-3">
                        <input asp-for="EditCategory.Code"
                               class="form-control"
                               placeholder="Código"
                               required />
                        <label asp-for="EditCategory.Code">Código</label>
                        <span asp-validation-for="EditCategory.Code" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="EditCategory.Name"
                               class="form-control"
                               placeholder="Nombre"
                               required />
                        <label asp-for="EditCategory.Name">Nombre</label>
                        <span asp-validation-for="EditCategory.Name" class="text-danger small"></span>
                    </div>

                    <div class="form-floating">
                        <textarea asp-for="EditCategory.Description"
                                  class="form-control"
                                  placeholder="Descripción"
                                  rows="5"
                                  style="height: 100px; resize: none;"></textarea>
                        <label asp-for="EditCategory.Description">Descripción</label>
                    </div>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <a href="/Categories?page=@Model.CurrentPage" class="btn btn-outline-secondary">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1" aria-hidden="true"></i>
                        Actualizar
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (Model.ShowCreateCategoryModal)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var createModalElement = document.getElementById('addCategoryModal');
                if (!createModalElement || typeof bootstrap === 'undefined') {
                    return;
                }

                var createModal = new bootstrap.Modal(createModalElement);
                createModal.show();
            });
        </script>
    }

    @if (Model.ShowEditCategoryModal)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var editModalElement = document.getElementById('editCategoryModal');
                if (!editModalElement || typeof bootstrap === 'undefined') {
                    return;
                }

                var editModal = new bootstrap.Modal(editModalElement);
                editModalElement.addEventListener('hidden.bs.modal', function () {
                    var url = new URL(window.location.href);
                    if (url.searchParams.has('editId')) {
                        window.location.href = '/Categories?page=@Model.CurrentPage';
                    }
                }, { once: true });
                editModal.show();
            });
        </script>
    }
}
