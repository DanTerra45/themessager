@page "/Categories"
@model Mercadito.Pages.Categories.CategoriesModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Categorias";
    ViewData["UseToasts"] = true;
    var showIdColumn = bool.TryParse(Configuration["Ui:ShowIDs"], out var showIDs) && showIDs;
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Organizacion del catalogo</p>
    </section>
    <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
        <i class="bi bi-plus-circle"></i> Nueva Categoria
    </button>
</header>

<section>
    @if (Model.Categories.Count > 0)
    {
        <section class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="text-center">
                    <tr>
                        @if (showIdColumn)
                        {
                            <th class="sortable-header" title="Ordenar por ID">
                                <section class="d-flex align-items-center justify-content-center gap-1">
                                    ID <i class="bi bi-arrow-down-up" style="font-size: 0.8em;"></i>
                                </section>
                            </th>
                        }
                        <th class="sortable-header" title="Ordenar por Codigo">
                            <section class="d-flex align-items-center justify-content-center gap-1">
                                Codigo <i class="bi bi-arrow-down-up" style="font-size: 0.8em;"></i>
                            </section>
                        </th>
                        <th class="sortable-header" title="Ordenar por Nombre">
                            <section class="d-flex align-items-center justify-content-center gap-1">
                                Nombre <i class="bi bi-arrow-down-up" style="font-size: 0.8em;"></i>
                            </section>
                        </th>
                        <th>Descripcion</th>
                        <th class="sortable-header" title="Ordenar por Productos Asociados">
                            <section class="d-flex align-items-center justify-content-center gap-1">
                                Productos Asociados <i class="bi bi-arrow-down-up" style="font-size: 0.8em;"></i>
                            </section>
                        </th>
                        <th class="text-center" style="width: 170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model.Categories)
                    {
                        <tr>
                            @if (showIdColumn)
                            {
                                <td class="small text-muted" style="font-family: var(--font-mono);">
                                    @category.Id
                                </td>
                            }
                            <td class="text-center">
                                <mark class="badge bg-secondary" style="font-family: var(--font-mono); font-size: 0.9rem;">@category.Code</mark>
                            </td>
                            <td class="fw-bold" style="font-family: var(--font-display); font-size: 1.1rem;">@category.Name</td>
                            <td class="text-truncate truncate-description-category" style="max-width: 250px;">@category.Description</td>
                            <td class="text-center">
                                @{
                                    var productStatus = category.ProductCount == 0
                                        ? "danger"
                                        : category.ProductCount <= 5
                                            ? "warning"
                                            : "good";
                                }

                                <mark class="status-badge" data-status="@productStatus">@category.ProductCount</mark>

                                @if (category.ProductCount > 0)
                                {
                                    <form method="post" asp-page="/Products/Products" asp-page-handler="Filter" class="d-inline">
                                        <input type="hidden" name="categoryFilter" value="@category.Id" />
                                        <button type="submit"
                                                class="b-btn ms-2" style="background-color: white; color: #0d6efd; border-color: #0d6efd; box-shadow: 2px 2px 0 #0d6efd; padding: 0.1rem 0.4rem; font-size: 0.85rem; vertical-align: middle;"
                                                title="Ver productos de esta categora">
                                            <i class="bi bi-eye-fill" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                            <td class="text-center">
                                <menu class="d-flex justify-content-center gap-2 m-0 p-0" style="list-style: none;">
                                    <form method="post" asp-page-handler="StartEdit" class="d-inline">
                                        <input type="hidden" name="id" value="@category.Id" />
                                        <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                                        <button type="submit" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;"
                                                title="Editar"
                                                aria-label="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </form>
                                    
                                    <button class="b-btn b-btn-danger" style="padding: 0.25rem 0.5rem;"
                                            title="Eliminar"
                                            aria-label="Eliminar"
                                            type="button"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteCategoryModal"
                                            data-id="@category.Id"
                                            data-name="@category.Name"
                                            data-product-count="@category.ProductCount">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </menu>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>

        <!-- Paginacion -->
        <section class="d-flex justify-content-center mt-4">
            <nav aria-label="Paginacion de categorias">
                <ul class="pagination">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <form method="post" asp-page-handler="Navigate" class="d-inline">
                            <input type="hidden" name="pageNumber" value="@(Model.CurrentPage - 1)" />
                            <button type="submit" class="page-link" disabled="@(Model.CurrentPage == 1)">
                                <i class="bi bi-chevron-left me-1"></i>Anterior
                            </button>
                        </form>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <form method="post" asp-page-handler="Navigate" class="d-inline">
                                <input type="hidden" name="pageNumber" value="@i" />
                                <button type="submit" class="page-link">@i</button>
                            </form>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <form method="post" asp-page-handler="Navigate" class="d-inline">
                            <input type="hidden" name="pageNumber" value="@(Model.CurrentPage + 1)" />
                            <button type="submit" class="page-link" disabled="@(Model.CurrentPage == Model.TotalPages)">
                                Siguiente<i class="bi bi-chevron-right ms-1"></i>
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>
        </section>
    }
    else
    {
        <aside class="text-center text-muted py-5" style="font-family: var(--font-mono); border: 2px dashed var(--mrc-ink); border-radius: var(--radius-md);">
            No hay categorias registradas en el sistema.
        </aside>
    }
</section>

<!-- Modals -->
<section class="modal fade" id="deleteCategoryModal" tabindex="-1" aria-labelledby="deleteCategoryModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Delete" id="deleteCategoryForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" name="id" id="DeleteCategoryId" />

                <header class="modal-header" style="background-color: var(--mrc-danger); color: white;">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; color: white;" id="deleteCategoryModalLabel">
                        <i class="bi bi-exclamation-triangle me-2"></i> Confirmar eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">
                    <p class="mb-3" style="font-size: 1.1rem;">¿Está seguro de eliminar la categoría seleccionada?</p>
                    <p class="mb-0" style="font-family: var(--font-mono); padding: 1rem; background-color: var(--mrc-surface-alt); border: 2px solid var(--mrc-ink); border-radius: var(--radius-sm);">
                        Categoría: <strong id="deleteCategoryName" style="font-size: 1.2rem;">-</strong>
                    </p>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn b-btn-danger">
                        <i class="bi bi-trash me-1"></i> Eliminar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate id="createCategoryForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />

                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="addCategoryModalLabel">
                        <i class="bi bi-tags me-2"></i> Nueva Categoria
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">

                    <section class="mb-3">
                        <section class="form-floating">
                            <input asp-for="NewCategory.Code" class="form-control fw-bold" placeholder="Codigo" required />
                            <label asp-for="NewCategory.Code" class="fw-bold">Codigo</label>
                        </section>
                        <span asp-validation-for="NewCategory.Code" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <section class="mb-3">
                        <section class="form-floating">
                            <input asp-for="NewCategory.Name" class="form-control fw-bold" placeholder="Nombre" required />
                            <label asp-for="NewCategory.Name" class="fw-bold">Nombre</label>
                        </section>
                        <span asp-validation-for="NewCategory.Name" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <section class="mb-3">
                        <section class="form-floating">
                            <textarea asp-for="NewCategory.Description" class="form-control category-description-textarea" placeholder="Descripcion" rows="5"></textarea>
                            <label asp-for="NewCategory.Description" class="fw-bold">Descripcion</label>
                        </section>
                        <span asp-validation-for="NewCategory.Description" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                    </section>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">
                        <i class="bi bi-check-lg me-1"></i> Guardar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="editCategoryModal" tabindex="-1" aria-labelledby="editCategoryModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate id="updateCategoryForm">
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <input type="hidden" asp-for="EditCategory.Id" />

                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="editCategoryModalLabel">
                        <i class="bi bi-pencil-square me-2"></i> Editar Categoria
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">

                    <section class="mb-3">
                        <section class="form-floating">
                            <input asp-for="EditCategory.Code" class="form-control fw-bold" placeholder="Codigo" required />
                            <label asp-for="EditCategory.Code" class="fw-bold">Codigo</label>
                        </section>
                        <span asp-validation-for="EditCategory.Code" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <section class="mb-3">
                        <section class="form-floating">
                            <input asp-for="EditCategory.Name" class="form-control fw-bold" placeholder="Nombre" required />
                            <label asp-for="EditCategory.Name" class="fw-bold">Nombre</label>
                        </section>
                        <span asp-validation-for="EditCategory.Name" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <section class="mb-3">
                        <section class="form-floating">
                            <textarea asp-for="EditCategory.Description" class="form-control category-description-textarea" placeholder="Descripcion" rows="5"></textarea>
                            <label asp-for="EditCategory.Description" class="fw-bold">Descripcion</label>
                        </section>
                        <span asp-validation-for="EditCategory.Description" class="text-danger d-block mt-1" style="font-size: 0.85em; font-family: var(--font-mono); font-weight: bold;"></span>
                    </section>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">
                        <i class="bi bi-check-lg me-1"></i> Actualizar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<!-- Brutalist Toasts -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1060;">
    @if (TempData["SuccessMessage"] is string successMsg && !string.IsNullOrWhiteSpace(successMsg))
    {
        <div class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4000" style="background-color: white; border: 4px solid var(--mrc-ink) !important; border-radius: 0; box-shadow: 4px 4px 0 var(--mrc-ink); opacity: 1;">
            <div class="d-flex position-relative">
                <div class="toast-icon d-flex align-items-center justify-content-center" style="background-color: var(--mrc-success); width: 60px; border-right: 4px solid var(--mrc-ink);">
                    <i class="bi bi-check-circle" style="font-size: 1.5rem; color: var(--mrc-ink);"></i>
                </div>
                <div class="toast-body d-flex align-items-center" style="font-family: var(--font-mono); font-weight: bold; flex-grow: 1; min-height: 60px;">
                    @successMsg
                </div>
                <button type="button" class="btn-close me-2 m-auto position-absolute top-0 end-0 mt-2" data-bs-dismiss="toast" aria-label="Cerrar" style="background-size: 0.8em;"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMsg && !string.IsNullOrWhiteSpace(errorMsg))
    {
        <div class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="6000" style="background-color: white; border: 4px solid var(--mrc-ink) !important; border-radius: 0; box-shadow: 4px 4px 0 var(--mrc-ink); opacity: 1;">
            <div class="d-flex position-relative">
                <div class="toast-icon d-flex align-items-center justify-content-center" style="background-color: var(--mrc-danger); width: 60px; border-right: 4px solid var(--mrc-ink);">
                    <i class="bi bi-x-circle" style="font-size: 1.5rem; color: white;"></i>
                </div>
                <div class="toast-body d-flex align-items-center" style="font-family: var(--font-mono); font-weight: bold; flex-grow: 1; min-height: 60px;">
                    @errorMsg
                </div>
                <button type="button" class="btn-close me-2 m-auto position-absolute top-0 end-0 mt-2" data-bs-dismiss="toast" aria-label="Cerrar" style="background-size: 0.8em;"></button>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Auto-initialize toasts
            const toastElList = document.querySelectorAll('.toast');
            const toastList = [...toastElList].map(toastEl => new bootstrap.Toast(toastEl));
            toastList.forEach(toast => toast.show());
            
            if (typeof bootstrap === 'undefined') {
                return;
            }

            var deleteCategoryModal = document.getElementById('deleteCategoryModal');
            if (deleteCategoryModal) {
                deleteCategoryModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    if (!button) {
                        return;
                    }

                    var categoryId = button.getAttribute('data-id') || '';
                    var categoryName = button.getAttribute('data-name') || '-';

                    var deleteIdInput = document.getElementById('DeleteCategoryId');
                    var deleteNameLabel = document.getElementById('deleteCategoryName');

                    if (deleteIdInput) {
                        deleteIdInput.value = categoryId;
                    }
                    if (deleteNameLabel) {
                        deleteNameLabel.textContent = categoryName;
                    }
                });
            }

            @if (Model.ShowCreateCategoryModal)
            {
                <text>
                var createModal = new bootstrap.Modal(document.getElementById('addCategoryModal'));
                createModal.show();
                </text>
            }

            @if (Model.ShowEditCategoryModal)
            {
                <text>
                var editModalElement = document.getElementById('editCategoryModal');
                var editModal = new bootstrap.Modal(editModalElement);
                editModal.show();
                </text>
            }

        });
    </script>
}
