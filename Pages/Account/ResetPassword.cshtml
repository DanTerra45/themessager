@page "/Account/ResetPassword"
@model Mercadito.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Nueva contraseña";
}

<section class="mx-auto" style="max-width: 520px;">
    <header class="dash-header mb-4">
        <section>
            <h1>NUEVA CONTRASEÑA</h1>
            <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Restablecimiento de acceso</p>
        </section>
    </header>

    <section class="b-card p-4">
        @if (Model.IsTokenValid)
        {
            <form method="post">
                <input type="hidden" asp-for="Token" />

                <section class="mb-3">
                    <label class="form-label fw-bold">Usuario</label>
                    <input class="form-control readonly-display-input" value="@Model.Username" readonly />
                </section>

                <section class="mb-3">
                    <label asp-for="Password" class="form-label fw-bold">
                        Nueva contraseña
                        <span asp-validation-for="Password" class="validation-icon-inline"></span>
                    </label>
                    <input asp-for="Password" type="password" class="form-control" autocomplete="new-password" />
                    <small class="text-muted d-block mt-1">Debe tener entre 8 y 128 caracteres, con mayúscula, minúscula y número.</small>
                </section>

                <section class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label fw-bold">
                        Confirmar contraseña
                        <span asp-validation-for="ConfirmPassword" class="validation-icon-inline"></span>
                    </label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                </section>

                <footer class="d-flex justify-content-end gap-2">
                    <a href="/Login" class="b-btn b-btn-secondary">Cancelar</a>
                    <button type="submit" class="b-btn">Actualizar contraseña</button>
                </footer>
            </form>
        }
        else
        {
            <section class="d-flex justify-content-end">
                <a href="/ForgotPassword" class="b-btn">Solicitar nuevo enlace</a>
            </section>
        }
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
