@page "/Account/ForgotPassword"
@model Mercadito.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Restablecer contraseña";
}

<section class="mx-auto" style="max-width: 520px;">
    <header class="dash-header mb-4">
        <section>
            <h1>RESTABLECER CONTRASEÑA</h1>
            <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Solicitud de acceso por correo</p>
        </section>
    </header>

    <section class="b-card p-4">
        <form method="post">
            <section class="mb-3">
                <label asp-for="Identifier" class="form-label fw-bold">Usuario o correo</label>
                <input asp-for="Identifier" class="form-control" autocomplete="username email" />
                <small class="text-muted d-block mt-1">Se enviará un enlace de restablecimiento si la cuenta existe y tiene correo asociado.</small>
                <span asp-validation-for="Identifier" class="text-danger small"></span>
            </section>

            <footer class="d-flex justify-content-end gap-2">
                <a href="/Login" class="b-btn b-btn-secondary">Volver</a>
                <button type="submit" class="b-btn">Enviar enlace</button>
            </footer>
        </form>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
