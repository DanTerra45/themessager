@page "/Sales/Cancellation"
@model Mercadito.Pages.Sales.CancellationModel
@{
    ViewData["Title"] = "Anulación de ventas";
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Control visual de solicitudes de anulación</p>
    </section>
    <a asp-page="/Sales/Sales" class="b-btn b-btn-secondary text-decoration-none">
        <i class="bi bi-arrow-left"></i> Volver a Ventas
    </a>
</header>

<section class="row g-3 mb-4">
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Solicitudes hoy</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.RequestCountToday</p>
            <small class="text-muted">Dato referencial - no persistente</small>
        </article>
    </section>
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Pendientes</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.PendingCount</p>
            <small class="text-muted">Dato referencial - no persistente</small>
        </article>
    </section>
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Monto observado</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.AmountUnderReview.ToString("N2") Bs.</p>
            <small class="text-muted">Dato referencial - no persistente</small>
        </article>
    </section>
</section>

<section class="b-card p-0 overflow-hidden">
    <header class="d-flex justify-content-between align-items-center p-3" style="border-bottom: 2px solid var(--mrc-ink); background-color: var(--mrc-surface-alt);">
        <strong style="font-family: var(--font-display); text-transform: uppercase;">Solicitudes recientes</strong>
        <mark class="status-badge" data-status="warning">Solo visual</mark>
    </header>
    <section class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="text-center">
                <tr>
                    <th>Venta</th>
                    <th>Motivo</th>
                    <th>Solicitante</th>
                    <th>Fecha/Hora</th>
                    <th class="text-end">Monto</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.CancellationRequests)
                {
                    <tr>
                        <td class="fw-bold" style="font-family: var(--font-mono);">@item.SaleCode</td>
                        <td>@item.Reason</td>
                        <td>@item.RequestedBy</td>
                        <td style="font-family: var(--font-mono);">@item.RequestedAt</td>
                        <td class="text-end fw-bold" style="font-family: var(--font-mono);">@item.Amount.ToString("N2") Bs.</td>
                        <td class="text-center">
                            <mark class="status-badge" data-status="warning">@item.Status</mark>
                        </td>
                        <td class="text-center">
                            <button type="button" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;" disabled title="Revisar solicitud">
                                <i class="bi bi-search"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</section>
