@model Mercadito.Pages.Sales.CancellationModel

<form id="cancelSaleForm" method="post" asp-page-handler="Cancel" novalidate autocomplete="off">
    <input type="hidden" name="sortBy" value="@Model.SortBy" />
    <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
    <section class="modal fade"
             id="cancelSaleModal"
             tabindex="-1"
             aria-labelledby="cancelSaleModalLabel"
             aria-hidden="true"
             data-preserve-reason="@(Model.ShowCancelModal.ToString().ToLowerInvariant())">
        <section class="modal-dialog modal-dialog-centered">
            <article class="modal-content">
                <header class="modal-header">
                    <h5 class="modal-title" id="cancelSaleModalLabel" style="font-family: var(--font-display); font-weight: 800;">
                        <i class="bi bi-x-circle me-2"></i>Anular Venta
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>
                <section class="modal-body p-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <input asp-for="CancelRequest.SaleId" type="hidden" />

                    <section class="mb-3">
                        <label class="form-label fw-bold" for="cancelSaleCode">Venta</label>
                        <input id="cancelSaleCode" class="form-control" value="@Model.CancelTargetCode" readonly />
                    </section>

                    <section class="mb-0">
                        <label asp-for="CancelRequest.Reason" class="form-label fw-bold">
                            Motivo de anulación
                            <span asp-validation-for="CancelRequest.Reason" class="validation-icon-inline"></span>
                        </label>
                        <textarea asp-for="CancelRequest.Reason" class="form-control" rows="4" data-normalize="collapse" placeholder="Describe el motivo de la anulación"></textarea>
                    </section>
                </section>
                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="b-btn b-btn-danger">
                        Confirmar Anulación
                    </button>
                </footer>
            </article>
        </section>
    </section>
</form>
