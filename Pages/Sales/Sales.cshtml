@page "/Sales"
@model Mercadito.Pages.Sales.SalesModel
@{
    ViewData["Title"] = "Ventas";
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Registro operativo de ventas y comprobantes</p>
    </section>
    <div class="d-flex gap-2">
        <a asp-page="/Sales/Sales"
           asp-route-sortBy="@Model.SortBy"
           asp-route-sortDirection="@Model.SortDirection"
           class="b-btn b-btn-secondary listing-icon-btn dash-header-icon-btn text-decoration-none"
           title="Refrescar ventas"
           aria-label="Refrescar ventas">
            <i class="bi bi-arrow-clockwise"></i>
        </a>
        <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#newSaleModal">
            <i class="bi bi-receipt-cutoff"></i> Nueva Venta
        </button>
    </div>
</header>

<section class="row g-3 mb-4">
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Ventas registradas hoy</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.SalesTodayCount</p>
            <small class="text-muted">Operaciones activas del día actual</small>
        </article>
    </section>
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Ingresos de hoy</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.SalesTodayTotal.ToString("N2") Bs.</p>
            <small class="text-muted">Suma de ventas con estado registrada</small>
        </article>
    </section>
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Ticket promedio</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.AverageTicketToday.ToString("N2") Bs.</p>
            <small class="text-muted">Promedio del total por venta registrada hoy</small>
        </article>
    </section>
</section>

<section class="b-card p-0 overflow-hidden sales-history-card">
    <header class="p-3 sales-history-header">
        <strong style="font-family: var(--font-display); text-transform: uppercase;">Últimas ventas</strong>
    </header>
    <section class="table-responsive sales-history-table-wrap">
        <table class="table table-hover align-middle mb-0 products-table sales-history-table">
            <thead class="text-center">
                <tr>
                    <th class="sortable-header text-center fw-bold" title="Ordenar por Código">
                        <a asp-page="/Sales/Sales"
                           asp-route-sortBy="code"
                           asp-route-sortDirection="@Model.GetNextSortDirection("code")"
                           class="sort-button text-decoration-none">
                            Código <i class="bi @Model.GetSortIcon("code")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="sortable-header text-center fw-bold" title="Ordenar por Fecha/Hora">
                        <a asp-page="/Sales/Sales"
                           asp-route-sortBy="createdat"
                           asp-route-sortDirection="@Model.GetNextSortDirection("createdat")"
                           class="sort-button text-decoration-none">
                            Fecha/Hora <i class="bi @Model.GetSortIcon("createdat")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="sortable-header text-center fw-bold" title="Ordenar por Cliente">
                        <a asp-page="/Sales/Sales"
                           asp-route-sortBy="customer"
                           asp-route-sortDirection="@Model.GetNextSortDirection("customer")"
                           class="sort-button text-decoration-none">
                            Cliente <i class="bi @Model.GetSortIcon("customer")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="sortable-header text-center fw-bold" title="Ordenar por Canal">
                        <a asp-page="/Sales/Sales"
                           asp-route-sortBy="channel"
                           asp-route-sortDirection="@Model.GetNextSortDirection("channel")"
                           class="sort-button text-decoration-none">
                            Canal <i class="bi @Model.GetSortIcon("channel")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="sortable-header text-center fw-bold" title="Ordenar por Método">
                        <a asp-page="/Sales/Sales"
                           asp-route-sortBy="paymentmethod"
                           asp-route-sortDirection="@Model.GetNextSortDirection("paymentmethod")"
                           class="sort-button text-decoration-none">
                            Método <i class="bi @Model.GetSortIcon("paymentmethod")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="sortable-header text-end fw-bold" title="Ordenar por Total">
                        <a asp-page="/Sales/Sales"
                           asp-route-sortBy="total"
                           asp-route-sortDirection="@Model.GetNextSortDirection("total")"
                           class="sort-button text-decoration-none">
                            Total <i class="bi @Model.GetSortIcon("total")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="sortable-header text-center fw-bold" title="Ordenar por Estado">
                        <a asp-page="/Sales/Sales"
                           asp-route-sortBy="status"
                           asp-route-sortDirection="@Model.GetNextSortDirection("status")"
                           class="sort-button text-decoration-none">
                            Estado <i class="bi @Model.GetSortIcon("status")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="text-center products-actions-col">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.RecentSales.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">No existen ventas registradas todavía.</td>
                    </tr>
                }
                else
                {
                    @foreach (var sale in Model.RecentSales)
                    {
                        <tr>
                            <td class="fw-bold" style="font-family: var(--font-mono);">@sale.Code</td>
                            <td style="font-family: var(--font-mono);">@sale.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@sale.CustomerName</td>
                            <td>@sale.Channel</td>
                            <td>@sale.PaymentMethod</td>
                            <td class="text-end fw-bold" style="font-family: var(--font-mono);">@sale.Total.ToString("N2") Bs.</td>
                            <td class="text-center">
                                @if (string.Equals(sale.Status, "Anulada", StringComparison.Ordinal))
                                {
                                    <mark class="status-badge" data-status="danger">@sale.Status</mark>
                                }
                                else
                                {
                                    <mark class="status-badge" data-status="success">@sale.Status</mark>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-inline-flex gap-2">
                                    <a asp-page="/Sales/Sales"
                                       asp-route-detailSaleId="@sale.Id"
                                       asp-route-sortBy="@Model.SortBy"
                                       asp-route-sortDirection="@Model.SortDirection"
                                       class="b-btn b-btn-secondary"
                                       style="padding: 0.25rem 0.5rem;"
                                       title="Ver detalle">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-page="/Sales/Receipt"
                                       asp-route-saleId="@sale.Id"
                                       target="_blank"
                                       rel="noopener noreferrer"
                                       class="b-btn b-btn-secondary"
                                       style="padding: 0.25rem 0.5rem;"
                                       title="Ver comprobante">
                                        <i class="bi bi-file-earmark-text"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </section>
</section>

<section id="salesPageConfig"
         data-show-create-modal="@(Model.ShowCreateModal.ToString().ToLowerInvariant())"
         data-show-detail-modal="@(Model.ShowDetailModal.ToString().ToLowerInvariant())"
         data-show-new-customer-modal="@(Model.ShowNewCustomerPanel.ToString().ToLowerInvariant())"
         data-auto-open-receipt-url="@Model.AutoOpenReceiptUrl"
         data-customer-search-url="@Url.Page("/Sales/Sales", "SearchCustomers")"
         data-product-search-url="@Url.Page("/Sales/Sales", "SearchProducts")">
</section>

<partial name="_CreateSaleModal" model="Model" />

@if (Model.SelectedSaleDetail != null)
{
    <partial name="_SaleDetailModal" model="Model.SelectedSaleDetail" />
}

@section Scripts {
    <script src="~/js/pages/sales-page.shared.js" asp-append-version="true"></script>
    <script src="~/js/pages/sales-page.create.customer.js" asp-append-version="true"></script>
    <script src="~/js/pages/sales-page.create.draft.js" asp-append-version="true"></script>
    <script src="~/js/pages/sales-page.create.js" asp-append-version="true"></script>
    <script src="~/js/pages/sales-page.js" asp-append-version="true"></script>
}
