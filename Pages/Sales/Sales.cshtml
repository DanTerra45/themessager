@page "/Sales"
@model Mercadito.Pages.Sales.SalesModel
@{
    ViewData["Title"] = "Ventas";
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Panel para seguimiento comercial rápido</p>
    </section>
    <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#nuevaVentaModal">
        <i class="bi bi-receipt-cutoff"></i> Nueva Venta
    </button>
</header>

<section class="row g-3 mb-4">
    <section class="col-md-6">
        <article class="b-card h-100 p-3 d-flex align-items-center justify-content-between">
            <section>
                <strong class="d-block" style="font-family: var(--font-display);">Anulación de ventas</strong>
                <small class="text-muted">Seguimiento de solicitudes y estado actual</small>
            </section>
            <a asp-page="/Sales/Cancellation" class="b-btn b-btn-secondary text-decoration-none">
                <i class="bi bi-arrow-right"></i> Abrir
            </a>
        </article>
    </section>
    <section class="col-md-6">
        <article class="b-card h-100 p-3 d-flex align-items-center justify-content-between">
            <section>
                <strong class="d-block" style="font-family: var(--font-display);">Reportes de ventas</strong>
                <small class="text-muted">Resumen y exportación de información comercial</small>
            </section>
            <a asp-page="/Sales/Reports" class="b-btn b-btn-secondary text-decoration-none">
                <i class="bi bi-arrow-right"></i> Abrir
            </a>
        </article>
    </section>
</section>

<section class="row g-3 mb-4">
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Ventas de hoy</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.VentasHoy.ToString("N2") Bs.</p>
            <small class="text-muted">Dato referencial - no persistente</small>
        </article>
    </section>
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Ticket promedio</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.TicketPromedio.ToString("N2") Bs.</p>
            <small class="text-muted">Dato referencial - no persistente</small>
        </article>
    </section>
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Transacciones</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.VentasRegistradasHoy</p>
            <small class="text-muted">Dato referencial - no persistente</small>
        </article>
    </section>
</section>

<section class="b-card p-0 overflow-hidden">
    <header class="d-flex justify-content-between align-items-center p-3" style="border-bottom: 2px solid var(--mrc-ink); background-color: var(--mrc-surface-alt);">
        <strong style="font-family: var(--font-display); text-transform: uppercase;">Últimas ventas</strong>
        <mark class="status-badge" data-status="warning">Solo visual</mark>
    </header>
    <section class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="text-center">
                <tr>
                    <th>Código</th>
                    <th>Fecha/Hora</th>
                    <th>Canal</th>
                    <th>Método</th>
                    <th class="text-end">Total</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var venta in Model.VentasRecientes)
                {
                    <tr>
                        <td class="fw-bold" style="font-family: var(--font-mono);">@venta.Codigo</td>
                        <td style="font-family: var(--font-mono);">@venta.FechaHora</td>
                        <td>@venta.Canal</td>
                        <td>@venta.MetodoPago</td>
                        <td class="text-end fw-bold" style="font-family: var(--font-mono);">@venta.Total.ToString("N2") Bs.</td>
                        <td class="text-center">
                            <button type="button" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;" disabled title="Ver detalle">
                                <i class="bi bi-eye"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</section>

<section class="modal fade" id="nuevaVentaModal" tabindex="-1" aria-labelledby="nuevaVentaModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <header class="modal-header">
                <h5 class="modal-title" id="nuevaVentaModalLabel" style="font-family: var(--font-display); font-weight: 800;">
                    <i class="bi bi-receipt me-2"></i> Nueva Venta
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </header>
            <section class="modal-body p-4">
                <p class="mb-3">Esta pantalla es un prototipo visual.</p>
                <section class="mb-3">
                    <label class="form-label fw-bold">Cliente</label>
                    <input class="form-control" value="Consumidor final" readonly />
                </section>
                <section class="mb-3">
                    <label class="form-label fw-bold">Método de pago</label>
                    <input class="form-control" value="Efectivo / QR / Tarjeta" readonly />
                </section>
                <section class="mb-0">
                    <label class="form-label fw-bold">Productos</label>
                    <textarea class="form-control" rows="3" readonly>Integración pendiente para fase 2</textarea>
                </section>
            </section>
            <footer class="modal-footer">
                <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="b-btn" disabled>Guardar</button>
            </footer>
        </article>
    </section>
</section>
