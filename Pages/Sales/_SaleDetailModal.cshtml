@model Mercadito.src.sales.application.models.SaleDetailDto

<section class="modal fade" id="saleDetailModal" tabindex="-1" aria-labelledby="saleDetailModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <article class="modal-content">
            <header class="modal-header">
                <h5 class="modal-title" id="saleDetailModalLabel" style="font-family: var(--font-display); font-weight: 800;">
                    <i class="bi bi-eye me-2"></i>Detalle de Venta
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </header>
            <section class="modal-body p-4">
                <section class="row g-3 mb-4">
                    <section class="col-md-4">
                        <strong class="d-block" style="font-family: var(--font-mono);">Código</strong>
                        <span>@Model.Code</span>
                    </section>
                    <section class="col-md-4">
                        <strong class="d-block" style="font-family: var(--font-mono);">Cliente</strong>
                        <span>@Model.CustomerDocumentNumber - @Model.CustomerName</span>
                    </section>
                    <section class="col-md-4">
                        <strong class="d-block" style="font-family: var(--font-mono);">Estado</strong>
                        @if (string.Equals(Model.Status, "Anulada", StringComparison.Ordinal))
                        {
                            <mark class="status-badge" data-status="danger">@Model.Status</mark>
                        }
                        else
                        {
                            <mark class="status-badge" data-status="success">@Model.Status</mark>
                        }
                    </section>
                    <section class="col-md-4">
                        <strong class="d-block" style="font-family: var(--font-mono);">Canal</strong>
                        <span>@Model.Channel</span>
                    </section>
                    <section class="col-md-4">
                        <strong class="d-block" style="font-family: var(--font-mono);">Método de pago</strong>
                        <span>@Model.PaymentMethod</span>
                    </section>
                    <section class="col-md-4">
                        <strong class="d-block" style="font-family: var(--font-mono);">Registrado por</strong>
                        <span>@Model.CreatedByUsername</span>
                    </section>
                </section>

                @if (!string.IsNullOrWhiteSpace(Model.CancellationReason))
                {
                    <section class="b-card p-3 mb-4" style="background-color: var(--mrc-surface-alt);">
                        <strong class="d-block mb-2" style="font-family: var(--font-mono);">Motivo de anulación</strong>
                        <p class="mb-0">@Model.CancellationReason</p>
                    </section>
                }

                <section class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="text-center">
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio Unitario</th>
                                <th class="text-end">Importe</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model.Lines)
                            {
                                <tr>
                                    <td>@line.ProductName</td>
                                    <td class="text-center" style="font-family: var(--font-mono);">@line.Quantity</td>
                                    <td class="text-end" style="font-family: var(--font-mono);">@line.UnitPrice.ToString("N2") Bs.</td>
                                    <td class="text-end fw-bold" style="font-family: var(--font-mono);">@line.Amount.ToString("N2") Bs.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </section>
            </section>
            <footer class="modal-footer d-flex justify-content-between">
                <span class="fw-bold" style="font-family: var(--font-display);">Total: @Model.Total.ToString("N2") Bs.</span>
                <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </footer>
        </article>
    </section>
</section>
