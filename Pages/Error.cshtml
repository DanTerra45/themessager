@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<section class="app-error-wrap">
    <article class="app-error-panel p-4 p-md-5">

        <section class="d-flex align-items-start">
            <p class="text-danger me-3 fs-2 mb-0">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </p>

            <section class="w-100">
                <h1 class="h3 mb-2" style="font-family: var(--font-display); font-weight: 800; color: var(--mrc-danger); text-transform: uppercase;">
                    Se produjo un error
                </h1>
                <p class="mb-3" style="font-size: 1.1rem;">@Model.UserMessage</p>

                @if (Model.ShowRequestId)
                {
                    <p class="small mb-3" style="font-family: var(--font-mono); background-color: var(--mrc-surface-alt); padding: 0.5rem; border-radius: var(--radius-sm); border: 1px dashed var(--mrc-border);">
                        <strong>Request ID:</strong> @Model.RequestId
                    </p>
                }
            </section>
        </section>

        <hr class="my-4" style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" />
        <p class="text-muted mb-0 small" style="font-family: var(--font-mono);">Si el problema persiste, revise los logs técnicos para más detalle.</p>

    </article>
</section>
