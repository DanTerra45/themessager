@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<section class="app-error-wrap">
    <article class="app-error-panel p-4 p-md-5">
        <section class="d-flex align-items-start">
            <p class="text-danger me-3 fs-2 mb-0">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </p>
            <section class="w-100">
                <h1 class="h3 mb-2" style="font-family: var(--font-display); font-weight: 800; color: var(--mrc-danger); text-transform: uppercase;">
                    Se produjo un error
                </h1>
                <p class="mb-3" style="font-size: 1.1rem;">Ocurrio un error inesperado. Vuelve a intentarlo despues.</p>

                @if (Model.ShowRequestId)
                {
                    <p>
                        <strong>Request ID:</strong> <code>@Model.RequestId</code>
                    </p>
                }
            </section>
        </section>
        <hr class="my-4" />
        <p class= "text-muted mb-0 small">Si el problema persiste, revise los logs tecnicos para mas detalles</p>
    </article>
</section>

