@page "/ChangePassword"
@model Mercadito.Frontend.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Cambiar contraseña";
}

<section class="mx-auto" style="max-width: 520px;">
    <header class="dash-header mb-4">
        <section>
            <h1>CAMBIAR CONTRASEÑA</h1>
            <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Actualización obligatoria de acceso</p>
        </section>
    </header>

    <section class="b-card b-card-static p-4">
        <form method="post" class="needs-validation" novalidate>
            <section class="mb-3">
                <label class="form-label fw-bold">Usuario</label>
                <input class="form-control readonly-display-input" value="@Model.Username" readonly />
                <small class="text-muted d-block mt-1">Debes definir una nueva contraseña antes de continuar.</small>
            </section>

            <section class="mb-3">
                <label asp-for="PasswordChange.Password" class="form-label fw-bold">
                    Nueva contraseña
                    <span asp-validation-for="PasswordChange.Password" class="validation-icon-inline"></span>
                </label>
                <input asp-for="PasswordChange.Password" type="password" class="form-control" autocomplete="new-password" />
                <small class="text-muted d-block mt-1">Debe tener entre 8 y 128 caracteres, con mayúscula, minúscula y número.</small>
            </section>

            <section class="mb-3">
                <label asp-for="PasswordChange.ConfirmPassword" class="form-label fw-bold">
                    Confirmar contraseña
                    <span asp-validation-for="PasswordChange.ConfirmPassword" class="validation-icon-inline"></span>
                </label>
                <input asp-for="PasswordChange.ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
            </section>

            <footer class="d-flex justify-content-end gap-2">
                <button type="submit" class="b-btn">Actualizar contraseña</button>
            </footer>
        </form>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
