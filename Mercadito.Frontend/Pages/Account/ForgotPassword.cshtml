@page "/ForgotPassword"
@model Mercadito.Frontend.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Restablecer contraseña";
}

<section class="mx-auto" style="max-width: 520px;">
    <header class="dash-header mb-4">
        <section>
            <h1>RESTABLECER CONTRASEÑA</h1>
            <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Solicitud de acceso por correo</p>
        </section>
    </header>

    <section class="b-card b-card-static p-4">
        <form method="post" class="needs-validation" novalidate>
            <section class="mb-3">
                <label asp-for="PasswordReset.Identifier" class="form-label fw-bold">
                    Usuario o correo
                    <span asp-validation-for="PasswordReset.Identifier" class="validation-icon-inline"></span>
                </label>
                <input asp-for="PasswordReset.Identifier" class="form-control" autocomplete="username email" data-normalize="trim-lower" />
                <small class="text-muted d-block mt-1">Se enviará un enlace de restablecimiento si la cuenta existe y tiene correo asociado.</small>
            </section>

            <footer class="d-flex justify-content-end gap-2">
                <a href="/Login" class="b-btn b-btn-secondary">Volver</a>
                <button type="submit" class="b-btn">Enviar enlace</button>
            </footer>
        </form>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
