@page "/Employees"
@model Mercadito.Frontend.Pages.Employees.EmployeesModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Empleados";
    ViewData["UseToasts"] = true;
    var showIdColumn = bool.TryParse(Configuration["Ui:ShowIDs"], out var showIDs) && showIDs;
    var firstPageEmployeeId = 0L;
    var lastPageEmployeeId = 0L;
    if (Model.Employees.Count > 0)
    {
        firstPageEmployeeId = Model.Employees[0].Id;
        lastPageEmployeeId = Model.Employees[Model.Employees.Count - 1].Id;
    }

    var disablePreviousPage = !Model.HasPreviousPage || Model.CurrentPage <= 1;
    var previousPageCss = string.Empty;
    if (disablePreviousPage)
    {
        previousPageCss = "disabled";
    }

    var nextPageCss = string.Empty;
    if (!Model.HasNextPage)
    {
        nextPageCss = "disabled";
    }

    var newEmployeeCiValue = string.Empty;
    if (Model.NewEmployee != null && Model.NewEmployee.Ci.HasValue && Model.NewEmployee.Ci.Value != 0)
    {
        newEmployeeCiValue = Model.NewEmployee.Ci.Value.ToString();
    }

    var editEmployeeCiValue = string.Empty;
    if (Model.EditEmployee != null && Model.EditEmployee.Ci.HasValue && Model.EditEmployee.Ci.Value != 0)
    {
        editEmployeeCiValue = Model.EditEmployee.Ci.Value.ToString();
    }
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Administración de personal</p>
    </section>
    <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#addEmployeeModal">
        <i class="bi bi-person-plus-fill"></i> Registrar Empleado
    </button>
</header>

<section>
    <section class="mb-4 listing-filter-wrap">
        <form method="post" asp-page-handler="Filter" class="listing-filter-form">
            <input type="hidden" name="sortBy" value="@Model.SortBy" />
            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
            <section class="listing-search-field">
                <label for="employeesSearchTerm" class="visually-hidden">Buscar empleado</label>
                <input type="search"
                       id="employeesSearchTerm"
                       name="searchTerm"
                       class="form-control listing-search-input"
                       value="@Model.SearchTerm"
                       placeholder="Buscar empleado..."
                       autocomplete="off" />
            </section>
            <section class="listing-filter-actions">
                <button type="submit" class="b-btn b-btn-secondary listing-icon-btn" title="Buscar empleados" aria-label="Buscar empleados">
                    <i class="bi bi-search"></i>
                </button>
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                    <button type="submit" name="clear" value="true" class="b-btn b-btn-secondary listing-icon-btn" title="Limpiar búsqueda" aria-label="Limpiar búsqueda">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </button>
                }
            </section>
        </form>
    </section>

    @if (Model.Employees.Count > 0)
    {
        <section class="table-responsive table-shadow-safe-wrap">
            <table class="table table-hover align-middle">
                <thead class="text-center">
                    <tr>
                        @if (showIdColumn)
                        {
                            <th class="sortable-header" title="Ordenar por ID">
                                <form method="post" asp-page-handler="Sort" class="d-inline">
                                    <input type="hidden" name="sortBy" value="id" />
                                    <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                    <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                    <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                    <button type="submit" class="sort-button">
                                        ID <i class="bi @Model.GetSortIcon("id")" style="font-size: 0.8em;"></i>
                                    </button>
                                </form>
                            </th>
                        }
                        <th class="sortable-header" title="Ordenar por CI">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="ci" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                <button type="submit" class="sort-button">
                                    CI <i class="bi @Model.GetSortIcon("ci")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="sortable-header" title="Ordenar por Apellidos">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="apellidos" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                <button type="submit" class="sort-button">
                                    Apellidos <i class="bi @Model.GetSortIcon("apellidos")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="sortable-header" title="Ordenar por Nombre">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="nombres" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                <button type="submit" class="sort-button">
                                    Nombre <i class="bi @Model.GetSortIcon("nombres")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th>Teléfono</th>
                        <th class="sortable-header" title="Ordenar por Cargo">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="cargo" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                <button type="submit" class="sort-button">
                                    Cargo <i class="bi @Model.GetSortIcon("cargo")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="text-center" style="width: 170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model.Employees)
                    {
                        <tr>
                            @if (showIdColumn)
                            {
                                <td class="small text-muted text-center" style="font-family: var(--font-mono);">@emp.Id</td>
                            }
                            <td class="text-center" style="font-family: var(--font-mono);">
                                @{
                                    var ciPart = string.Empty;
                                    if (emp.Ci != 0)
                                    {
                                        ciPart = emp.Ci.ToString();
                                    }
                                    var employeeCiDisplay = ciPart;
                                    if (!string.IsNullOrWhiteSpace(emp.Complemento) && !string.IsNullOrEmpty(ciPart))
                                    {
                                        employeeCiDisplay += "-" + emp.Complemento;
                                    }
                                }
                                <span class="table-ellipsis table-ellipsis-employee-ci" title="@employeeCiDisplay">@employeeCiDisplay</span>
                            </td>
                            <td class="text-center" style="font-family: var(--font-display); font-size: 1.1rem;">
                                @{
                                    var employeeLastNamesDisplay = (emp.PrimerApellido + " " + emp.SegundoApellido).Trim();
                                }
                                <span class="table-ellipsis table-ellipsis-employee-surnames" title="@employeeLastNamesDisplay">@employeeLastNamesDisplay</span>
                            </td>
                            <td class="text-center" style="font-family: var(--font-display); font-size: 1.1rem;">
                                <span class="table-ellipsis table-ellipsis-employee-name" title="@emp.Nombres">@emp.Nombres</span>
                            </td>
                            <td class="text-center" style="font-family: var(--font-mono);">
                                <span class="table-ellipsis table-ellipsis-employee-contact" title="@emp.NumeroContacto">@emp.NumeroContacto</span>
                            </td>
                            <td class="text-center">
                                <mark class="status-badge" data-status="good">@emp.Cargo</mark>
                            </td>
                            <td class="text-center">
                                <menu class="d-flex justify-content-center gap-2 m-0 p-0" style="list-style: none;">
                                    <form method="post" asp-page-handler="StartEdit" class="d-inline">
                                        <input type="hidden" name="id" value="@emp.Id" />
                                        <input type="hidden" name="sortBy" value="@Model.SortBy" />
                                        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                                        <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                        <input type="hidden" name="CurrentPage" value="@Model.CurrentPage" />
                                        <input type="hidden" name="CurrentAnchorEmployeeId" value="@Model.CurrentAnchorEmployeeId" />
                                        <button type="submit" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;"
                                                title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </form>
                                    <button class="b-btn b-btn-danger" style="padding: 0.25rem 0.5rem;"
                                            title="Eliminar"
                                            aria-label="Eliminar"
                                            type="button"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteEmployeeModal"
                                            data-id="@emp.Id"
                                            data-name="@($"{emp.PrimerApellido} {emp.SegundoApellido} {emp.Nombres}".Trim())">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </menu>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>

        <section class="d-flex justify-content-center mt-4">
            <nav aria-label="Paginación de empleados">
                <ul class="pagination">
                    <li class="page-item @previousPageCss">
                        <form method="post" asp-page-handler="Navigate" class="d-inline">
                            <input type="hidden" name="sortBy" value="@Model.SortBy" />
                            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                            <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                            <input type="hidden" name="currentPage" value="@Model.CurrentPage" />
                            <input type="hidden" name="navigationMode" value="prev" />
                            <input type="hidden" name="cursorEmployeeId" value="@firstPageEmployeeId" />
                            <button type="submit" class="page-link" disabled="@disablePreviousPage">
                                <i class="bi bi-chevron-left me-1"></i>Anterior
                            </button>
                        </form>
                    </li>

                    <li class="page-item active">
                        <button type="button" class="page-link">@Model.CurrentPage</button>
                    </li>

                    <li class="page-item @nextPageCss">
                        <form method="post" asp-page-handler="Navigate" class="d-inline">
                            <input type="hidden" name="sortBy" value="@Model.SortBy" />
                            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                            <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                            <input type="hidden" name="currentPage" value="@Model.CurrentPage" />
                            <input type="hidden" name="navigationMode" value="next" />
                            <input type="hidden" name="cursorEmployeeId" value="@lastPageEmployeeId" />
                            <button type="submit" class="page-link" disabled="@(!Model.HasNextPage)">
                                Siguiente<i class="bi bi-chevron-right ms-1"></i>
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>
        </section>
    }
    else
    {
        <aside class="text-center text-muted py-5" style="font-family: var(--font-mono); border: 2px dashed var(--mrc-ink); border-radius: var(--radius-md);">
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <span>No se encontraron empleados para la búsqueda actual.</span>
            }
            else
            {
                <span>No hay empleados registrados en el sistema.</span>
            }
        </aside>
    }
</section>

<section class="modal fade" id="addEmployeeModal" tabindex="-1" aria-labelledby="addEmployeeModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-lg modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate autocomplete="off" id="createEmployeeForm">
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                <input type="hidden" name="CurrentPage" value="@Model.CurrentPage" />
                <input type="hidden" name="CurrentAnchorEmployeeId" value="@Model.CurrentAnchorEmployeeId" />
                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="addEmployeeModalLabel">
                        <i class="bi bi-person-badge me-2"></i> Registrar Empleado
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>
                <section class="modal-body p-4 employee-modal-body">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Identificación & Cargo</h6>
                    <section class="row g-3 mb-4">
                        <section class="col-md-5 mb-2 mb-md-0">
                            <label asp-for="NewEmployee.Ci" class="form-label fw-bold">
                                CI
                                <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Solo números, entre 7 y 8 dígitos, sin puntos ni espacios.">i</span>
                                <span asp-validation-for="NewEmployee.Ci" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="NewEmployee.Ci" type="text" class="form-control" inputmode="numeric" autocomplete="off"
                                   value="@newEmployeeCiValue" />
                        </section>
                        <section class="col-md-2 mb-2 mb-md-0">
                            <label asp-for="NewEmployee.Complemento" class="form-label fw-bold">
                                <span class="employee-label-ellipsis">Complemento</span>
                                <span class="info-tooltip" tabindex="0" data-info-message="Opcional. Si se llena, debe tener formato número+letra (ejemplo: 1A).">i</span>
                                <span asp-validation-for="NewEmployee.Complemento" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="NewEmployee.Complemento" class="form-control text-uppercase js-uppercase" autocomplete="off" data-normalize="trim-upper" />
                        </section>
                        <section class="col-md-5 mb-2 mb-md-0">
                            <label asp-for="NewEmployee.Cargo" class="form-label fw-bold">
                                Cargo
                                <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Valores permitidos: Cajero o Inventario.">i</span>
                                <span asp-validation-for="NewEmployee.Cargo" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="NewEmployee.Cargo" type="hidden" />
                            <section class="dropdown">
                                <button class="form-select text-start category-select-trigger" type="button" id="newRoleDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border: 2px solid var(--mrc-ink); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 1rem;">
                                    <span id="newRoleDropdownText" class="dropdown-fade-container">Cajero</span>
                                </button>
                                <ul class="dropdown-menu w-100 p-0 shadow-sm category-dropdown-menu role-dropdown-menu" aria-labelledby="newRoleDropdown" style="max-height: 200px; overflow-y: auto; background-color: var(--mrc-surface); border: 2px solid var(--mrc-ink); border-radius: 0; box-shadow: var(--shadow-brutal);">
                                    <li>
                                        <button type="button" class="dropdown-item role-select-item m-0 d-flex align-items-center justify-content-between" data-role-dropdown="newRole" data-value="Cajero" style="cursor: pointer; border-radius: 0; font-family: var(--font-mono); font-size: 0.9rem; padding: 0.5rem 1rem; border-bottom: 1px solid var(--mrc-ink);">
                                            <span class="text-truncate">Cajero</span>
                                            <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                                        </button>
                                    </li>
                                    <li>
                                        <button type="button" class="dropdown-item role-select-item m-0 d-flex align-items-center justify-content-between" data-role-dropdown="newRole" data-value="Inventario" style="cursor: pointer; border-radius: 0; font-family: var(--font-mono); font-size: 0.9rem; padding: 0.5rem 1rem; border-bottom: 1px solid var(--mrc-ink);">
                                            <span class="text-truncate">Inventario</span>
                                            <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                                        </button>
                                    </li>
                                </ul>
                            </section>
                        </section>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Datos Personales</h6>
                    <section class="row g-3">
                        <section class="col-md-4 mb-2 mb-md-0">
                            <label asp-for="NewEmployee.Nombres" class="form-label fw-bold">
                                Nombres
                                <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Solo letras y separadores válidos (espacio, punto, apóstrofe o guion).">i</span>
                                <span asp-validation-for="NewEmployee.Nombres" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="NewEmployee.Nombres" class="form-control" autocomplete="off" data-normalize="collapse" />
                        </section>
                        <section class="col-md-4 mb-2 mb-md-0">
                            <label asp-for="NewEmployee.PrimerApellido" class="form-label fw-bold">
                                Primer Apellido
                                <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Solo letras y separadores válidos (espacio, punto, apóstrofe o guion).">i</span>
                                <span asp-validation-for="NewEmployee.PrimerApellido" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="NewEmployee.PrimerApellido" class="form-control" autocomplete="off" data-normalize="collapse" />
                        </section>
                        <section class="col-md-4 mb-2 mb-md-0">
                            <label asp-for="NewEmployee.SegundoApellido" class="form-label fw-bold">
                                Segundo Apellido
                                <span class="info-tooltip" tabindex="0" data-info-message="Opcional. Si se llena, solo letras y separadores válidos (espacio, punto, apóstrofe o guion).">i</span>
                                <span asp-validation-for="NewEmployee.SegundoApellido" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="NewEmployee.SegundoApellido" class="form-control" autocomplete="off" data-normalize="collapse" />
                        </section>
                        <section class="col-md-6 mt-2 mt-md-4">
                            <label asp-for="NewEmployee.NumeroContacto" class="form-label fw-bold">
                                Número de teléfono/domicilio
                                <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Ingrese exactamente 8 dígitos.">i</span>
                                <span asp-validation-for="NewEmployee.NumeroContacto" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="NewEmployee.NumeroContacto" class="form-control" inputmode="numeric" autocomplete="off" data-normalize="trim" />
                        </section>
                    </section>
                </section>
                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">
                        <i class="bi bi-check-lg me-1"></i> Guardar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="editEmployeeModal" tabindex="-1" aria-labelledby="editEmployeeModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-lg modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate autocomplete="off" id="editEmployeeForm">
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                <input type="hidden" name="CurrentPage" value="@Model.CurrentPage" />
                <input type="hidden" name="CurrentAnchorEmployeeId" value="@Model.CurrentAnchorEmployeeId" />
                <input asp-for="EditEmployee.Id" type="hidden" />
                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="editEmployeeModalLabel">
                        <i class="bi bi-pencil-square me-2"></i> Actualizar Empleado
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>
                <section class="modal-body p-4 employee-modal-body">
                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Identificación & Cargo</h6>
                    <section class="row g-3 mb-4">
                        <section class="col-md-5 mb-2 mb-md-0">
                            <label asp-for="EditEmployee.Ci" class="form-label fw-bold">
                                CI
                                <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Solo números, entre 7 y 8 dígitos, sin puntos ni espacios.">i</span>
                                <span asp-validation-for="EditEmployee.Ci" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="EditEmployee.Ci" type="text" class="form-control" inputmode="numeric" autocomplete="off"
                                   value="@editEmployeeCiValue" />
                        </section>
                        <section class="col-md-2 mb-2 mb-md-0">
                            <label asp-for="EditEmployee.Complemento" class="form-label fw-bold">
                                <span class="employee-label-ellipsis">Complemento</span>
                                <span class="info-tooltip" tabindex="0" data-info-message="Opcional. Si se llena, debe tener formato número+letra (ejemplo: 1A).">i</span>
                                <span asp-validation-for="EditEmployee.Complemento" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="EditEmployee.Complemento" class="form-control text-uppercase js-uppercase" autocomplete="off" data-normalize="trim-upper" />
                        </section>
                        <section class="col-md-5 mb-2 mb-md-0">
                            <label asp-for="EditEmployee.Cargo" class="form-label fw-bold">
                                Cargo
                                <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Valores permitidos: Cajero o Inventario.">i</span>
                                <span asp-validation-for="EditEmployee.Cargo" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="EditEmployee.Cargo" type="hidden" />
                            <section class="dropdown">
                                <button class="form-select text-start category-select-trigger" type="button" id="editRoleDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border: 2px solid var(--mrc-ink); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 1rem;">
                                    <span id="editRoleDropdownText" class="dropdown-fade-container">Cajero</span>
                                </button>
                                <ul class="dropdown-menu w-100 p-0 shadow-sm category-dropdown-menu role-dropdown-menu" aria-labelledby="editRoleDropdown" style="max-height: 200px; overflow-y: auto; background-color: var(--mrc-surface); border: 2px solid var(--mrc-ink); border-radius: 0; box-shadow: var(--shadow-brutal);">
                                    <li>
                                        <button type="button" class="dropdown-item role-select-item m-0 d-flex align-items-center justify-content-between" data-role-dropdown="editRole" data-value="Cajero" style="cursor: pointer; border-radius: 0; font-family: var(--font-mono); font-size: 0.9rem; padding: 0.5rem 1rem; border-bottom: 1px solid var(--mrc-ink);">
                                            <span class="text-truncate">Cajero</span>
                                            <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                                        </button>
                                    </li>
                                    <li>
                                        <button type="button" class="dropdown-item role-select-item m-0 d-flex align-items-center justify-content-between" data-role-dropdown="editRole" data-value="Inventario" style="cursor: pointer; border-radius: 0; font-family: var(--font-mono); font-size: 0.9rem; padding: 0.5rem 1rem; border-bottom: 1px solid var(--mrc-ink);">
                                            <span class="text-truncate">Inventario</span>
                                            <i class="bi bi-check-lg check-icon d-none" style="font-size: 1.1rem; color: var(--mrc-ink);"></i>
                                        </button>
                                    </li>
                                </ul>
                            </section>
                        </section>
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <h6 class="mb-3" style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase;">Datos Personales</h6>
                    <section class="row g-3">
                        <section class="col-md-4 mb-2 mb-md-0">
                            <label asp-for="EditEmployee.Nombres" class="form-label fw-bold">
                                Nombres
                                <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Solo letras y separadores válidos (espacio, punto, apóstrofe o guion).">i</span>
                                <span asp-validation-for="EditEmployee.Nombres" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="EditEmployee.Nombres" class="form-control" autocomplete="off" data-normalize="collapse" />
                        </section>
                        <section class="col-md-4 mb-2 mb-md-0">
                            <label asp-for="EditEmployee.PrimerApellido" class="form-label fw-bold">
                                Primer Apellido
                                <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Solo letras y separadores válidos (espacio, punto, apóstrofe o guion).">i</span>
                                <span asp-validation-for="EditEmployee.PrimerApellido" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="EditEmployee.PrimerApellido" class="form-control" autocomplete="off" data-normalize="collapse" />
                        </section>
                        <section class="col-md-4 mb-2 mb-md-0">
                            <label asp-for="EditEmployee.SegundoApellido" class="form-label fw-bold">
                                Segundo Apellido
                                <span class="info-tooltip" tabindex="0" data-info-message="Opcional. Si se llena, solo letras y separadores válidos (espacio, punto, apóstrofe o guion).">i</span>
                                <span asp-validation-for="EditEmployee.SegundoApellido" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="EditEmployee.SegundoApellido" class="form-control" autocomplete="off" data-normalize="collapse" />
                        </section>
                        <section class="col-md-6 mt-2 mt-md-4">
                            <label asp-for="EditEmployee.NumeroContacto" class="form-label fw-bold">
                                Número de teléfono/domicilio
                                <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Ingrese exactamente 8 dígitos.">i</span>
                                <span asp-validation-for="EditEmployee.NumeroContacto" class="validation-icon-inline"></span>
                            </label>
                            <input asp-for="EditEmployee.NumeroContacto" class="form-control" inputmode="numeric" autocomplete="off" data-normalize="trim" />
                        </section>
                    </section>
                </section>
                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">
                        <i class="bi bi-check-lg me-1"></i> Actualizar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="deleteEmployeeModal" tabindex="-1" aria-labelledby="deleteEmployeeModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Delete">
                <input type="hidden" id="DeleteEmployeeId" name="id" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                <input type="hidden" name="CurrentPage" value="@Model.CurrentPage" />
                <input type="hidden" name="CurrentAnchorEmployeeId" value="@Model.CurrentAnchorEmployeeId" />
                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.4rem;" id="deleteEmployeeModalLabel">
                        <i class="bi bi-exclamation-octagon me-2"></i> Desactivar Empleado
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>
                <section class="modal-body p-4">
                    <p class="mb-2 fw-bold">¿Confirmas la desactivación de este empleado?</p>
                    <p class="mb-0" style="font-family: var(--font-mono);" id="deleteEmployeeName">-</p>
                </section>
                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn b-btn-danger">Confirmar</button>
                </footer>
            </form>
        </article>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        window.employeesPageConfig = {
            showCreateModal: @(Model.ShowCreateEmployeeModal.ToString().ToLowerInvariant()),
            showEditModal: @(Model.ShowEditEmployeeModal.ToString().ToLowerInvariant())
        };
    </script>
    <script src="~/js/pages/employees-page.js" asp-append-version="true"></script>
}
