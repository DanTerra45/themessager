@model Mercadito.Frontend.Pages.Users.IndexModel

<form method="post" asp-page-handler="AssignTemporaryPassword">
    <section class="modal fade" id="temporaryPasswordModal" tabindex="-1" aria-labelledby="temporaryPasswordModalLabel" aria-hidden="true">
        <section class="modal-dialog modal-dialog-centered">
            <article class="modal-content">
                <header class="modal-header">
                    <h5 class="modal-title" id="temporaryPasswordModalLabel" style="font-family: var(--font-display); font-weight: 800;">
                        <i class="bi bi-key me-2"></i> Asignar Contraseña Temporal
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>
                <section class="modal-body p-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <input asp-for="TemporaryPassword.UserId" type="hidden" />

                    <section class="mb-3">
                        <label asp-for="TemporaryPassword.Username" class="form-label fw-bold">
                            Usuario
                            <span asp-validation-for="TemporaryPassword.Username" class="validation-icon-inline"></span>
                        </label>
                        <input asp-for="TemporaryPassword.Username" class="form-control readonly-display-input" readonly />
                        <small class="text-muted d-block mt-1">La persona usuaria deberá cambiar esta contraseña al iniciar sesión.</small>
                    </section>

                    <section class="mb-3">
                        <label asp-for="TemporaryPassword.TemporaryPassword" class="form-label fw-bold">
                            Contraseña temporal
                            <span asp-validation-for="TemporaryPassword.TemporaryPassword" class="validation-icon-inline"></span>
                        </label>
                        <input asp-for="TemporaryPassword.TemporaryPassword" type="password" class="form-control" autocomplete="new-password" />
                        <small class="text-muted d-block mt-1">Debe tener entre 8 y 128 caracteres, con mayúscula, minúscula y número.</small>
                    </section>

                    <section class="mb-0">
                        <label asp-for="TemporaryPassword.ConfirmTemporaryPassword" class="form-label fw-bold">
                            Confirmar contraseña
                            <span asp-validation-for="TemporaryPassword.ConfirmTemporaryPassword" class="validation-icon-inline"></span>
                        </label>
                        <input asp-for="TemporaryPassword.ConfirmTemporaryPassword" type="password" class="form-control" autocomplete="new-password" />
                    </section>
                </section>
                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">Guardar</button>
                </footer>
            </article>
        </section>
    </section>
</form>
