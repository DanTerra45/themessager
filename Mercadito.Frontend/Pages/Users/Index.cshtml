@page "/Users"
@model Mercadito.Frontend.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Usuarios";
    var currentUsername = User.Identity?.Name ?? string.Empty;
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>USUARIOS</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Accesos al sistema y roles de seguridad</p>
    </section>
    <button type="button" class="b-btn" data-bs-toggle="modal" data-bs-target="#nuevoUsuarioModal">
        <i class="bi bi-person-plus"></i> Nuevo Usuario
    </button>
</header>

<section class="table-responsive table-shadow-safe-wrap">
    <table class="table table-hover align-middle">
        <thead class="text-center">
            <tr>
                <th>Usuario</th>
                <th>Empleado asociado</th>
                <th>Rol</th>
                <th>Correo</th>
                <th>Último login</th>
                <th>Registro</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.ActiveUsers.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center py-4 text-muted" style="font-family: var(--font-mono);">
                        No hay usuarios activos registrados.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var user in Model.ActiveUsers)
                {
                    var isCurrentUser = string.Equals(currentUsername, user.UserName, StringComparison.OrdinalIgnoreCase);
                    var isAdminUser = string.Equals(user.Role, "Admin", StringComparison.OrdinalIgnoreCase);
                    var canDeactivateUser = !isCurrentUser && !isAdminUser;
                    var canSendResetLink = !string.IsNullOrWhiteSpace(user.Email);
                    var deactivateBlockedReason = isCurrentUser
                        ? "No puedes dar de baja tu propio usuario."
                        : "No se puede dar de baja un usuario administrador.";
                    var sendResetLinkBlockedReason = "El usuario no tiene un correo asociado.";

                    <tr>
                        <td class="fw-bold" style="font-family: var(--font-mono);">@user.UserName</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(user.EmployeeFullName))
                            {
                                <span class="text-muted">Sin empleado asociado</span>
                            }
                            else
                            {
                                <section>
                                    <strong>@user.EmployeeFullName</strong>
                                    <small class="d-block text-muted">@user.EmployeeCargo</small>
                                </section>
                            }
                        </td>
                        <td>@user.Role</td>
                        <td>@(string.IsNullOrWhiteSpace(user.Email) ? "Sin correo" : user.Email)</td>
                        <td style="font-family: var(--font-mono);">@(user.LastLogin.HasValue ? user.LastLogin.Value.ToString("dd/MM/yyyy HH:mm") : "Sin ingreso")</td>
                        <td style="font-family: var(--font-mono);">@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center">
                            <div class="users-actions-wrap">
                                @if (canSendResetLink)
                                {
                                    <button type="button"
                                            class="b-btn b-btn-secondary"
                                            style="padding: 0.25rem 0.5rem;"
                                            data-bs-toggle="modal"
                                            data-bs-target="#sendResetLinkModal"
                                            data-user-id="@user.Id"
                                            data-username="@user.UserName"
                                            data-user-email="@user.Email"
                                            title="Enviar enlace de restablecimiento"
                                            aria-label="Enviar enlace de restablecimiento">
                                        <i class="bi bi-envelope"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="b-btn b-btn-secondary"
                                            style="padding: 0.25rem 0.5rem;"
                                            title="@sendResetLinkBlockedReason"
                                            aria-label="@sendResetLinkBlockedReason"
                                            disabled>
                                        <i class="bi bi-envelope"></i>
                                    </button>
                                }
                                <button type="button"
                                        class="b-btn b-btn-secondary"
                                        style="padding: 0.25rem 0.5rem;"
                                        data-bs-toggle="modal"
                                        data-bs-target="#temporaryPasswordModal"
                                        data-user-id="@user.Id"
                                        data-username="@user.UserName"
                                        title="Asignar contraseña temporal"
                                        aria-label="Asignar contraseña temporal">
                                    <i class="bi bi-key"></i>
                                </button>
                                @if (canDeactivateUser)
                                {
                                    <button type="button"
                                            class="b-btn b-btn-danger"
                                            style="padding: 0.25rem 0.5rem;"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deactivateUserModal"
                                            data-user-id="@user.Id"
                                            data-username="@user.UserName"
                                            title="Dar de baja"
                                            aria-label="Dar de baja">
                                        <i class="bi bi-person-dash"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="b-btn b-btn-secondary"
                                            style="padding: 0.25rem 0.5rem;"
                                            title="@deactivateBlockedReason"
                                            aria-label="@deactivateBlockedReason"
                                            disabled>
                                        <i class="bi bi-person-dash"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</section>

<partial name="_CreateUserModal" model="Model" />
<partial name="_SendResetLinkModal" model="Model" />
<partial name="_AssignTemporaryPasswordModal" model="Model" />
<partial name="_DeactivateUserModal" model="Model" />
<section id="usersPageConfig"
         data-show-create-modal="@Model.ShowCreateModal.ToString().ToLowerInvariant()"
         data-show-send-reset-link-modal="@Model.ShowSendResetLinkModal.ToString().ToLowerInvariant()"
         data-show-temporary-password-modal="@Model.ShowTemporaryPasswordModal.ToString().ToLowerInvariant()"
         data-show-deactivate-modal="@Model.ShowDeactivateModal.ToString().ToLowerInvariant()"
         hidden></section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/users-page.js" asp-append-version="true"></script>
}
