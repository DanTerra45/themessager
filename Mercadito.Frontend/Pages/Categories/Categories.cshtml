@page "/Categories"
@model Mercadito.Frontend.Pages.Categories.CategoriesModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Categorías";
    ViewData["UseToasts"] = true;
    var showIdColumn = bool.TryParse(Configuration["Ui:ShowIDs"], out var showIDs) && showIDs;
    var firstPageCategoryId = 0L;
    var lastPageCategoryId = 0L;
    if (Model.Categories.Count > 0)
    {
        firstPageCategoryId = Model.Categories[0].Id;
        lastPageCategoryId = Model.Categories[Model.Categories.Count - 1].Id;
    }

    var disablePreviousPage = !Model.HasPreviousPage || Model.CurrentPage <= 1;
    var previousPageCss = string.Empty;
    if (disablePreviousPage)
    {
        previousPageCss = "disabled";
    }

    var nextPageCss = string.Empty;
    if (!Model.HasNextPage)
    {
        nextPageCss = "disabled";
    }
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Organización del catálogo</p>
    </section>
    <button type="button" class="b-btn" id="openAddCategoryModal" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
        <i class="bi bi-plus-circle"></i> Nueva Categoría
    </button>
</header>

<section>
    <section class="mb-4 listing-filter-wrap">
        <form method="post" asp-page-handler="Filter" class="listing-filter-form">
            <input type="hidden" name="sortBy" value="@Model.SortBy" />
            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
            <section class="listing-search-field">
                <label for="categoriesSearchTerm" class="visually-hidden">Buscar categoría</label>
                <input type="search"
                       id="categoriesSearchTerm"
                       name="searchTerm"
                       class="form-control listing-search-input"
                       value="@Model.SearchTerm"
                       placeholder="Buscar categoría..."
                       autocomplete="off" />
            </section>
            <section class="listing-filter-actions">
                <button type="submit" class="b-btn b-btn-secondary listing-icon-btn" title="Buscar categorías" aria-label="Buscar categorías">
                    <i class="bi bi-search"></i>
                </button>
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                    <button type="submit" name="clear" value="true" class="b-btn b-btn-secondary listing-icon-btn" title="Limpiar búsqueda" aria-label="Limpiar búsqueda">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </button>
                }
            </section>
        </form>
    </section>

    @if (Model.Categories.Count > 0)
    {
        <section class="table-responsive table-shadow-safe-wrap">
            <table class="table table-hover align-middle">
                <thead class="text-center">
                    <tr>
                        @if (showIdColumn)
                        {
                            <th class="sortable-header text-center fw-normal" title="Ordenar por ID">
                                <form method="post" asp-page-handler="Sort" class="d-inline">
                                    <input type="hidden" name="sortBy" value="id" />
                                    <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                    <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                    <button type="submit" class="sort-button">
                                        ID <i class="bi @Model.GetSortIcon("id")" style="font-size: 0.8em;"></i>
                                    </button>
                                </form>
                            </th>
                        }
                        <th class="sortable-header text-center fw-bold" title="Ordenar por Código">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="code" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Código <i class="bi @Model.GetSortIcon("code")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="sortable-header text-center fw-bold" title="Ordenar por Nombre">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="name" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Nombre <i class="bi @Model.GetSortIcon("name")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="text-center fw-bold">Descripción</th>
                        <th class="sortable-header text-center fw-bold" title="Ordenar por Productos Asociados">
                            <form method="post" asp-page-handler="Sort" class="d-inline">
                                <input type="hidden" name="sortBy" value="productCount" />
                                <input type="hidden" name="currentSortBy" value="@Model.SortBy" />
                                <input type="hidden" name="currentSortDirection" value="@Model.SortDirection" />
                                <button type="submit" class="sort-button">
                                    Productos Asociados <i class="bi @Model.GetSortIcon("productCount")" style="font-size: 0.8em;"></i>
                                </button>
                            </form>
                        </th>
                        <th class="text-center fw-bold" style="width: 170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model.Categories)
                    {
                        <tr>
                            @if (showIdColumn)
                            {
                                <td class="small text-muted text-center" style="font-family: var(--font-mono);">
                                    @category.Id
                                </td>
                            }
                            <td class="text-center fw-normal">
                                <mark class="badge bg-secondary" style="font-family: var(--font-mono); font-size: 0.9rem;">@category.Code</mark>
                            </td>
                            <td class="text-center fw-normal" style="font-family: var(--font-display); font-size: 1.1rem;">
                                <span class="table-ellipsis table-ellipsis-category-name" title="@category.Name">@category.Name</span>
                            </td>
                            <td class="text-center fw-normal">
                                <span class="table-ellipsis table-ellipsis-category-description" title="@category.Description">@category.Description</span>
                            </td>
                            <td class="text-center fw-normal">
                                @{
                                    var productStatus = "good";
                                    if (category.ProductCount == 0)
                                    {
                                        productStatus = "danger";
                                    }
                                    else if (category.ProductCount <= 5)
                                    {
                                        productStatus = "warning";
                                    }
                                }

                                <mark class="status-badge" data-status="@productStatus">@category.ProductCount</mark>

                                @if (category.ProductCount > 0)
                                {
                                    <form method="post" asp-page="/Products/Products" asp-page-handler="Filter" class="d-inline">
                                        <input type="hidden" name="categoryFilter" value="@category.Id" />
                                        <button type="submit"
                                                class="b-btn b-btn-secondary ms-2 category-products-view-btn"
                                                title="Ver productos de esta categoría"
                                                aria-label="Ver productos de esta categoría">
                                            <i class="bi bi-eye-fill" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                            <td class="text-center fw-normal">
                                <menu class="d-flex justify-content-center gap-2 m-0 p-0" style="list-style: none;">
                                    <form method="post" asp-page-handler="StartEdit" class="d-inline">
                                        <input type="hidden" name="id" value="@category.Id" />
                                        <input type="hidden" name="sortBy" value="@Model.SortBy" />
                                        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                                        <button type="submit" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;"
                                                title="Editar"
                                                aria-label="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </form>
                                    
                                    <button class="b-btn b-btn-danger" style="padding: 0.25rem 0.5rem;"
                                            title="Eliminar"
                                            aria-label="Eliminar"
                                            type="button"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteCategoryModal"
                                            data-id="@category.Id"
                                            data-name="@category.Name">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </menu>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>

        <section class="d-flex justify-content-center mt-4">
            <nav aria-label="Paginación de categorías">
                <ul class="pagination">
                    <li class="page-item @previousPageCss">
                        <form method="post" asp-page-handler="Navigate" class="d-inline">
                            <input type="hidden" name="sortBy" value="@Model.SortBy" />
                            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                            <input type="hidden" name="currentPage" value="@Model.CurrentPage" />
                            <input type="hidden" name="navigationMode" value="prev" />
                            <input type="hidden" name="cursorCategoryId" value="@firstPageCategoryId" />
                            <button type="submit" class="page-link" disabled="@disablePreviousPage">
                                <i class="bi bi-chevron-left me-1"></i>Anterior
                            </button>
                        </form>
                    </li>

                    <li class="page-item active">
                        <button type="button" class="page-link">@Model.CurrentPage</button>
                    </li>

                    <li class="page-item @nextPageCss">
                        <form method="post" asp-page-handler="Navigate" class="d-inline">
                            <input type="hidden" name="sortBy" value="@Model.SortBy" />
                            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                            <input type="hidden" name="currentPage" value="@Model.CurrentPage" />
                            <input type="hidden" name="navigationMode" value="next" />
                            <input type="hidden" name="cursorCategoryId" value="@lastPageCategoryId" />
                            <button type="submit" class="page-link" disabled="@(!Model.HasNextPage)">
                                Siguiente<i class="bi bi-chevron-right ms-1"></i>
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>
        </section>
    }
    else
    {
        <aside class="text-center text-muted py-5" style="font-family: var(--font-mono); border: 2px dashed var(--mrc-ink); border-radius: var(--radius-md);">
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <span>No se encontraron categorías para la búsqueda actual.</span>
            }
            else
            {
                <span>No hay categorías registradas en el sistema.</span>
            }
        </aside>
    }
</section>

<section class="modal fade" id="deleteCategoryModal" tabindex="-1" aria-labelledby="deleteCategoryModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Delete" id="deleteCategoryForm">
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <input type="hidden" name="id" id="DeleteCategoryId" />

                <header class="modal-header" style="background-color: var(--mrc-danger); color: white;">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; color: white;" id="deleteCategoryModalLabel">
                        <i class="bi bi-exclamation-triangle me-2"></i> Confirmar eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4">
                    <p class="mb-3" style="font-size: 1.1rem;">¿Está seguro de eliminar la categoría seleccionada?</p>
                    <p class="mb-0" style="font-family: var(--font-mono); padding: 1rem; background-color: var(--mrc-surface-alt); border: 2px solid var(--mrc-ink); border-radius: var(--radius-sm);">
                        Categoría: <strong id="deleteCategoryName" style="font-size: 1.2rem;">-</strong>
                    </p>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn b-btn-danger">
                        <i class="bi bi-trash me-1"></i> Eliminar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Create" class="needs-validation" novalidate autocomplete="off" id="createCategoryForm">
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />

                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="addCategoryModalLabel">
                        <i class="bi bi-tags me-2"></i> Nueva Categoría
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4 category-modal-body">

                    <section class="mb-3">
                        <label asp-for="NewCategory.Code" class="form-label fw-bold">
                            Código
                            <span class="info-tooltip" tabindex="0" data-info-message="Autogenerado al guardar. Esta es una vista previa del siguiente código disponible.">i</span>
                            <span asp-validation-for="NewCategory.Code" class="validation-icon-inline"></span>
                        </label>
                        <input asp-for="NewCategory.Code" class="form-control category-code-readonly" value="@Model.NextCategoryCodePreview" readonly autocomplete="off" />
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <section class="mb-3">
                        <label asp-for="NewCategory.Name" class="form-label fw-bold">
                            Nombre
                            <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Máximo 150 caracteres.">i</span>
                            <span asp-validation-for="NewCategory.Name" class="validation-icon-inline"></span>
                        </label>
                        <input asp-for="NewCategory.Name" class="form-control" autocomplete="off" data-normalize="collapse" />
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <section class="mb-3">
                        <label asp-for="NewCategory.Description" class="form-label fw-bold">
                            Descripción
                            <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Máximo 150 caracteres.">i</span>
                            <span asp-validation-for="NewCategory.Description" class="validation-icon-inline"></span>
                        </label>
                        <textarea asp-for="NewCategory.Description" class="form-control category-description-textarea" autocomplete="off" rows="5" data-normalize="trim"></textarea>
                    </section>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">
                        <i class="bi bi-check-lg me-1"></i> Guardar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

<section class="modal fade" id="editCategoryModal" tabindex="-1" aria-labelledby="editCategoryModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <article class="modal-content">
            <form method="post" asp-page-handler="Edit" class="needs-validation" novalidate autocomplete="off" id="updateCategoryForm">
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <input type="hidden" asp-for="EditCategory.Id" />

                <header class="modal-header">
                    <h5 class="modal-title" style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;" id="editCategoryModalLabel">
                        <i class="bi bi-pencil-square me-2"></i> Editar Categoría
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </header>

                <section class="modal-body p-4 category-modal-body">

                    <section class="mb-3">
                        <label asp-for="EditCategory.Code" class="form-label fw-bold">
                            Código
                            <span class="info-tooltip" tabindex="0" data-info-message="Código autogenerado. Este campo no es editable.">i</span>
                            <span asp-validation-for="EditCategory.Code" class="validation-icon-inline"></span>
                        </label>
                        <input asp-for="EditCategory.Code" class="form-control fw-bold category-code-readonly" readonly autocomplete="off" />
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <section class="mb-3">
                        <label asp-for="EditCategory.Name" class="form-label fw-bold">
                            Nombre
                            <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Máximo 150 caracteres.">i</span>
                            <span asp-validation-for="EditCategory.Name" class="validation-icon-inline"></span>
                        </label>
                        <input asp-for="EditCategory.Name" class="form-control fw-bold" autocomplete="off" data-normalize="collapse" />
                    </section>

                    <hr style="border-top: 2px dashed var(--mrc-ink); opacity: 0.2;" class="my-4">

                    <section class="mb-3">
                        <label asp-for="EditCategory.Description" class="form-label fw-bold">
                            Descripción
                            <span class="info-tooltip" tabindex="0" data-info-message="Requerido. Máximo 150 caracteres.">i</span>
                            <span asp-validation-for="EditCategory.Description" class="validation-icon-inline"></span>
                        </label>
                        <textarea asp-for="EditCategory.Description" class="form-control category-description-textarea" autocomplete="off" rows="5" data-normalize="trim"></textarea>
                    </section>
                </section>

                <footer class="modal-footer">
                    <button type="button" class="b-btn b-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="b-btn">
                        <i class="bi bi-check-lg me-1"></i> Actualizar
                    </button>
                </footer>
            </form>
        </article>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        window.categoriesPageConfig = {
            showCreateModal: @(Model.ShowCreateCategoryModal.ToString().ToLowerInvariant()),
            showEditModal: @(Model.ShowEditCategoryModal.ToString().ToLowerInvariant())
        };
    </script>
    <script src="~/js/pages/categories-page.js" asp-append-version="true"></script>
}
