@page "/Sales/Reports"
@model Mercadito.Frontend.Pages.Sales.ReportsModel
@{
    ViewData["Title"] = "Reportes de ventas";
}

<header class="dash-header d-flex justify-content-between align-items-end">
    <section>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0 text-muted" style="font-family: var(--font-mono);">Comprobantes y consulta operativa de ventas registradas</p>
    </section>
    <div class="d-flex gap-2">
        <a asp-page="/Sales/Reports"
           asp-route-sortBy="@Model.SortBy"
           asp-route-sortDirection="@Model.SortDirection"
           class="b-btn b-btn-secondary listing-icon-btn dash-header-icon-btn text-decoration-none"
           title="Refrescar reportes de ventas"
           aria-label="Refrescar reportes de ventas">
            <i class="bi bi-arrow-clockwise"></i>
        </a>
    </div>
</header>

@if (Model.Errors.Count > 0)
{
    <section class="toast-container position-fixed bottom-0 end-0 p-3 app-toast-container" aria-live="polite" aria-atomic="true">
        <section class="toast align-items-center border-0 app-toast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="7000">
            <section class="d-flex position-relative">
                <section class="toast-icon d-flex align-items-center justify-content-center app-toast-icon app-toast-icon-error">
                    <i class="bi bi-exclamation-lg"></i>
                </section>
                <section class="toast-body app-toast-body">
                    <strong>No se pudo cargar toda la información de reportes.</strong>
                    <ul class="mb-0 mt-2">
                        @foreach (var error in Model.Errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </section>
                <button type="button" class="btn-close me-2 m-auto position-absolute top-0 end-0 mt-2 app-toast-close" data-bs-dismiss="toast" aria-label="Cerrar"></button>
            </section>
        </section>
    </section>
}

<section class="row g-3 mb-4">
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Comprobantes disponibles</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.RegisteredSalesCount</p>
            <small class="text-muted">Ventas registradas con comprobante consultable</small>
        </article>
    </section>
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Ventas anuladas</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.CancelledSalesCount</p>
            <small class="text-muted">Operaciones anuladas visibles en el historial</small>
        </article>
    </section>
    <section class="col-md-4">
        <article class="b-card h-100 p-3">
            <h2 style="font-family: var(--font-mono); font-size: 0.85rem; text-transform: uppercase; margin: 0 0 0.5rem 0;">Monto reportado</h2>
            <p style="font-family: var(--font-display); font-size: 2rem; margin: 0;">@Model.RegisteredAmountTotal.ToString("N2") Bs.</p>
            <small class="text-muted">Total acumulado de ventas registradas en el historial cargado</small>
        </article>
    </section>
</section>

<section class="b-card p-0 overflow-hidden sales-history-card">
    <header class="p-3 sales-history-header">
        <strong style="font-family: var(--font-display); text-transform: uppercase;">Centro de comprobantes</strong>
    </header>
    <section class="table-responsive sales-history-table-wrap">
        <table class="table table-hover align-middle mb-0 products-table sales-history-table">
            <thead class="text-center">
                <tr>
                    <th class="sortable-header text-center fw-bold" title="Ordenar por Código">
                        <a asp-page="/Sales/Reports" asp-route-sortBy="code" asp-route-sortDirection="@Model.GetNextSortDirection("code")" class="sort-button text-decoration-none">
                            Código <i class="bi @Model.GetSortIcon("code")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="sortable-header text-center fw-bold" title="Ordenar por Fecha/Hora">
                        <a asp-page="/Sales/Reports" asp-route-sortBy="createdat" asp-route-sortDirection="@Model.GetNextSortDirection("createdat")" class="sort-button text-decoration-none">
                            Fecha/Hora <i class="bi @Model.GetSortIcon("createdat")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="sortable-header text-center fw-bold" title="Ordenar por Cliente">
                        <a asp-page="/Sales/Reports" asp-route-sortBy="customer" asp-route-sortDirection="@Model.GetNextSortDirection("customer")" class="sort-button text-decoration-none">
                            Cliente <i class="bi @Model.GetSortIcon("customer")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="sortable-header text-center fw-bold" title="Ordenar por Método">
                        <a asp-page="/Sales/Reports" asp-route-sortBy="paymentmethod" asp-route-sortDirection="@Model.GetNextSortDirection("paymentmethod")" class="sort-button text-decoration-none">
                            Método <i class="bi @Model.GetSortIcon("paymentmethod")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="sortable-header text-end fw-bold" title="Ordenar por Total">
                        <a asp-page="/Sales/Reports" asp-route-sortBy="total" asp-route-sortDirection="@Model.GetNextSortDirection("total")" class="sort-button text-decoration-none">
                            Total <i class="bi @Model.GetSortIcon("total")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="sortable-header text-center fw-bold" title="Ordenar por Estado">
                        <a asp-page="/Sales/Reports" asp-route-sortBy="status" asp-route-sortDirection="@Model.GetNextSortDirection("status")" class="sort-button text-decoration-none">
                            Estado <i class="bi @Model.GetSortIcon("status")" style="font-size: 0.8em;"></i>
                        </a>
                    </th>
                    <th class="text-center products-actions-col">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.RecentSales.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">No existen ventas para reportar todavía.</td>
                    </tr>
                }
                else
                {
                    @foreach (var sale in Model.RecentSales)
                    {
                        <tr>
                            <td class="fw-bold" style="font-family: var(--font-mono);">@sale.Code</td>
                            <td style="font-family: var(--font-mono);">@sale.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@sale.CustomerName</td>
                            <td>@sale.PaymentMethod</td>
                            <td class="text-end fw-bold" style="font-family: var(--font-mono);">@sale.Total.ToString("N2") Bs.</td>
                            <td class="text-center">
                                @if (string.Equals(sale.Status, "Anulada", StringComparison.Ordinal))
                                {
                                    <mark class="status-badge" data-status="danger">@sale.Status</mark>
                                }
                                else
                                {
                                    <mark class="status-badge" data-status="success">@sale.Status</mark>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-inline-flex gap-2">
                                    <a asp-page="/Sales/Detail" asp-route-saleId="@sale.Id" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;" title="Ver detalle">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-page="/Sales/Receipt" asp-route-saleId="@sale.Id" target="_blank" rel="noopener noreferrer" class="b-btn b-btn-secondary" style="padding: 0.25rem 0.5rem;" title="Ver comprobante">
                                        <i class="bi bi-file-earmark-text"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </section>
</section>
