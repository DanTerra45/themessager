@page "/Sales/Receipt/{saleId:long?}"
@model Mercadito.Frontend.Pages.Sales.ReceiptModel
@{
    Layout = null;
    var receipt = Model.Receipt!;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Comprobante @receipt.Code - Mercadito</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/fonts-local.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        @@media print {
            @@page {
                size: auto;
                margin: 12mm;
            }

            .print-hidden {
                display: none !important;
            }

            body {
                background: white !important;
            }

            .receipt-page-shell {
                max-width: 100% !important;
                width: 100% !important;
                padding: 0 !important;
            }

            .receipt-card {
                box-shadow: none !important;
                margin: 0 !important;
            }
        }
    </style>
</head>
<body class="receipt-page-body">
    <main class="container receipt-page-shell">
        <section class="receipt-toolbar print-hidden">
            <button type="button" class="b-btn" onclick="window.print()">Imprimir</button>
        </section>

        <article class="b-card b-card-static receipt-card p-4">
            <header class="d-flex justify-content-between align-items-start gap-4 mb-4" style="border-bottom: 2px solid var(--mrc-ink); padding-bottom: 1rem;">
                <section class="d-flex align-items-center gap-3">
                    <img src="~/favicon.svg" alt="Mercadito" style="width: 72px; height: 72px;" />
                    <section>
                        <strong class="d-block" style="font-family: var(--font-display); font-size: 2rem; line-height: 1;">Mercadito</strong>
                        <span style="font-family: var(--font-mono); text-transform: uppercase;">Comprobante de Venta</span>
                    </section>
                </section>
                <section class="text-end">
                    <strong class="d-block" style="font-family: var(--font-mono);">Código</strong>
                    <span>@receipt.Code</span>
                </section>
            </header>

            <section class="row g-3 mb-4">
                <section class="col-md-4">
                    <strong class="d-block" style="font-family: var(--font-mono);">Fecha</strong>
                    <span>@receipt.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                </section>
                <section class="col-md-4">
                    <strong class="d-block" style="font-family: var(--font-mono);">CI/NIT</strong>
                    <span>@receipt.CustomerCiNit</span>
                </section>
                <section class="col-md-4">
                    <strong class="d-block" style="font-family: var(--font-mono);">Usuario</strong>
                    <span>@receipt.CreatedBy</span>
                </section>
                <section class="col-12">
                    <strong class="d-block" style="font-family: var(--font-mono);">Razón social</strong>
                    <span>@receipt.CustomerBusinessName</span>
                </section>
            </section>

            <section class="table-responsive mb-4">
                <table class="table align-middle mb-0 receipt-table">
                    <thead class="text-center">
                        <tr>
                            <th class="text-center">Cantidad</th>
                            <th>Descripción</th>
                            <th class="text-end">Precio Unitario</th>
                            <th class="text-end">Importe</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in receipt.Lines)
                        {
                            <tr>
                                <td class="text-center" style="font-family: var(--font-mono);">@line.Quantity</td>
                                <td>@line.ProductName</td>
                                <td class="text-end" style="font-family: var(--font-mono);">@line.UnitPrice.ToString("N2") Bs.</td>
                                <td class="text-end fw-bold" style="font-family: var(--font-mono);">@line.Subtotal.ToString("N2") Bs.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>

            <section class="receipt-summary">
                <strong style="font-family: var(--font-display); font-size: 1.5rem;">Total: @receipt.Total.ToString("N2") Bs.</strong>
                <span class="text-end">@receipt.AmountInWords</span>
                <small class="text-muted">Generado: @receipt.GeneratedAt.ToString("dd/MM/yyyy HH:mm")</small>
            </section>
        </article>
    </main>
</body>
</html>
