{
  "version": "1.0",
  "defaultProvider": "jsdelivr",
  "libraries": [
    {
      "library": "bootstrap@5.3.8",
      "destination": "wwwroot/lib/bootstrap/",
      "files": [
        "dist/css/bootstrap.min.css",
        "dist/js/bootstrap.bundle.min.js",
        "LICENSE"
      ]
    },
    {
      "library": "jquery@4.0.0",
      "destination": "wwwroot/lib/jquery/",
      "files": [
        "dist/jquery.min.js",
        "LICENSE.txt"
      ]
    },
    {
      "library": "jquery-validation@1.22.1",
      "destination": "wwwroot/lib/jquery-validation/",
      "files": [
        "dist/jquery.validate.min.js",
        "LICENSE.md"
      ]
    },
    {
      "library": "jquery-validation-unobtrusive@4.0.0",
      "destination": "wwwroot/lib/jquery-validation-unobtrusive/",
      "files": [
        "dist/jquery.validate.unobtrusive.min.js",
        "LICENSE.txt"
      ]
    },
    {
      "library": "bootstrap-icons@1.13.1",
      "destination": "wwwroot/lib/bootstrap-icons/",
      "files": [
        "font/bootstrap-icons.min.css",
        "font/fonts/bootstrap-icons.woff2",
        "font/fonts/bootstrap-icons.woff",
        "LICENSE"
      ]
    },
    {
      "library": "air-datepicker@3.6.0",
      "destination": "wwwroot/lib/air-datepicker",
      "files": [
        "air-datepicker.js",
        "air-datepicker.css",
        "locale/es.js"
      ]
    },
    {
      "library": "@fontsource-variable/bricolage-grotesque@5.2.10",
      "destination": "wwwroot/lib/fonts/bricolage-grotesque/",
      "files": [
        "files/bricolage-grotesque-latin-wght-normal.woff2",
        "LICENSE"
      ]
    },
    {
      "library": "@fontsource-variable/chivo-mono@5.2.8",
      "destination": "wwwroot/lib/fonts/chivo-mono/",
      "files": [
        "files/chivo-mono-latin-wght-normal.woff2",
        "LICENSE"
      ]
    },
    {
      "library": "@fontsource-variable/dm-sans@5.2.8",
      "destination": "wwwroot/lib/fonts/dm-sans/",
      "files": [
        "files/dm-sans-latin-wght-normal.woff2",
        "LICENSE"
      ]
    }
  ]
}
